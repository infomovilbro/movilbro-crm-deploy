<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="ri-bank-card-line"></i> Remesas</h2>
  </div>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-warning"><%= error %></div><% } %>
  <div class="row g-3 mb-3">
    <a href="/remittances" class="text-decoration-none col-md-4 col-6 stat-card-item"><div class="stat-card" style="background:#f8f9fa;border-left:3px solid var(--primary);border-radius:10px;padding:16px;"><div style="display:flex;align-items:center;gap:12px;"><span style="font-size:2rem;">🏦</span><div><div class="stat-value" style="font-size:24px;font-weight:700;color:#222;"><%= remittances.length %></div><div class="stat-label" style="font-size:13px;color:#6c757d;font-weight:500;">Total Remesas</div></div></div></div></a>
    <a href="/remittances" class="text-decoration-none col-md-4 col-6 stat-card-item"><div class="stat-card" style="background:#f8f9fa;border-left:3px solid #28a745;border-radius:10px;padding:16px;"><div style="display:flex;align-items:center;gap:12px;"><span style="font-size:2rem;">✅</span><div><div class="stat-value" style="font-size:24px;font-weight:700;color:#222;"><%= remittances.filter(r => (r.status||'').toUpperCase() === 'PAID' || (r.status||'').toUpperCase() === 'COMPLETED').length %></div><div class="stat-label" style="font-size:13px;color:#6c757d;font-weight:500;">Pagadas</div></div></div></div></a>
    <a href="/remittances" class="text-decoration-none col-md-4 col-6 stat-card-item"><div class="stat-card" style="background:#f8f9fa;border-left:3px solid #ffc107;border-radius:10px;padding:16px;"><div style="display:flex;align-items:center;gap:12px;"><span style="font-size:2rem;">⏳</span><div><div class="stat-value" style="font-size:24px;font-weight:700;color:#222;"><%= remittances.filter(r => (r.status||'').toUpperCase() === 'PENDING').length %></div><div class="stat-label" style="font-size:13px;color:#6c757d;font-weight:500;">Pendientes</div></div></div></div></a>
  </div>
  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover">
          <thead><tr><th>ID</th><th>Cliente</th><th>Importe</th><th>Estado</th><th>Fecha</th><th></th></tr></thead>
          <tbody>
            <% if (!remittances || remittances.length === 0) { %>
            <tr><td colspan="6" class="text-center text-muted py-4">No hay remesas</td></tr>
            <% } else { remittances.forEach(r => { 
              const st = (r.status||'').toUpperCase();
              const sc = st === 'PAID' || st === 'COMPLETED' ? 'success' : st === 'PENDING' ? 'warning' : st === 'CANCELED' ? 'secondary' : 'danger';
            %>
            <tr>
              <td><%= r.id || r.remesaId || '-' %></td>
              <td><%= r.customerName || r.name || '-' %></td>
              <td><%= r.amount || r.importe ? (r.amount || r.importe) + '€' : '-' %></td>
              <td><span class="badge bg-<%= sc %>"><%= st %></span></td>
              <td class="small"><%= r.date || r.fecha ? new Date(r.date || r.fecha).toLocaleDateString('es-ES') : '-' %></td>
              <td><button class="btn btn-sm btn-outline-primary"><i class="ri-eye-line"></i></button></td>
            </tr>
            <% }); } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
