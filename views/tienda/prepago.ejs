<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-sim"></i> Clientes Prepago</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalPrepago"><i class="bi bi-plus-lg"></i> Nuevo Cliente Prepago</button>
  </div>

  <% var mesNombres = ['','Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre']; %>

  <!-- Historial por Meses -->
  <div class="card mb-3 hideable-section" data-card-id="prepago-meses">
    <div class="card-header"><i class="bi bi-folder"></i> Historial de Pagos por Meses</div>
    <div class="card-body">
      <div class="row g-1 mb-0">
      <% meses.forEach((m) => { %>
        <% var todosPagados = m.total > 0 && m.pagados === m.total; %>
        <% var color = todosPagados ? 'success' : (m.pagados > 0 ? 'danger' : 'secondary') %>
        <div class="col-md-1 col-2 text-center" style="cursor:pointer;" onclick="cambiarMes(<%= m.mes %>)">
          <div class="p-1 rounded bg-<%= color %> text-white small mes-cuadro <%= m.mes === mesActual ? 'mes-activo' : '' %>" data-mes="<%= m.mes %>" style="min-height:48px;display:flex;flex-direction:column;justify-content:center;align-items:center;">
            <div><%= m.label.substring(0,3) %></div>
            <div class="fw-bold"><%= m.pagados %>/<%= m.total %></div>
          </div>
        </div>
      <% }) %>
      </div>
    </div>
  </div>

  <!-- Cobrar Panel -->
  <div class="card mb-4 border-primary hideable-section" data-card-id="prepago-cobrar">
    <div class="card-header bg-primary text-white"><i class="bi bi-cash-coin"></i> Cobrar Prepago — <%= mesNombres[mesActual] %> <%= anoActual %></div>
    <div class="card-body">
      <div class="row g-2 align-items-end">
        <div class="col-md-5">
          <label class="form-label">Cliente</label>
          <select id="cobrarCliente" class="form-select">
            <option value="">Seleccionar cliente...</option>
            <% clientes.forEach(c => { %>
              <option value="<%= c.id %>" data-importe="<%= c.importe %>"><%= c.nombre %> — <%= (c.importe || 0).toFixed(2) %>€/mes</option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">Importe</label>
          <input type="text" id="cobrarImporte" class="form-control" readonly>
        </div>
        <div class="col-md-2">
          <label class="form-label">Método de pago</label>
          <select id="cobrarMetodo" class="form-select">
            <option value="efectivo">Efectivo</option>
            <option value="tarjeta">Tarjeta</option>
            <option value="stripe">Stripe</option>
          </select>
        </div>
        <div class="col-md-2">
          <button class="btn btn-success w-100" id="btnCobrarPrepago"><i class="bi bi-check-lg"></i> Cobrar</button>
        </div>
      </div>
      <div id="cobrarMensaje" class="mt-2"></div>
    </div>
  </div>

  <!-- Estado del Mes -->
  <div class="card mb-3 hideable-section" data-card-id="prepago-estado">
    <div class="card-header"><i class="bi bi-check2-square"></i> Estado de Pagos — <span id="tituloMes"><%= mesNombres[mesActual] %></span></div>
    <div class="card-body p-0">
      <table class="table table-hover mb-0" id="tablaEstadoPrepago">
        <thead><tr><th>Nombre</th><th>Importe</th><th>Estado</th><th>Método</th><th>Acción</th></tr></thead>
        <tbody>
        <% clientes.forEach(c => { %>
          <% var pagados = (c.meses_pagados || '').split(',').map(Number); %>
          <% var pagadoEsteMes = pagados.includes(mesActual); %>
          <% var metodoPago = ''; %>
          <% try { var mp = JSON.parse(metodoPorCliente); if (mp[c.nombre] && mp[c.nombre][mesActual]) metodoPago = mp[c.nombre][mesActual]; } catch(e) {} %>
          <tr class="<%= pagadoEsteMes ? 'table-success' : '' %> prepago-row" data-id="<%= c.id %>" data-importe="<%= c.importe || 0 %>" data-meses-pagados="<%= c.meses_pagados || '' %>" data-metodo-pago="<%= metodoPago %>">
            <td><%= c.nombre %></td>
            <td><%= (c.importe || 0).toFixed(2) %>€</td>
            <td class="estado-cell">
              <% if (pagadoEsteMes) { %>
                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Pagado</span>
              <% } else { %>
                <span class="badge bg-warning text-dark">Pendiente</span>
              <% } %>
            </td>
            <td class="metodo-cell"><%= metodoPago || '-' %></td>
            <td class="accion-cell">
              <% if (!pagadoEsteMes) { %>
                <button class="btn btn-sm btn-outline-success cobrar-rapido" data-id="<%= c.id %>" data-nombre="<%= c.nombre %>" data-importe="<%= c.importe %>"><i class="bi bi-cash"></i> Cobrar</button>
              <% } else { %>
                <button class="btn btn-sm btn-outline-secondary cobrar-rapido" data-id="<%= c.id %>" data-nombre="<%= c.nombre %>" data-importe="<%= c.importe %>"><i class="bi bi-arrow-repeat"></i> Cobrado</button>
              <% } %>
            </td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Clientes Finalizados -->
  <div class="card mb-3">
    <div class="card-header bg-dark text-white"><i class="bi bi-check-circle"></i> Clientes Finalizados</div>
    <div class="card-body p-0">
      <table class="table table-hover mb-0">
        <thead><tr><th>Nombre</th><th>Teléfono</th><th>Importe</th><th>Acciones</th></tr></thead>
        <tbody>
        <% if (finalizados.length === 0) { %>
          <tr><td colspan="4" class="text-center text-muted py-3">No hay clientes finalizados</td></tr>
        <% } else { finalizados.forEach(c => { %>
          <tr class="table-secondary">
            <td><%= c.nombre %> <%= c.apellidos || '' %></td>
            <td><%= c.telefono || '-' %></td>
            <td><%= (c.importe || 0).toFixed(2) %>€</td>
            <td>
              <button class="btn btn-sm btn-outline-secondary reactivar-prepago" data-id="<%= c.id %>"><i class="bi bi-arrow-counterclockwise"></i> Reactivar</button>
            </td>
          </tr>
        <% }) } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Todos los clientes -->
  <div class="card">
    <div class="card-header" style="cursor:pointer;" data-bs-toggle="collapse" data-bs-target="#collapseTodosPrepago"><i class="bi bi-list"></i> Todos los Clientes Prepago <i class="bi bi-chevron-down float-end"></i></div>
    <div class="collapse" id="collapseTodosPrepago">
    <div class="card-body p-0">
      <table class="table table-hover mb-0" id="tablaPrepago">
        <thead><tr><th>Nombre</th><th>Teléfono</th><th>DNI/NIF</th><th>Línea</th><th>ICCID</th><th>PIN/PUK</th><th>Operador</th><th>Importe</th><th>Estado</th><th>Acciones</th></tr></thead>
        <tbody>
        <% if (clientes.length === 0) { %>
          <tr><td colspan="10" class="text-center text-muted py-4"><i class="bi bi-sim" style="font-size:2rem;display:block;margin-bottom:8px;"></i>No hay clientes prepago registrados</td></tr>
        <% } else { clientes.forEach(c => { %>
          <% var pagados = (c.meses_pagados || '').split(',').map(Number); %>
          <tr>
            <td><%= c.nombre %> <%= c.apellidos || '' %></td>
            <td><%= c.telefono || '-' %></td>
            <td><%= c.dni_nif || '-' %></td>
            <td><%= c.linea || '-' %></td>
            <td class="small"><%= c.iccid ? c.iccid.substring(0,10)+'...' : '-' %></td>
            <td class="small">PIN: <%= c.pin || '-' %> | PUK: <%= c.puk || '-' %></td>
            <td><%= c.operador %></td>
            <td><%= (c.importe || 0).toFixed(2) %>€</td>
            <td>
              <span class="badge bg-<%= pagados.includes(mesActual) ? 'success' : 'warning' %>">
                <%= pagados.includes(mesActual) ? 'Pagado' : 'Pendiente' %>
              </span>
            </td>
            <td>
              <button class="btn btn-sm btn-outline-primary editar-prepago" data-id="<%= c.id %>" data-nombre="<%= c.nombre %>" data-apellidos="<%= c.apellidos || '' %>" data-dni="<%= c.dni_nif || '' %>" data-tel="<%= c.telefono || '' %>" data-email="<%= c.email || '' %>" data-pin="<%= c.pin || '' %>" data-puk="<%= c.puk || '' %>" data-op="<%= c.operador %>" data-linea="<%= c.linea || '' %>" data-iccid="<%= c.iccid || '' %>" data-importe="<%= c.importe || 0 %>" data-estado="<%= c.estado %>" data-notas="<%= c.notas || '' %>"><i class="bi bi-pencil"></i></button>
              <button class="btn btn-sm btn-outline-danger eliminar-prepago" data-id="<%= c.id %>"><i class="bi bi-trash"></i></button>
            </td>
          </tr>
        <% }) } %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- Modal Nuevo Prepago -->
