  <div class="modal-dialog modal-lg"><div class="modal-content">
    <form method="POST" action="/tienda/prepago/crear">
      <div class="modal-header"><h5><i class="bi bi-sim"></i> Nuevo Cliente Prepago</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
