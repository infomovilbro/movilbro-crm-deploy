<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-shield-person"></i> Gestión de Agentes</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalNuevoAgente"><i class="bi bi-plus-lg"></i> Nuevo Agente</button>
  </div>

  <div class="card">
    <div class="card-body p-0 table-responsive">
      <table class="table table-hover mb-0" style="white-space:nowrap;">
        <thead><tr><th>Usuario</th><th>Nombre</th><th>Email</th><th>Puesto</th><th>Rol</th><th>Estado</th><th>Permisos</th><th>Acciones</th></tr></thead>
        <tbody>
        <% if (agentes.length === 0) { %>
          <tr><td colspan="8" class="text-center text-muted py-4"><i class="bi bi-people" style="font-size:2rem;display:block;margin-bottom:8px;"></i>No hay agentes registrados</td></tr>
        <% } else { agentes.forEach(function(a) { %>
          <tr>
            <td><%= a.username || '-' %></td>
            <td><%= a.nombre %> <%= a.apellidos || '' %></td>
            <td><%= a.email || '-' %></td>
            <td><%= a.puesto || '-' %></td>
            <td><span class="badge bg-<%= a.rol === 'admin' ? 'danger' : 'primary' %>"><%= a.rol || 'user' %></span></td>
            <td><span class="badge bg-<%= a.activo !== 0 ? 'success' : 'secondary' %>"><%= a.activo !== 0 ? 'Activo' : 'Inactivo' %></span></td>
            <td class="small">
              <% try { var p = JSON.parse(a.permissions || '{}'); } catch(e) { var p = {}; } %>
              <% var allKeys = Object.keys(p).filter(function(k) { return k.startsWith('tienda_') || k.startsWith('crm_') || k.startsWith('postventa_') || k.startsWith('redes_'); }); %>
              <% allKeys.forEach(function(k) { %>
                <span class="badge bg-info me-1" style="font-size:0.65rem;"><%= k.replace(/^(tienda_|crm_|postventa_|redes_)/, '').replace(/_/g, ' ') %></span>
              <% }) %>
              <% if (allKeys.length === 0) { %><span class="text-muted">-</span><% } %>
            </td>
            <td>
              <button class="btn btn-sm btn-outline-primary editar-agente" data-id="<%= a.id %>" data-username="<%= a.username || '' %>" data-nombre="<%= a.nombre %>" data-apellidos="<%= a.apellidos || '' %>" data-email="<%= a.email || '' %>" data-puesto="<%= a.puesto || '' %>" data-salario="<%= a.salario || 0 %>" data-rol="<%= a.rol || 'user' %>" data-activo="<%= a.activo !== undefined ? a.activo : 1 %>" data-permissions='<%= JSON.stringify(a.permissions || "{}") %>'><i class="bi bi-pencil"></i></button>
              <button class="btn btn-sm btn-outline-danger eliminar-agente" data-id="<%= a.id %>"><i class="bi bi-trash"></i></button>
            </td>
          </tr>
        <% }) } %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- Modal Nuevo Agente -->
<div class="modal fade" id="modalNuevoAgente" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
    <form id="formNuevoAgente">
      <div class="modal-header"><h5><i class="bi bi-person-plus"></i> Nuevo Agente</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <div class="row g-2 mb-2">
          <div class="col-md-3"><label class="form-label">Usuario *</label><input type="text" name="username" class="form-control" required></div>
          <div class="col-md-3"><label class="form-label">Contraseña *</label><input type="password" name="password" class="form-control" required></div>
          <div class="col-md-3"><label class="form-label">Rol</label><select name="rol" class="form-select"><option value="user">Usuario</option><option value="admin">Admin</option></select></div>
          <div class="col-md-3"><label class="form-label">Activo</label><select name="activo" class="form-select"><option value="1">Sí</option><option value="0">No</option></select></div>
        </div>
        <div class="row g-2 mb-2">
          <div class="col-md-4"><label class="form-label">Nombre *</label><input type="text" name="nombre" class="form-control" required></div>
          <div class="col-md-4"><label class="form-label">Apellidos</label><input type="text" name="apellidos" class="form-control"></div>
          <div class="col-md-4"><label class="form-label">Email</label><input type="email" name="email" class="form-control"></div>
        </div>
        <div class="row g-2 mb-3">
          <div class="col-md-4"><label class="form-label">Puesto</label><select name="puesto" class="form-select"><option value="">Seleccionar</option><option value="dependiente">Dependiente</option><option value="gerente">Gerente</option><option value="tecnico">Técnico</option><option value="administrativo">Administrativo</option></select></div>
          <div class="col-md-4"><label class="form-label">Salario (€)</label><input type="number" step="0.01" name="salario" class="form-control" value="0"></div>
        </div>

        <h6 class="border-bottom pb-2 mb-2"><i class="bi bi-shield-lock"></i> Permisos del Sistema</h6>
        <div id="perm-container">
          <% var groupIdx = 0; %>
          <% Object.keys(sections).forEach(function(groupName) { %>
            <% var group = sections[groupName]; %>
            <% groupIdx++; var gid = 'new-g' + groupIdx; %>
            <div class="card mb-2 border-<%= groupName === 'Panel Tienda' ? 'success' : groupName === 'Panel Clientes' ? 'primary' : groupName === 'PostVenta' ? 'warning' : '' %>" style="border-left:3px solid <%= group.color %>;">
              <div class="card-header py-2 d-flex align-items-center" style="cursor:pointer;" onclick="togglePermGroup(this, '<%= gid %>')">
                <i class="bi bi-chevron-right me-2 perm-arrow-<%= gid %>"></i>
                <strong><%= groupName %></strong>
                <span class="ms-2 text-muted small"><%= Object.keys(group.sections).length %> secciones</span>
              </div>
              <div id="<%= gid %>" style="display:none;" class="card-body py-2">
                <% Object.keys(group.sections).forEach(function(section) { %>
                  <% var sectionLabel = section.charAt(0).toUpperCase() + section.slice(1).replace(/_/g, ' '); %>
                  <div class="perm-group mb-1">
                    <div class="d-flex align-items-center">
                      <input class="form-check-input me-2 perm-section-check" type="checkbox" data-group="<%= gid %>" data-prefix="<%= group.prefix %>" data-section="<%= section %>" id="<%= gid %>-<%= section %>" checked>
                      <label class="form-check-label fw-medium small" for="<%= gid %>-<%= section %>"><%= sectionLabel %></label>
                      <button type="button" class="btn btn-sm btn-link text-muted p-0 ms-2" onclick="togglePermActions(this, '<%= gid %>-<%= section %>-actions')"><i class="bi bi-gear"></i></button>
                    </div>
                    <div id="<%= gid %>-<%= section %>-actions" style="display:none;" class="ms-4 ps-2 mb-1" style="border-left:2px solid #dee2e6;">
                      <% group.sections[section].forEach(function(action) { %>
                        <div class="form-check form-check-inline">
                          <input class="form-check-input perm-action" type="checkbox" data-parent="<%= section %>" name="perm_<%= group.prefix %>_<%= section %>_<%= action %>" value="1" checked>
                          <label class="form-check-label small"><%= action.charAt(0).toUpperCase() + action.slice(1).replace(/_/g, ' ') %></label>
                        </div>
                      <% }) %>
                    </div>
                  </div>
                  <hr class="my-1">
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Guardar</button>
      </div>
    </form>
  </div></div>
</div>

<!-- Modal Editar Agente -->
<div class="modal fade" id="modalEditarAgente" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
    <form id="formEditarAgente">
      <input type="hidden" name="id" id="edit-id">
      <div class="modal-header"><h5><i class="bi bi-pencil"></i> Editar Agente</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <div class="row g-2 mb-2">
          <div class="col-md-3"><label class="form-label">Usuario</label><input type="text" name="username" id="edit-username" class="form-control" readonly></div>
          <div class="col-md-3"><label class="form-label">Nueva contraseña</label><input type="password" name="password" class="form-control" placeholder="Dejar vacío para mantener"></div>
          <div class="col-md-3"><label class="form-label">Rol</label><select name="rol" id="edit-rol" class="form-select"><option value="user">Usuario</option><option value="admin">Admin</option></select></div>
          <div class="col-md-3"><label class="form-label">Activo</label><select name="activo" id="edit-activo" class="form-select"><option value="1">Sí</option><option value="0">No</option></select></div>
        </div>
        <div class="row g-2 mb-2">
          <div class="col-md-4"><label class="form-label">Nombre *</label><input type="text" name="nombre" id="edit-nombre" class="form-control" required></div>
          <div class="col-md-4"><label class="form-label">Apellidos</label><input type="text" name="apellidos" id="edit-apellidos" class="form-control"></div>
          <div class="col-md-4"><label class="form-label">Email</label><input type="email" name="email" id="edit-email" class="form-control"></div>
        </div>
        <div class="row g-2 mb-3">
          <div class="col-md-4"><label class="form-label">Puesto</label><select name="puesto" id="edit-puesto" class="form-select"><option value="">Seleccionar</option><option value="dependiente">Dependiente</option><option value="gerente">Gerente</option><option value="tecnico">Técnico</option><option value="administrativo">Administrativo</option></select></div>
          <div class="col-md-4"><label class="form-label">Salario (€)</label><input type="number" step="0.01" name="salario" id="edit-salario" class="form-control"></div>
        </div>

        <h6 class="border-bottom pb-2 mb-2"><i class="bi bi-shield-lock"></i> Permisos del Sistema</h6>
        <div id="edit-perm-container">
          <% var eGroupIdx = 0; %>
          <% Object.keys(sections).forEach(function(groupName) { %>
            <% var group = sections[groupName]; %>
            <% eGroupIdx++; var egid = 'edit-g' + eGroupIdx; %>
            <div class="card mb-2 border-<%= groupName === 'Panel Tienda' ? 'success' : groupName === 'Panel Clientes' ? 'primary' : groupName === 'PostVenta' ? 'warning' : '' %>" style="border-left:3px solid <%= group.color %>;">
              <div class="card-header py-2 d-flex align-items-center" style="cursor:pointer;" onclick="togglePermGroup(this, '<%= egid %>')">
                <i class="bi bi-chevron-right me-2 perm-arrow-<%= egid %>"></i>
                <strong><%= groupName %></strong>
                <span class="ms-2 text-muted small"><%= Object.keys(group.sections).length %> secciones</span>
              </div>
              <div id="<%= egid %>" style="display:none;" class="card-body py-2">
                <% Object.keys(group.sections).forEach(function(section) { %>
                  <% var sectionLabel = section.charAt(0).toUpperCase() + section.slice(1).replace(/_/g, ' '); %>
                  <div class="perm-group mb-1">
                    <div class="d-flex align-items-center">
                      <input class="form-check-input me-2 perm-section-check" type="checkbox" data-prefix="<%= group.prefix %>" data-section="<%= section %>" id="<%= egid %>-<%= section %>">
                      <label class="form-check-label fw-medium small" for="<%= egid %>-<%= section %>"><%= sectionLabel %></label>
                      <button type="button" class="btn btn-sm btn-link text-muted p-0 ms-2" onclick="togglePermActions(this, '<%= egid %>-<%= section %>-actions')"><i class="bi bi-gear"></i></button>
                    </div>
                    <div id="<%= egid %>-<%= section %>-actions" style="display:none;" class="ms-4 ps-2 mb-1" style="border-left:2px solid #dee2e6;">
                      <% group.sections[section].forEach(function(action) { %>
                        <div class="form-check form-check-inline">
                          <input class="form-check-input perm-action" type="checkbox" data-parent="<%= section %>" name="perm_<%= group.prefix %>_<%= section %>_<%= action %>" value="1">
                          <label class="form-check-label small"><%= action.charAt(0).toUpperCase() + action.slice(1).replace(/_/g, ' ') %></label>
                        </div>
                      <% }) %>
                    </div>
                  </div>
                  <hr class="my-1">
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Guardar Cambios</button>
      </div>
    </form>
  </div></div>
</div>

<script>
function togglePermGroup(el, gid) {
  var arrow = el.querySelector('.perm-arrow-' + gid);
  var body = document.getElementById(gid);
  if (body.style.display === 'none') {
    body.style.display = 'block';
    if (arrow) arrow.className = 'bi bi-chevron-down me-2 perm-arrow-' + gid;
  } else {
    body.style.display = 'none';
    if (arrow) arrow.className = 'bi bi-chevron-right me-2 perm-arrow-' + gid;
  }
}

function togglePermActions(btn, id) {
  var el = document.getElementById(id);
  if (el.style.display === 'none') {
    el.style.display = 'block';
    btn.innerHTML = '<i class="bi bi-gear-fill"></i>';
  } else {
    el.style.display = 'none';
    btn.innerHTML = '<i class="bi bi-gear"></i>';
  }
}

document.addEventListener('DOMContentLoaded', function() {
  // Toggle sub-permissions when section checkbox changes
  document.querySelectorAll('.perm-section-check').forEach(function(cb) {
    cb.addEventListener('change', function() {
      var section = this.dataset.section;
      var container = this.closest('.perm-group') || this.closest('.card-body');
      var actions = container ? container.querySelectorAll('.perm-action[data-parent="' + section + '"]') : [];
      actions.forEach(function(a) { a.checked = cb.checked; });
    });
  });

  // Nuevo agente
  document.getElementById('formNuevoAgente').addEventListener('submit', function(e) {
    e.preventDefault();
    var form = new FormData(this);
    var data = {};
    form.forEach(function(v, k) { data[k] = v; });
    fetch('/tienda/plantilla/crear', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify(data)
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.ok) location.reload();
      else alert(d.error || 'Error al crear agente');
    }).catch(function(err) {
      alert('Error de conexión: ' + err.message);
    });
  });

  // Editar agente - populate modal
  document.querySelectorAll('.editar-agente').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('edit-id').value = this.dataset.id;
      document.getElementById('edit-username').value = this.dataset.username;
      document.getElementById('edit-nombre').value = this.dataset.nombre;
      document.getElementById('edit-apellidos').value = this.dataset.apellidos;
      document.getElementById('edit-email').value = this.dataset.email;
      document.getElementById('edit-puesto').value = this.dataset.puesto;
      document.getElementById('edit-salario').value = this.dataset.salario;
      document.getElementById('edit-rol').value = this.dataset.rol;
      document.getElementById('edit-activo').value = this.dataset.activo;
      // Restore permissions
      try { var perms = JSON.parse(this.dataset.permissions); } catch(e) { var perms = {}; }
      document.querySelectorAll('#formEditarAgente [name^="perm_"]').forEach(function(cb) {
        var key = cb.name.replace('perm_', '');
        cb.checked = !!perms[key];
      });
      // Toggle section checkboxes based on actions
      document.querySelectorAll('#formEditarAgente .perm-section-check').forEach(function(cb) {
        var section = cb.dataset.section;
        var container = cb.closest('.card-body');
        var actions = container ? container.querySelectorAll('.perm-action[data-parent="' + section + '"]') : [];
        var allChecked = true;
        actions.forEach(function(a) { if (!a.checked) allChecked = false; });
        cb.checked = allChecked;
      });
      new bootstrap.Modal(document.getElementById('modalEditarAgente')).show();
    });
  });

  // Editar agente - submit
  document.getElementById('formEditarAgente').addEventListener('submit', function(e) {
    e.preventDefault();
    var form = new FormData(this);
    var data = {};
    form.forEach(function(v, k) { data[k] = v; });
    fetch('/tienda/plantilla/editar', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify(data)
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.ok) location.reload();
      else alert(d.error || 'Error al guardar');
    }).catch(function(err) {
      alert('Error de conexión: ' + err.message);
    });
  });

  // Eliminar
  document.querySelectorAll('.eliminar-agente').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (!confirm('¿Eliminar este agente?')) return;
      fetch('/tienda/plantilla/eliminar', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ id: parseInt(this.dataset.id) })
      }).then(function(r) { return r.json(); }).then(function(d) {
        if (d.ok) location.reload();
        else alert(d.error || 'Error al eliminar');
      }).catch(function(err) {
        alert('Error de conexión: ' + err.message);
      });
    });
  });
});
</script>
