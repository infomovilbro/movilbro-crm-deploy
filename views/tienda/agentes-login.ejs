<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Movilbro CRM</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body { background: linear-gradient(135deg, #0050A1 0%, #003366 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .login-card { background: #fff; border-radius: 16px; padding: 40px; width: 100%; max-width: 400px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
    .login-logo { text-align: center; margin-bottom: 24px; }
    .login-logo img { width: 64px; height: 64px; border-radius: 12px; }
    .login-logo h4 { margin-top: 12px; font-weight: 700; color: #0050A1; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="login-logo">
      <img src="/img/logo.jpg" alt="Logo">
      <h4>Acceso Agentes</h4>
      <p class="text-muted small">Introduce usuario y contraseña</p>
    </div>
    <% if (error) { %><div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle"></i> <%= error %></div><% } %>
    <% if (success) { %><div class="alert alert-success py-2"><i class="bi bi-check-circle"></i> <%- success %></div><% } %>
    
    <form method="POST" action="/tienda/agentes/login">
      <div class="mb-3">
        <label class="form-label">Usuario</label>
        <input type="text" name="username" class="form-control" value="movilbro" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Contraseña</label>
        <input type="password" name="password" class="form-control" required>
      </div>
      <button type="submit" class="btn btn-primary w-100"><i class="bi bi-box-arrow-in-right"></i> Acceder</button>
    </form>
    
    <hr class="my-3">
    <form method="POST" action="/tienda/agentes/solicitar">
      <label class="form-label small">¿Olvidaste la contraseña?</label>
      <div class="input-group">
        <input type="email" name="email" class="form-control" placeholder="tu@email.com" required>
        <button type="submit" class="btn btn-outline-primary">Recuperar</button>
      </div>
    </form>
  </div>
</body>
</html>
