<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-circle"></i> Mi Perfil</h2>
  </div>

  <div class="row g-3">
    <div class="col-md-4">
      <div class="card text-center hideable-section" data-card-id="perfil-avatar">
        <div class="card-body">
          <div class="display-1 mb-2" style="width:100px;height:100px;line-height:100px;border-radius:50%;background:var(--primary-gradient, #0d6efd);color:#fff;margin:0 auto;"><%= (user.nombre || 'U').charAt(0).toUpperCase() %></div>
          <h4 class="mt-2"><%= user.nombre %></h4>
          <span class="badge bg-primary"><%= user.rol %></span>
          <hr>
          <p class="text-muted mb-1"><i class="bi bi-envelope"></i> <%= user.email || 'Sin email' %></p>
          <p class="text-muted mb-1"><i class="bi bi-person-badge"></i> <%= user.username %></p>
          <p class="text-muted"><i class="bi bi-calendar3"></i> Miembro desde <%= new Date(user.created_at).toLocaleDateString('es-ES', { year:'numeric', month:'long' }) %></p>
        </div>
      </div>
    </div>
    <div class="col-md-8">
      <div class="card hideable-section" data-card-id="perfil-info"><div class="card-header"><i class="bi bi-shield-check"></i> Información de la Cuenta</div><div class="card-body">
        <table class="table">
          <tr><th>Usuario</th><td><%= user.username %></td></tr>
          <tr><th>Nombre</th><td><%= user.nombre %></td></tr>
          <tr><th>Email</th><td><%= user.email || '-' %></td></tr>
          <tr><th>Rol</th><td><span class="badge bg-primary"><%= user.rol %></span></td></tr>
          <tr><th>ID</th><td>#<%= user.id %></td></tr>
        </table>
      </div></div>
    </div>
  </div>
</section>
