<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-clock-history"></i> Historial del Día</h2>
    <div class="d-flex gap-2">
    <% if (!historial || !historial.cerrado) { %>
      <form method="POST" action="/tienda/historial-dia/cerrar" style="display:inline">
        <input type="hidden" name="fecha" value="<%= filterDate %>">
        <button type="submit" class="btn btn-success" onclick="return confirm('¿Cerrar el día <%= filterDate %>?')"><i class="bi bi-lock"></i> Cerrar Día</button>
      </form>
    <% } else { %>
      <span class="badge bg-success fs-6 p-2"><i class="bi bi-check-circle"></i> Día Cerrado</span>
    <% } %>
    </div>
  </div>

  <div class="card mb-3 hideable-section" data-card-id="historial-filtro">
    <div class="card-body py-2">
      <form method="GET" class="row g-2 align-items-center">
        <div class="col-auto"><label class="col-form-label"><i class="bi bi-calendar3"></i> Fecha:</label></div>
        <div class="col-auto"><input type="date" name="fecha" class="form-control form-control-sm" value="<%= filterDate %>" onchange="this.form.submit()"></div>
      </form>
    </div>
  </div>

  <% if (historial) { %>
  <div class="row g-3 mb-3">
    <a href="/tienda/caja?fecha=<%= filterDate %>&tipo=ingreso" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle primary"><span>💰</span></div><div><div class="stat-value"><%= (historial.total_ingresos || 0).toFixed(2) %>€</div><div class="stat-label">Ingresos</div></div></div></div></a>
    <a href="/tienda/caja?fecha=<%= filterDate %>&tipo=gasto" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle danger"><span>📤</span></div><div><div class="stat-value"><%= (historial.total_gastos || 0).toFixed(2) %>€</div><div class="stat-label">Gastos</div></div></div></div></a>
    <a href="/tienda/caja?fecha=<%= filterDate %>" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle secondary"><span>⚖️</span></div><div><div class="stat-value"><%= (historial.saldo_final || 0).toFixed(2) %>€</div><div class="stat-label">Saldo Final</div></div></div></div></a>
    <a href="/tienda/caja?fecha=<%= filterDate %>" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle success"><span>🛒</span></div><div><div class="stat-value"><%= historial.num_ventas || 0 %></div><div class="stat-label">Ventas</div></div></div></div></a>
  </div>
  <% } else { %>
  <div class="alert alert-info"><i class="bi bi-info-circle"></i> El día <%= filterDate %> aún no tiene resumen. Añade movimientos en <a href="/tienda/caja?fecha=<%= filterDate %>">Caja</a> y luego cierra el día.</div>
  <% } %>

  <div class="card hideable-section" data-card-id="historial-movimientos">
    <div class="card-header"><i class="bi bi-list-ul"></i> Movimientos del día</div>
    <div class="card-body p-0">
      <table class="table table-hover mb-0">
        <thead><tr><th>Hora</th><th>Tipo</th><th>Concepto</th><th>Importe</th><th>Usuario</th></tr></thead>
        <tbody>
        <% if (movimientos.length === 0) { %>
          <tr><td colspan="5" class="text-center text-muted py-3">Sin movimientos</td></tr>
        <% } else { movimientos.forEach(m => { %>
          <tr>
            <td class="small"><%= new Date(m.created_at).toLocaleTimeString('es-ES', { hour:'2-digit', minute:'2-digit' }) %></td>
            <td><span class="badge bg-<%= m.tipo === 'ingreso' ? 'success' : 'danger' %>"><%= m.tipo %></span></td>
            <td><%= m.concepto %></td>
            <td><strong class="text-<%= m.tipo === 'ingreso' ? 'success' : 'danger' %>"><%= m.tipo === 'ingreso' ? '+' : '-' %><%= Math.abs(m.importe).toFixed(2) %>€</strong></td>
            <td class="small"><%= m.user_name || '-' %></td>
          </tr>
        <% }) } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="row mt-3">
    <div class="col-12"><div class="card hideable-section" data-card-id="historial-cierres"><div class="card-header"><i class="bi bi-bar-chart"></i> Historial de Cierres</div><div class="card-body p-0">
      <table class="table table-hover mb-0">
        <thead><tr><th>Fecha</th><th>Ingresos</th><th>Gastos</th><th>Saldo</th><th>Ventas</th><th>Cerrado</th></tr></thead>
        <tbody>
        <% if (cajaDias.length === 0) { %>
          <tr><td colspan="6" class="text-center text-muted py-3">Sin datos</td></tr>
        <% } else { cajaDias.forEach(d => { %>
          <tr class="<%= d.cerrado ? '' : 'table-warning' %>" style="cursor:pointer;" onclick="window.location.href='/tienda/historial-dia?fecha=<%= d.fecha %>'">
            <td><%= d.fecha %></td>
            <td class="text-success"><%= (d.total_ingresos || 0).toFixed(2) %>€</td>
            <td class="text-danger"><%= (d.total_gastos || 0).toFixed(2) %>€</td>
            <td><strong><%= (d.saldo_final || 0).toFixed(2) %>€</strong></td>
            <td><%= d.num_ventas || 0 %></td>
            <td><% if (d.cerrado) { %><i class="bi bi-check-circle-fill text-success"></i><% } else { %><i class="bi bi-x-circle-fill text-warning"></i><% } %></td>
          </tr>
        <% }) } %>
        </tbody>
      </table>
      <div class="card-footer bg-white text-muted small py-1 text-center">Pulsa en una fila para ver el detalle completo</div>
    </div></div></div>
  </div>
</section>
