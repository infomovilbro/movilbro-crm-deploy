<script>
function togglePermGroup(el) {
  var arrow = el.querySelector('.perm-arrow');
  var sub = el.parentElement.querySelector('.perm-sub');
  if (sub.style.display === 'none') {
    sub.style.display = 'block';
    arrow.className = 'bi bi-chevron-down me-2 perm-arrow';
  } else {
    sub.style.display = 'none';
    arrow.className = 'bi bi-chevron-right me-2 perm-arrow';
  }
}

document.addEventListener('DOMContentLoaded', function() {
  // Toggle sub-permissions when section checkbox changes
  document.querySelectorAll('.perm-section-check').forEach(function(cb) {
    cb.addEventListener('change', function() {
      var section = this.dataset.section;
      var actions = this.closest('.perm-group').querySelectorAll('.perm-action[data-parent="' + section + '"]');
      actions.forEach(function(a) { a.checked = cb.checked; });
    });
  });

  // Nuevo usuario
  document.getElementById('formNuevoUsuario').addEventListener('submit', function(e) {
    e.preventDefault();
    var form = new FormData(this);
    var data = {};
    form.forEach(function(v, k) { data[k] = v; });
    fetch('/tienda/plantilla/crear', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify(data)
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.ok) location.reload();
      else alert(d.error || 'Error');
    });
  });

  // Editar usuario - populate modal
  document.querySelectorAll('.editar-usuario').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('edit-id').value = this.dataset.id;
      document.getElementById('edit-username').value = this.dataset.username;
      document.getElementById('edit-nombre').value = this.dataset.nombre;
      document.getElementById('edit-apellidos').value = this.dataset.apellidos;
      document.getElementById('edit-email').value = this.dataset.email;
      document.getElementById('edit-puesto').value = this.dataset.puesto;
      document.getElementById('edit-salario').value = this.dataset.salario;
      document.getElementById('edit-rol').value = this.dataset.rol;
      document.getElementById('edit-activo').value = this.dataset.activo;
      // Restore permissions checkboxes
      try { var perms = JSON.parse(this.dataset.permissions); } catch(e) { var perms = {}; }
      document.querySelectorAll('#formEditarUsuario [name^="perm_"]').forEach(function(cb) {
        var key = cb.name.replace('perm_', '');
        cb.checked = !!perms[key];
      });
      // Toggle section checkboxes based on actions
      document.querySelectorAll('#formEditarUsuario .perm-section-check').forEach(function(cb) {
        var section = cb.dataset.section;
        var actions = cb.closest('.perm-group').querySelectorAll('.perm-action[data-parent="' + section + '"]');
        var allChecked = true;
        actions.forEach(function(a) { if (!a.checked) allChecked = false; });
        cb.checked = allChecked;
      });
      new bootstrap.Modal(document.getElementById('modalEditarUsuario')).show();
    });
  });

  // Editar usuario - submit
  document.getElementById('formEditarUsuario').addEventListener('submit', function(e) {
    e.preventDefault();
    var form = new FormData(this);
    var data = {};
    form.forEach(function(v, k) { data[k] = v; });
    fetch('/tienda/plantilla/editar', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify(data)
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.ok) location.reload();
      else alert(d.error || 'Error');
    });
  });

  // Eliminar
  document.querySelectorAll('.eliminar-usuario').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (!confirm('¿Eliminar este usuario?')) return;
      fetch('/tienda/plantilla/eliminar', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ id: parseInt(this.dataset.id) })
      }).then(function(r) { return r.json(); }).then(function(d) {
        if (d.ok) location.reload();
        else alert(d.error || 'Error');
      });
    });
  });
});
</script>