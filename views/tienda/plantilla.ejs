<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people"></i> Usuarios / Trabajadores</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalNuevoUsuario"><i class="bi bi-plus-lg"></i> Nuevo Usuario</button>
  </div>

  <div class="card">
    <div class="card-body p-0 table-responsive">
      <table class="table table-hover mb-0" style="white-space:nowrap;">
        <thead><tr><th>Usuario</th><th>Nombre</th><th>Email</th><th>Puesto</th><th>Rol</th><th>Estado</th><th>Permisos</th><th>Acciones</th></tr></thead>
        <tbody>
        <% if (trabajadores.length === 0) { %>
          <tr><td colspan="8" class="text-center text-muted py-4"><i class="bi bi-people" style="font-size:2rem;display:block;margin-bottom:8px;"></i>No hay usuarios registrados</td></tr>
        <% } else { trabajadores.forEach(t => { %>
          <tr>
            <td><%= t.username || '-' %></td>
            <td><%= t.nombre %> <%= t.apellidos || '' %></td>
            <td><%= t.email || '-' %></td>
            <td><%= t.puesto || '-' %></td>
            <td><span class="badge bg-<%= t.rol === 'admin' ? 'danger' : 'primary' %>"><%= t.rol || 'user' %></span></td>
            <td>
              <span class="badge bg-<%= t.activo !== 0 ? 'success' : 'secondary' %>">
                <%= t.activo !== 0 ? 'Activo' : 'Inactivo' %>
              </span>
            </td>
            <td class="small">
              <% try { var perms = JSON.parse(t.permissions || '{}'); } catch(e) { var perms = {}; } %>
              <% var tiendaPerms = ['dashboard','agenda','prepago','caja','presupuestos','inventario','historial','plantilla','cierres']; %>
              <% tiendaPerms.forEach(function(s) { if (perms['tienda_'+s]) { %>
                <span class="badge bg-info me-1"><%= s %></span>
              <% } }) %>
              <% if (perms['tienda']) { %><span class="badge bg-success">todo</span><% } %>
            </td>
            <td>
              <button class="btn btn-sm btn-outline-primary editar-usuario" data-id="<%= t.id %>" data-username="<%= t.username || '' %>" data-nombre="<%= t.nombre %>" data-apellidos="<%= t.apellidos || '' %>" data-email="<%= t.email || '' %>" data-puesto="<%= t.puesto || '' %>" data-salario="<%= t.salario || 0 %>" data-rol="<%= t.rol || 'user' %>" data-activo="<%= t.activo !== undefined ? t.activo : 1 %>" data-permissions='<%= JSON.stringify(t.permissions || "{}") %>'><i class="bi bi-pencil"></i></button>
              <button class="btn btn-sm btn-outline-danger eliminar-usuario" data-id="<%= t.id %>"><i class="bi bi-trash"></i></button>
            </td>
          </tr>
        <% }) } %>
        </tbody>
      </table>
    </div>
  </div>
</section>

