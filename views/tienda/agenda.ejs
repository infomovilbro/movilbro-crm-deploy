<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-calendar-event"></i> Agenda</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalAgenda"><i class="bi bi-plus-lg"></i> Nueva Cita</button>
  </div>

  <!-- Notifications -->
  <% if (proximasCitas && proximasCitas.length > 0) { %>
    <div class="alert alert-warning mb-3 hideable-section" data-card-id="agenda-notificaciones">
      <i class="bi bi-exclamation-triangle"></i> <strong>Próximos eventos importantes:</strong>
      <% proximasCitas.forEach(n => { %>
        <div class="mt-1"><i class="bi bi-dot"></i> <strong><%= n.fecha %></strong> — <%= n.cliente_nombre %> <span class="text-muted">(<%= n.motivo || n.tipo %><%= n.hora ? ' ' + n.hora.slice(0,5) : '' %>)</span></div>
      <% }) %>
    </div>
  <% } %>

  <div class="row g-3">
    <!-- Calendar column -->
    <div class="col-md-5">
      <div class="card mb-3 hideable-section" data-card-id="agenda-calendario">
        <div class="card-header d-flex justify-content-between align-items-center">
          <button class="btn btn-sm btn-outline-secondary" onclick="navegarMes(-1)">&laquo;</button>
          <strong><%= mesNombre %> <%= anoActual %></strong>
          <button class="btn btn-sm btn-outline-secondary" onclick="navegarMes(1)">&raquo;</button>
        </div>
        <div class="card-body p-2">
          <table class="calendar-table">
            <thead>
              <tr><th>Do</th><th>Lu</th><th>Ma</th><th>Mi</th><th>Ju</th><th>Vi</th><th>Sá</th></tr>
            </thead>
            <tbody>
              <% calendario.forEach(semana => { %>
                <tr>
                  <% semana.forEach(dia => { %>
                    <% if (dia) {
                      const tieneCita = diasConCitas.includes(dia.dateStr);
                      const seleccionada = dia.dateStr === filterDate;
                    %>
                      <td class="<%= tieneCita ? 'has-cita' : '' %><%= dia.esHoy ? ' hoy' : '' %><%= seleccionada ? ' selected' : '' %>"
                          onclick="seleccionarFecha('<%= dia.dateStr %>')">
                        <%= dia.dia %>
                      </td>
                    <% } else { %>
                      <td class="empty"></td>
                    <% } %>
                  <% }) %>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Right column: date filter + daily note -->
    <div class="col-md-7">
      <!-- Date filter -->
      <div class="card mb-3 hideable-section" data-card-id="agenda-filtro">
        <div class="card-body py-2">
          <form method="GET" class="row g-2 align-items-center">
            <div class="col-auto"><label class="col-form-label"><i class="bi bi-calendar3"></i> Fecha:</label></div>
            <div class="col-auto"><input type="date" name="fecha" class="form-control form-control-sm" value="<%= filterDate %>" onchange="this.form.submit()"></div>
            <div class="col-auto"><span class="text-muted"><%= new Date(filterDate).toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span></div>
          </form>
        </div>
      </div>

      <!-- Daily note -->
      <div class="card mb-3 hideable-section" data-card-id="agenda-nota">
        <div class="card-header"><i class="bi bi-journal-text"></i> Nota del Día</div>
        <div class="card-body">
          <textarea id="notaDiaria" class="form-control" rows="2" placeholder="Me ausento de la tienda (media hora, cambio para el cajón...)"></textarea>
          <div class="mt-2 d-flex align-items-center gap-2">
            <div class="input-group input-group-sm" style="width:auto;">
              <input type="number" step="0.01" id="importeAgenda" class="form-control" placeholder="0.00" style="width:75px;">
              <button class="btn btn-success" onclick="insertarEnNota('notaDiaria', '+', 'importeAgenda')" title="Añadir ingreso"><i class="bi bi-plus-circle"></i></button>
              <button class="btn btn-danger" onclick="insertarEnNota('notaDiaria', '-', 'importeAgenda')" title="Añadir gasto"><i class="bi bi-dash-circle"></i></button>
            </div>
            <button class="btn btn-sm btn-primary" onclick="guardarNotaDiaria()"><i class="bi bi-check-lg"></i> Guardar</button>
          </div>
          <% if (notaDiaria && notaDiaria.importe > 0) { %>
            <div class="mt-2 small">
              <span class="badge bg-<%= notaDiaria.tipo === 'ingreso' ? 'success' : 'danger' %>">
                <i class="bi bi-<%= notaDiaria.tipo === 'ingreso' ? 'arrow-up' : 'arrow-down' %>"></i>
                <%= notaDiaria.importe.toFixed(2) %>€ (<%= notaDiaria.tipo === 'ingreso' ? 'Ingreso' : 'Gasto' %>)
              </span>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Appointments list -->
  <div class="card hideable-section" data-card-id="agenda-citas">
    <div class="card-header d-flex justify-content-between">
      <span><i class="bi bi-list-check"></i> Citas del día</span>
      <span class="badge bg-primary"><%= citas.length %> cita(s)</span>
    </div>
    <div class="card-body p-0">
      <table class="table table-hover mb-0">
        <thead><tr><th>Hora</th><th>Cliente</th><th>Teléfono</th><th>Tipo</th><th>Motivo</th><th>Estado</th><th>Acciones</th></tr></thead>
        <tbody>
        <% if (citas.length === 0) { %>
          <tr><td colspan="7" class="text-center text-muted py-4"><i class="bi bi-calendar-x" style="font-size:2rem;display:block;margin-bottom:8px;"></i>No hay citas para esta fecha</td></tr>
        <% } else { citas.forEach(c => { %>
          <tr>
            <td><strong><%= c.hora ? c.hora.slice(0,5) : '--:--' %></strong></td>
            <td><%= c.cliente_nombre %></td>
            <td><%= c.telefono || '-' %></td>
            <td><span class="badge bg-<%= c.estado === 'completada' ? 'success' : 'info' %>"><%= c.tipo %></span></td>
            <td class="small"><%= c.motivo || '-' %></td>
            <td>
              <select class="form-select form-select-sm estado-cita" data-id="<%= c.id %>" style="width:auto;display:inline-block;">
                <option value="pendiente" <%= c.estado === 'pendiente' ? 'selected' : '' %>>Pendiente</option>
                <option value="completada" <%= c.estado === 'completada' ? 'selected' : '' %>>Completada</option>
                <option value="cancelada" <%= c.estado === 'cancelada' ? 'selected' : '' %>>Cancelada</option>
              </select>
            </td>
            <td>
              <button class="btn btn-sm btn-outline-danger eliminar-cita" data-id="<%= c.id %>"><i class="bi bi-trash"></i></button>
            </td>
          </tr>
        <% }) } %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
.calendar-table { width:100%; border-collapse:collapse; }
.calendar-table th { text-align:center; font-size:11px; font-weight:600; color:#6c757d; padding:4px 0; }
.calendar-table td { text-align:center; padding:6px 0; font-size:13px; cursor:pointer; border-radius:4px; transition:all 0.1s; }
.calendar-table td:hover { background:#e9ecef; }
.calendar-table td.empty { cursor:default; }
.calendar-table td.hoy { font-weight:700; color:#0050A1; background:rgba(0,80,161,0.08); }
.calendar-table td.has-cita { position:relative; }
.calendar-table td.has-cita::after { content:''; display:block; width:5px; height:5px; background:#198754; border-radius:50%; margin:1px auto 0; }
.calendar-table td.selected { background:#0050A1 !important; color:#fff; }
.calendar-table td.selected::after { background:#fff; }
</style>

<!-- Modal Nueva Cita -->
<div class="modal fade" id="modalAgenda" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <form method="POST" action="/tienda/agenda/crear">
      <div class="modal-header"><h5><i class="bi bi-calendar-plus"></i> Nueva Cita</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <div class="mb-2"><label class="form-label">Cliente *</label><input type="text" name="cliente_nombre" class="form-control" required></div>
        <div class="row g-2 mb-2">
          <div class="col"><label class="form-label">Teléfono</label><input type="text" name="telefono" class="form-control"></div>
          <div class="col"><label class="form-label">Tipo</label><select name="tipo" class="form-select"><option value="cita">Cita</option><option value="instalacion">Instalación</option><option value="reparacion">Reparación</option><option value="seguimiento">Seguimiento</option></select></div>
        </div>
        <div class="row g-2 mb-2">
          <div class="col"><label class="form-label">Fecha</label><input type="date" name="fecha" class="form-control" value="<%= filterDate %>"></div>
          <div class="col"><label class="form-label">Hora</label><input type="time" name="hora" class="form-control"></div>
        </div>
        <div class="mb-2"><label class="form-label">Motivo</label><textarea name="motivo" class="form-control" rows="2"></textarea></div>
        <div class="mb-2"><label class="form-label">Notas</label><textarea name="notas" class="form-control" rows="2"></textarea></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Crear Cita</button>
      </div>
    </form>
  </div></div>
</div>

<script>
// Pre-populate daily note
(function() {
  var ta = document.getElementById('notaDiaria');
  <% if (notaDiaria && notaDiaria.nota) { %>
    ta.value = '<%= notaDiaria.nota.replace(/'/g, "\\'").replace(/\n/g, "\\n") %>';
  <% } %>
})();

document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.estado-cita').forEach(sel => {
    sel.addEventListener('change', function() {
      fetch('/tienda/agenda/estado', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ id: this.dataset.id, estado: this.value }) });
    });
  });
  document.querySelectorAll('.eliminar-cita').forEach(btn => {
    btn.addEventListener('click', function() {
      if (confirm('¿Eliminar esta cita?')) {
        fetch('/tienda/agenda/eliminar', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ id: this.dataset.id }) })
        .then(() => location.reload());
      }
    });
  });
});

function navegarMes(delta) {
  const params = new URLSearchParams(location.search);
  let mes = parseInt(params.get('mes')) || <%= mesActual %>;
  let ano = parseInt(params.get('ano')) || <%= anoActual %>;
  mes += delta;
  if (mes > 12) { mes = 1; ano++; }
  if (mes < 1) { mes = 12; ano--; }
  params.set('mes', mes);
  params.set('ano', ano);
  location.search = params.toString();
}

function seleccionarFecha(dateStr) {
  const params = new URLSearchParams(location.search);
  params.set('fecha', dateStr);
  location.search = params.toString();
}

function insertarEnNota(id, signo, importeId) {
  var ta = document.getElementById(id);
  var importe = parseFloat(document.getElementById(importeId).value) || 0;
  if (importe <= 0) { alert('Introduce un importe válido'); return; }
  var text = signo + importe.toFixed(2) + '€';
  var start = ta.selectionStart, end = ta.selectionEnd;
  ta.value = ta.value.substring(0, start) + text + ta.value.substring(end);
  ta.selectionStart = ta.selectionEnd = start + text.length;
  document.getElementById(importeId).value = '';
  ta.focus();
}
function guardarNotaDiaria() {
  const nota = document.getElementById('notaDiaria').value;
  const importeVal = parseFloat(document.getElementById('importeAgenda').value) || 0;
  var body = { nota: nota };
  if (importeVal !== 0) {
    body.importe_auto = Math.abs(importeVal);
    body.tipo_auto = importeVal > 0 ? 'ingreso' : 'gasto';
  }
  fetch('/tienda/agenda/nota-diaria', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
    body: JSON.stringify(body)
  }).then(function(r){ return r.json(); }).then(function(d){
    if (d.ok) {
      document.getElementById('notaDiaria').value = '';
      document.getElementById('importeAgenda').value = '';
    }
  });
}
</script>