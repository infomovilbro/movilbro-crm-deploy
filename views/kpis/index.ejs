<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-bar-chart"></i> KPIs - Likes Telecom</h5>
    <small class="text-muted">Última actualización: <%= new Date().toLocaleTimeString('es-ES', {hour:'2-digit',minute:'2-digit'}) %></small>
  </div>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> <%= error %></div><% } %>

  <% if (stats) { %>
  <!-- Key metrics row -->
  <div class="row g-2 mb-3">
    <div class="col-md-3 col-6">
      <div class="card border-0 shadow-sm" style="background:linear-gradient(135deg,#667eea,#764ba2);color:white;">
        <div class="card-body p-3 text-center">
          <small class="opacity-75">Recurrente Total</small>
          <div class="fs-4 fw-bold"><%= stats.recurrenteTotal ? stats.recurrenteTotal.toFixed(2) : '0.00' %>€</div>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card border-0 shadow-sm" style="background:linear-gradient(135deg,#f093fb,#f5576c);color:white;">
        <div class="card-body p-3 text-center">
          <small class="opacity-75">Líneas Totales</small>
          <div class="fs-4 fw-bold"><%= stats.totalLines || 0 %></div>
          <small class="opacity-75">Móvil: <%= stats.linesMobile || 0 %> · Fibra: <%= stats.linesFiber || 0 %></small>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card border-0 shadow-sm" style="background:linear-gradient(135deg,#4facfe,#00f2fe);color:white;">
        <div class="card-body p-3 text-center">
          <small class="opacity-75">Clientes Activos</small>
          <div class="fs-4 fw-bold"><%= stats.clientesConLineasActivas || 0 %></div>
          <small class="opacity-75">Total: <%= stats.totalCustomers || 0 %></small>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card border-0 shadow-sm" style="background:linear-gradient(135deg,#43e97b,#38f9d7);color:white;">
        <div class="card-body p-3 text-center">
          <small class="opacity-75">Mix Tarifas</small>
          <div class="fs-4 fw-bold"><%= stats.mixTarifas ? stats.mixTarifas.length : 0 %></div>
          <small class="opacity-75">Familias: <%= stats.familyCount || 0 %></small>
        </div>
      </div>
    </div>
  </div>

  <!-- Tabs -->
  <ul class="nav nav-tabs mb-3" id="kpiTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active" id="tab-general" data-bs-toggle="tab" data-bs-target="#kpiGeneral" type="button" role="tab">📊 General</button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="tab-movil" data-bs-toggle="tab" data-bs-target="#kpiMovil" type="button" role="tab">📱 Móvil</button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="tab-fibra" data-bs-toggle="tab" data-bs-target="#kpiFibra" type="button" role="tab">🌐 Fibra</button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="tab-facturacion" data-bs-toggle="tab" data-bs-target="#kpiFacturacion" type="button" role="tab">💰 Facturación</button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="tab-tarifas" data-bs-toggle="tab" data-bs-target="#kpiTarifas" type="button" role="tab">🏷️ Mix Tarifas</button>
    </li>
  </ul>

  <div class="tab-content">
    <!-- TAB: GENERAL -->
    <div class="tab-pane fade show active" id="kpiGeneral" role="tabpanel">
      <div class="row g-2 mb-3">
        <div class="col-md-2 col-4"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.totalCustomers || 0 %></div><small class="text-muted">Clientes</small></div></div></div>
        <div class="col-md-2 col-4"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.totalProducts || 0 %></div><small class="text-muted">Productos</small></div></div></div>
        <div class="col-md-2 col-4"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.totalSubscriptions || 0 %></div><small class="text-muted">Suscripciones</small></div></div></div>
        <div class="col-md-2 col-4"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.totalLines || 0 %></div><small class="text-muted">Líneas</small></div></div></div>
        <div class="col-md-2 col-4"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.totalPortabilities || 0 %></div><small class="text-muted">Portabilidades</small></div></div></div>
        <div class="col-md-2 col-4"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.totalTickets || 0 %></div><small class="text-muted">Tickets</small></div></div></div>
      </div>
      <div class="row g-2 mb-3">
        <div class="col-md-3"><div class="card"><div class="card-body p-2"><div style="height:160px;overflow:hidden;"><canvas id="kpiFamilies"></canvas></div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body p-2"><div style="height:160px;overflow:hidden;"><canvas id="kpiTimeline"></canvas></div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body p-2"><div style="height:160px;overflow:hidden;"><canvas id="kpiTypes"></canvas></div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body p-2"><div style="height:160px;overflow:hidden;"><canvas id="kpiCustStatuses"></canvas></div></div></div></div>
      </div>
      <div class="row g-2 mb-3">
        <div class="col-md-6"><div class="card"><div class="card-body p-2"><div style="height:160px;overflow:hidden;"><canvas id="kpiRegions"></canvas></div></div></div></div>
        <div class="col-md-6"><div class="card"><div class="card-body p-2"><div style="height:160px;overflow:hidden;"><canvas id="kpiPortTimeline"></canvas></div></div></div></div>
      </div>
    </div>

    <!-- TAB: MÓVIL -->
    <div class="tab-pane fade" id="kpiMovil" role="tabpanel">
      <div class="row g-2 mb-3">
        <div class="col-md-3 col-6"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.linesMobile || 0 %></div><small class="text-muted">Líneas Móvil</small></div></div></div>
        <div class="col-md-3 col-6"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.lineStatuses && stats.lineStatuses.ACTIVE ? stats.lineStatuses.ACTIVE : 0 %></div><small class="text-muted">Activas</small></div></div></div>
        <div class="col-md-3 col-6"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.lineStatuses && stats.lineStatuses.SUSPENDED ? stats.lineStatuses.SUSPENDED : 0 %></div><small class="text-muted">Suspendidas</small></div></div></div>
        <div class="col-md-3 col-6"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.lineStatuses && stats.lineStatuses.CANCELLED ? stats.lineStatuses.CANCELLED : 0 %></div><small class="text-muted">Canceladas</small></div></div></div>
      </div>
      <div class="row g-2 mb-3">
        <div class="col-md-6"><div class="card"><div class="card-body p-2"><div style="height:160px;overflow:hidden;"><canvas id="kpiPorts"></canvas></div></div></div></div>
        <div class="col-md-6"><div class="card"><div class="card-body p-2"><div style="height:160px;overflow:hidden;"><canvas id="kpiMixTarifas"></canvas></div></div></div></div>
      </div>
    </div>

    <!-- TAB: FIBRA -->
    <div class="tab-pane fade" id="kpiFibra" role="tabpanel">
      <div class="row g-2 mb-3">
        <div class="col-md-3 col-6"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.linesFiber || 0 %></div><small class="text-muted">Líneas Fibra</small></div></div></div>
        <div class="col-md-3 col-6"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.totalCustomers || 0 %></div><small class="text-muted">Clientes</small></div></div></div>
        <div class="col-md-3 col-6"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.portabilityIn || 0 %></div><small class="text-muted">Port. Entrantes</small></div></div></div>
        <div class="col-md-3 col-6"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.portabilityOut || 0 %></div><small class="text-muted">Port. Salientes</small></div></div></div>
      </div>
      <div class="row g-2 mb-3">
        <div class="col-12"><div class="card"><div class="card-body p-2"><div style="height:160px;overflow:hidden;"><canvas id="kpiPortTimeline2"></canvas></div></div></div></div>
      </div>
    </div>

    <!-- TAB: FACTURACIÓN -->
    <div class="tab-pane fade" id="kpiFacturacion" role="tabpanel">
      <div class="row g-2 mb-3">
        <div class="col-md-4"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.recurrenteTotal ? stats.recurrenteTotal.toFixed(2) : '0.00' %>€</div><small class="text-muted">Recurrente catálogo</small></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.clientesConLineasActivas || 0 %></div><small class="text-muted">Clientes activos</small></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body p-2 text-center"><div class="fs-5 fw-bold"><%= stats.familyCount || 0 %></div><small class="text-muted">Familias</small></div></div></div>
      </div>
      <div class="row g-2 mb-3">
        <div class="col-md-6"><div class="card"><div class="card-body p-2"><div style="height:160px;overflow:hidden;"><canvas id="kpiFamilies2"></canvas></div></div></div></div>
        <div class="col-md-6"><div class="card"><div class="card-body p-2"><div style="height:160px;overflow:hidden;"><canvas id="kpiTypes2"></canvas></div></div></div></div>
      </div>
    </div>

    <!-- TAB: MIX TARIFAS -->
    <div class="tab-pane fade" id="kpiTarifas" role="tabpanel">
      <div class="row g-2 mb-3">
        <div class="col-md-6">
          <div class="card">
            <div class="card-header"><i class="bi bi-pie-chart"></i> Mix de Tarifas Contratadas</div>
            <div class="card-body p-2">
              <div style="height:250px;"><canvas id="kpiMixTarifasDetalle"></canvas></div>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card">
            <div class="card-header"><i class="bi bi-table"></i> Detalle de Tarifas</div>
            <div class="card-body p-0">
              <div class="table-responsive" style="max-height:300px;">
                <table class="table table-sm table-hover mb-0">
                  <thead class="table-light"><tr><th>Tarifa</th><th class="text-end">Líneas</th></tr></thead>
                  <tbody>
                    <% if (stats.mixTarifas && stats.mixTarifas.length > 0) {
                      stats.mixTarifas.forEach(function(t) { %>
                    <tr><td><%= t.name %></td><td class="text-end fw-bold"><%= t.count %></td></tr>
                    <% }); } else { %>
                    <tr><td colspan="2" class="text-center text-muted">Sin datos de tarifas</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="row g-2">
        <div class="col-md-6"><div class="card"><div class="card-body p-2"><div style="height:160px;overflow:hidden;"><canvas id="kpiLineStatuses"></canvas></div></div></div></div>
        <div class="col-md-6"><div class="card"><div class="card-body p-2"><div style="height:160px;overflow:hidden;"><canvas id="kpiPortDonors"></canvas></div></div></div></div>
      </div>
    </div>
  </div>
  <% } %>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var opts = { responsive: true, maintainAspectRatio: false, animation: false, resizeDelay: 0 };
  var colors = ['#0d6efd','#198754','#20c997','#0dcaf0','#ffc107','#dc3545','#6f42c1','#fd7e14','#e83e8c','#20c997','#17a2b8','#6610f2'];
  var gray = '#6c757d';

  function tryChart(id, type, labels, data, extra) {
    try {
      if (!labels || !labels.length) return;
      var config = { type: type, data: { labels: labels, datasets: [{ data: data }] }, options: Object.assign({}, opts, extra || {}) };
      if (type !== 'doughnut') {
        config.data.datasets[0].backgroundColor = labels.map(function(_,i){ return colors[i%colors.length]; });
        config.data.datasets[0].borderRadius = 4;
      } else {
        config.data.datasets[0].backgroundColor = labels.map(function(_,i){ return colors[i%colors.length]; });
        config.data.datasets[0].borderWidth = 0;
      }
      new Chart(document.getElementById(id), config);
    } catch(e) {}
  }

  // General tab
  <% if (stats && stats.families) { %>tryChart('kpiFamilies', 'bar', <%= JSON.stringify(stats.families.map(x => x.name)) %>, <%= JSON.stringify(stats.families.map(x => x.count)) %>, { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } });<% } %>
  <% if (stats.customerTimeline) { %>tryChart('kpiTimeline', 'bar', <%= JSON.stringify(stats.customerTimeline.map(x => x.month)) %>, <%= JSON.stringify(stats.customerTimeline.map(x => x.count)) %>, { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } });<% } %>
  <% if (stats.productTypes) { %>tryChart('kpiTypes', 'bar', ['Main','Optional','Promotion'], [<%= (stats.productTypes.Main||0) %>,<%= (stats.productTypes.Optional||0) %>,<%= (stats.productTypes.Promotion||0) %>], { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } });<% } %>
  <% if (stats.custStatuses) { %>tryChart('kpiCustStatuses', 'doughnut', <%= JSON.stringify(Object.keys(stats.custStatuses)) %>, <%= JSON.stringify(Object.values(stats.custStatuses)) %>, { cutout: '60%', plugins: { legend: { display: false } } });<% } %>
  <% if (stats.topRegions) { %>tryChart('kpiRegions', 'bar', <%= JSON.stringify(stats.topRegions.map(x => x.name)) %>, <%= JSON.stringify(stats.topRegions.map(x => x.count)) %>, { indexAxis: 'y', plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true, grid: { color: '#eee' } }, y: { grid: { display: false } } } });<% } %>
  <% if (stats.portTimeline) { %>tryChart('kpiPortTimeline', 'bar', <%= JSON.stringify(stats.portTimeline.map(x => x.month)) %>, <%= JSON.stringify(stats.portTimeline.map(x => x.count)) %>, { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } });<% } %>

  // Móvil tab
  <% if (stats.portStatuses) { %>tryChart('kpiPorts', 'bar', <%= JSON.stringify(Object.keys(stats.portStatuses)) %>, <%= JSON.stringify(Object.values(stats.portStatuses)) %>, { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } });<% } %>
  <% if (stats.mixTarifas) { %>tryChart('kpiMixTarifas', 'bar', <%= JSON.stringify(stats.mixTarifas.map(x => x.name)) %>, <%= JSON.stringify(stats.mixTarifas.map(x => x.count)) %>, { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } });<% } %>

  // Fibra tab
  <% if (stats.portTimeline) { %>tryChart('kpiPortTimeline2', 'bar', <%= JSON.stringify(stats.portTimeline.map(x => x.month)) %>, <%= JSON.stringify(stats.portTimeline.map(x => x.count)) %>, { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } });<% } %>

  // Facturación tab
  <% if (stats.families) { %>tryChart('kpiFamilies2', 'bar', <%= JSON.stringify(stats.families.map(x => x.name)) %>, <%= JSON.stringify(stats.families.map(x => x.count)) %>, { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } });<% } %>
  tryChart('kpiTypes2', 'bar', ['Main','Optional','Promotion'], [<%= (stats.productTypes ? stats.productTypes.Main||0 : 0) %>,<%= (stats.productTypes ? stats.productTypes.Optional||0 : 0) %>,<%= (stats.productTypes ? stats.productTypes.Promotion||0 : 0) %>], { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } });

  // Mix Tarifas tab
  <% if (stats.mixTarifas) { %>tryChart('kpiMixTarifasDetalle', 'doughnut', <%= JSON.stringify(stats.mixTarifas.map(x => x.name)) %>, <%= JSON.stringify(stats.mixTarifas.map(x => x.count)) %>, { cutout: '50%', plugins: { legend: { position: 'right', labels: { boxWidth: 12, padding: 8, font: { size: 10 } } } } });<% } %>
  <% if (stats.lineStatuses) { %>tryChart('kpiLineStatuses', 'doughnut', <%= JSON.stringify(Object.keys(stats.lineStatuses)) %>, <%= JSON.stringify(Object.values(stats.lineStatuses)) %>, { cutout: '60%', plugins: { legend: { display: false } } });<% } %>
  <% if (stats.portDonors) { %>tryChart('kpiPortDonors', 'bar', <%= JSON.stringify(stats.portDonors.map(x => x.name)) %>, <%= JSON.stringify(stats.portDonors.map(x => x.count)) %>, { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } });<% } %>
});
</script>