  <% if (user && user.rol === 'admin') { %>
  <script>
    (function() {
      const fab = document.getElementById('uiEditorToggle');
      const panel = document.getElementById('uiEditorPanel');
      const closeBtn = document.getElementById('uiEditorClose');
      const editSwitch = document.getElementById('uiEditModeSwitch');
      const saveBtn = document.getElementById('uiSaveAll');
      const resetBtn = document.getElementById('uiResetOriginal');
      const reloadBtn = document.getElementById('uiReloadPage');
      if (!fab || !panel || !editSwitch) return;

      const themes = (typeof TEMAS_CRM !== 'undefined' && TEMAS_CRM.length) ? TEMAS_CRM : [
        { name: 'Movilbro', sidebarBg: '#ffffff', sidebarActive: '#0050a1', primary: '#0050a1' }
      ];

      let selected = null;
      let currentTheme = Object.assign({}, window.__UI_LIVE_THEME || {});
      let liveLayout = Object.assign({ sidebarPosition: 'left', overrides: {} }, <%- JSON.stringify(ui.liveLayout || {}) %> || {});

      const themeGrid = document.getElementById('uiThemeGrid');
      if (themeGrid) {
        themes.forEach((t) => {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'ui-theme-btn text-start';
          const preview = t.sidebarBg?.startsWith('#') ? t.sidebarBg : '#e0e0e0';
          const preview2 = t.primary?.startsWith('#') ? t.primary : '#666';
          b.innerHTML = `<div class="d-flex align-items-center gap-2 mb-1"><span style="display:inline-block;width:18px;height:18px;border-radius:4px;background:${preview};border:1px solid #ccc"></span><span style="display:inline-block;width:18px;height:18px;border-radius:4px;background:${preview2}"></span><span class="fw-semibold small">${t.name}</span></div><div class="small text-muted" style="font-size:10px">${t.desc || ''}</div>`;
          b.addEventListener('click', function() { applyTheme(t); });
          themeGrid.appendChild(b);
        });
      }

      function applyTheme(t) {
        currentTheme = Object.assign({}, t);
        const root = document.documentElement;
        const vars = {
          '--sidebar-bg': t.sidebarBg,
          '--sidebar-hover': t.sidebarHover,
          '--sidebar-active': t.sidebarActive,
          '--primary': t.primary,
          '--primary-light': t.primaryLight,
          '--primary-gradient': t.primaryGradient,
          '--topbar-bg': t.topbarBg,
          '--topbar-border': t.topbarBorder,
          '--bg-body': t.bgBody,
          '--card-bg': t.cardBg,
          '--text-primary': t.textPrimary,
          '--text-secondary': t.textSecondary,
          '--border-color': t.borderColor,
          '--table-hover-bg': t.tableHoverBg,
          '--table-stripe': t.tableStripe,
          '--input-focus-shadow': t.inputFocusShadow,
          '--shadow-sm': t.shadowSm,
          '--shadow-md': t.shadowMd,
          '--card-radius': t.cardRadius,
          '--font': t.font,
          '--success': t.success,
          '--danger': t.danger,
          '--warning': t.warning,
          '--info': t.info
        };
        Object.keys(vars).forEach(k => root.style.setProperty(k, vars[k]));
      }

      function applySidebarPosition(pos) {
        document.body.classList.remove('sidebar-right', 'sidebar-bottom');
        if (pos === 'right') document.body.classList.add('sidebar-right');
        if (pos === 'bottom') document.body.classList.add('sidebar-bottom');
      }

      function applyOverrides() {
        const ov = (liveLayout && liveLayout.overrides) ? liveLayout.overrides : {};
        Object.keys(ov).forEach(key => {
          const el = document.querySelector('[data-ui-key="' + key + '"]');
          if (!el) return;
          const cfg = ov[key] || {};
          const labelEl = el.querySelector('[data-group-label]') || el.querySelector('a');
          const iconEl = el.querySelector('[data-group-icon]') || el.querySelector('.emoji-icon');
          if (cfg.label && labelEl) {
            if (labelEl.matches('a')) {
              const textNode = Array.from(labelEl.childNodes).find(n => n.nodeType === 3);
              if (textNode) textNode.nodeValue = ' ' + cfg.label;
              else labelEl.appendChild(document.createTextNode(' ' + cfg.label));
            } else labelEl.textContent = cfg.label;
          }
          if (cfg.icon && iconEl) iconEl.textContent = cfg.icon;
          if (cfg.bg) el.style.backgroundColor = cfg.bg;
          if (cfg.color) el.style.color = cfg.color;
        });
        // Apply group background
        const savedGroupBg = localStorage.getItem('ui_group_bg') || '#ffffff';
        document.querySelector('.sidebar-scroll')?.style.setProperty('background', savedGroupBg, 'important');
        // Apply group visibility from localStorage (designer panel)
        try {
          const hiddenGroups = JSON.parse(localStorage.getItem('ui_hidden_groups') || '[]');
          hiddenGroups.forEach(function(key) {
            const el = document.querySelector('[data-group-key="' + key + '"]');
            if (el) el.style.display = 'none';
          });
        } catch(e) {}
        // Apply group/item visibility from server config
        var cfg = window.__UI_NAV_CONFIG;
        if (cfg && Array.isArray(cfg.groups)) {
          cfg.groups.forEach(function(g) {
            if (g.hidden) {
              var el = document.querySelector('[data-group-key="' + g.key + '"]');
              if (el) el.style.display = 'none';
            }
            if (Array.isArray(g.hiddenItems) && g.hiddenItems.length) {
              var groupEl = document.querySelector('[data-group-key="' + g.key + '"]');
              if (groupEl) {
                groupEl.querySelectorAll('li[data-item-key]').forEach(function(li) {
                  if (g.hiddenItems.indexOf(li.getAttribute('data-item-key')) !== -1) {
                    li.style.display = 'none';
                  }
                });
              }
            }
          });
        }
        // Apply local hidden items (from designer panel)
        try {
          var localHiddenItems = JSON.parse(localStorage.getItem('ui_hidden_items') || '{}');
          Object.keys(localHiddenItems).forEach(function(gk) {
            var items = localHiddenItems[gk];
            if (Array.isArray(items)) {
              items.forEach(function(ik) {
                var li = document.querySelector('[data-group-key="' + gk + '"] li[data-item-key="' + ik + '"]');
                if (li) li.style.display = 'none';
              });
            }
          });
        } catch(e) {}
        // Apply bottom nav background
        try {
          const savedBottomNavBg = localStorage.getItem('ui_bottomnav_bg');
          if (savedBottomNavBg) {
            if (savedBottomNavBg.startsWith('gradient:')) {
              var grad = savedBottomNavBg.replace('gradient:', '');
              document.getElementById('bottomNav')?.style.setProperty('background', 'linear-gradient(' + grad + ')', 'important');
            } else {
              document.getElementById('bottomNav')?.style.setProperty('background', savedBottomNavBg, 'important');
            }
          }
        } catch(e) {}
        // Apply bottom nav visibility
        try {
          const hiddenBottomNav = JSON.parse(localStorage.getItem('ui_hidden_bottomnav') || '[]');
          hiddenBottomNav.forEach(function(key) {
            var btn = document.querySelector('.bottom-nav-item[data-nav-group="' + key + '"]');
            if (btn) btn.style.display = 'none';
          });
        } catch(e) {}
      }

      function setSelected(el) {
        document.querySelectorAll('[data-ui-selected]').forEach(n => n.removeAttribute('data-ui-selected'));
        selected = el;
        if (!selected) return;
        selected.setAttribute('data-ui-selected', '1');
        const labelInput = document.getElementById('uiSelLabel');
        const iconInput = document.getElementById('uiSelIcon');
        const labelEl = selected.querySelector('[data-group-label]') || selected.querySelector('a');
        const iconEl = selected.querySelector('[data-group-icon]') || selected.querySelector('.emoji-icon');
        const key = selected.getAttribute('data-ui-key') || selected.getAttribute('data-group-key') || selected.getAttribute('data-item-key');
        if (labelInput) labelInput.value = (labelEl ? labelEl.textContent.trim() : '');
        if (iconInput) iconInput.value = (iconEl ? iconEl.textContent.trim() : '');
        const ov = (liveLayout.overrides && key) ? (liveLayout.overrides[key] || {}) : {};
        const bgInput = document.getElementById('uiSelBg');
        const textInput = document.getElementById('uiSelText');
        if (bgInput) bgInput.value = ov.bg || '#ffffff';
        if (textInput) textInput.value = ov.color || '#111111';
      }

      function collectConfig() {
        const sidebarNav = document.querySelector('.sidebar-scroll .sidebar-nav');
        const groups = [];
        if (sidebarNav) {
          sidebarNav.querySelectorAll('.nav-group[data-group-key]').forEach(groupEl => {
            const key = groupEl.getAttribute('data-group-key');
            const label = (groupEl.querySelector('[data-group-label]') || {}).textContent || key;
            const icon = (groupEl.querySelector('[data-group-icon]') || {}).textContent || '•';
            const hidden = groupEl.style.display === 'none';
            const items = [];
            const hiddenItems = [];
            groupEl.querySelectorAll('.nav-submenu li[data-item-key]').forEach(li => {
              var itemKey = li.getAttribute('data-item-key');
              items.push(itemKey);
              if (li.style.display === 'none') hiddenItems.push(itemKey);
            });
            var g = { key, label: label.trim(), icon: icon.trim(), items };
            if (hidden) g.hidden = true;
            if (hiddenItems.length) g.hiddenItems = hiddenItems;
            groups.push(g);
          });
        }
        return { groups };
      }

      function enableEditMode(on) {
        document.body.classList.toggle('ui-edit-mode', on);
        if (!on) {
          document.querySelectorAll('[data-ui-selected]').forEach(n => n.removeAttribute('data-ui-selected'));
          selected = null;
        }
      }

      fab.addEventListener('click', function() { panel.classList.toggle('open'); });
      closeBtn && closeBtn.addEventListener('click', function() { panel.classList.remove('open'); });
      editSwitch.addEventListener('change', function() { enableEditMode(editSwitch.checked); });

      document.getElementById('uiApplySel')?.addEventListener('click', function() {
        if (!selected) return;
        const label = (document.getElementById('uiSelLabel').value || '').trim();
        const icon = (document.getElementById('uiSelIcon').value || '').trim();
        const labelEl = selected.querySelector('[data-group-label]') || selected.querySelector('a');
        const iconEl = selected.querySelector('[data-group-icon]') || selected.querySelector('.emoji-icon');
        const bg = (document.getElementById('uiSelBg').value || '').trim();
        const color = (document.getElementById('uiSelText').value || '').trim();
        const key = selected.getAttribute('data-ui-key') || selected.getAttribute('data-group-key') || selected.getAttribute('data-item-key');
        if (label && labelEl) {
          if (labelEl.matches('a')) {
            const textNode = Array.from(labelEl.childNodes).find(n => n.nodeType === 3);
            if (textNode) textNode.nodeValue = ' ' + label;
            else labelEl.appendChild(document.createTextNode(' ' + label));
          } else {
            labelEl.textContent = label;
          }
        }
        if (icon && iconEl) iconEl.textContent = icon;
        if (bg) selected.style.backgroundColor = bg;
        if (color) selected.style.color = color;
        if (key) {
          if (!liveLayout.overrides) liveLayout.overrides = {};
          liveLayout.overrides[key] = Object.assign({}, liveLayout.overrides[key] || {}, { label, icon, bg, color });
        }
      });

      const sidebarPosSel = document.getElementById('uiSidebarPos');
      if (sidebarPosSel) {
        sidebarPosSel.value = liveLayout.sidebarPosition || 'left';
        applySidebarPosition(sidebarPosSel.value);
        sidebarPosSel.addEventListener('change', function() {
          liveLayout.sidebarPosition = sidebarPosSel.value;
          applySidebarPosition(sidebarPosSel.value);
        });
      }

      const iconSet = [
        '🏪','🖥️','🛠️','🌐','📡','📈','📦','📅','👥','💬','⚙️','🎫','🧾','💳','🔒','🔗','📋','🎯','🧠','🚀','📊','bi bi-house','bi bi-gear','bi bi-people','bi bi-broadcast','bi bi-tools','bi bi-graph-up','ri-dashboard-line','ri-tools-line','ri-team-line','ri-settings-3-line','ri-customer-service-2-line','ri-store-2-line','ri-bar-chart-box-line','ri-links-line','fa-solid fa-chart-line','fa-solid fa-users','fa-solid fa-wrench','fa-solid fa-satellite-dish','fa-solid fa-cubes','fa-solid fa-money-bill-trend-up','fa-solid fa-headset'
      ];
      const iconGrid = document.getElementById('uiIconGrid');
      const iconSearch = document.getElementById('uiIconSearch');
      function renderIconGrid(filter) {
        if (!iconGrid) return;
        const q = (filter || '').toLowerCase();
        iconGrid.innerHTML = '';
        iconSet.filter(i => !q || i.toLowerCase().includes(q)).slice(0, 300).forEach(i => {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'btn btn-light btn-sm';
          b.style.padding = '4px';
          if (i.includes('bi ') || i.includes('ri-') || i.includes('fa-')) b.innerHTML = `<i class="${i}"></i>`;
          else b.textContent = i;
          b.title = i;
          b.addEventListener('click', function() {
            document.getElementById('uiSelIcon').value = i;
          });
          iconGrid.appendChild(b);
        });
      }
      renderIconGrid('');
      iconSearch && iconSearch.addEventListener('input', function() { renderIconGrid(iconSearch.value); });

      // Group background color
      const groupBgInput = document.getElementById('uiGroupBgColor');
      const groupBgValue = document.getElementById('uiGroupBgValue');
      const applyGroupBg = document.getElementById('uiApplyGroupBg');
      if (groupBgInput) {
        const savedBg = localStorage.getItem('ui_group_bg') || '#ffffff';
        groupBgInput.value = savedBg;
        if (groupBgValue) groupBgValue.textContent = savedBg;
        groupBgInput.addEventListener('input', function() {
          if (groupBgValue) groupBgValue.textContent = this.value;
        });
      }
      if (applyGroupBg) {
        applyGroupBg.addEventListener('click', function() {
          const color = groupBgInput ? groupBgInput.value : '#ffffff';
          document.querySelector('.sidebar-scroll')?.style.setProperty('background', color, 'important');
          localStorage.setItem('ui_group_bg', color);
          // Also save to server
          if (!liveLayout.overrides) liveLayout.overrides = {};
          liveLayout.overrides['_groupBg'] = { bg: color };
        });
      }

      // Bottom nav background color
      const bottomNavBgInput = document.getElementById('uiBottomNavBgColor');
      const bottomNavBgInput2 = document.getElementById('uiBottomNavBgColor2');
      const bottomNavBgValue = document.getElementById('uiBottomNavBgValue');
      const applyBottomNavBg = document.getElementById('uiApplyBottomNavBg');
      if (bottomNavBgInput) {
        const savedBg = localStorage.getItem('ui_bottomnav_bg') || '#ffffff';
        if (savedBg.startsWith('gradient:')) {
          bottomNavBgInput.value = '#ffffff';
          if (bottomNavBgValue) bottomNavBgValue.textContent = 'gradiente';
        } else {
          bottomNavBgInput.value = savedBg;
          if (bottomNavBgValue) bottomNavBgValue.textContent = savedBg;
        }
        if (bottomNavBgInput2) bottomNavBgInput2.value = '#ffffff';
        bottomNavBgInput.addEventListener('input', function() {
          if (bottomNavBgValue && !bottomNavBgInput2) bottomNavBgValue.textContent = this.value;
        });
      }
      if (applyBottomNavBg) {
        applyBottomNavBg.addEventListener('click', function() {
          const c1 = bottomNavBgInput ? bottomNavBgInput.value : '#ffffff';
          const c2 = bottomNavBgInput2 ? bottomNavBgInput2.value : c1;
          if (c1 !== c2) {
            var grad = '135deg,' + c1 + ',' + c2;
            document.getElementById('bottomNav')?.style.setProperty('background', 'linear-gradient(' + grad + ')', 'important');
            localStorage.setItem('ui_bottomnav_bg', 'gradient:' + grad);
            if (bottomNavBgValue) bottomNavBgValue.textContent = 'gradiente';
          } else {
            document.getElementById('bottomNav')?.style.setProperty('background', c1, 'important');
            localStorage.setItem('ui_bottomnav_bg', c1);
            if (bottomNavBgValue) bottomNavBgValue.textContent = c1;
          }
        });
      }

      // Bottom nav visibility
      function renderBottomNavVisibility() {
        const container = document.getElementById('uiBottomNavVisibility');
        if (!container) return;
        const hidden = (function() { try { return JSON.parse(localStorage.getItem('ui_hidden_bottomnav') || '[]'); } catch(e) { return []; } })();
        container.innerHTML = '';
        // Grupos actuales por defecto en la barra inferior
        var items = [
          { key: 'tienda', label: 'Tienda', icon: '🏪' },
          { key: 'clientes', label: 'Clientes', icon: '🖥️' },
          { key: 'isp', label: 'ISP', icon: '🌐' },
          { key: 'redes', label: 'Herramientas', icon: '🔗' }
        ];
        items.forEach(function(item) {
          const isHidden = hidden.indexOf(item.key) !== -1;
          var existingBtn = document.querySelector('.bottom-nav-item[data-nav-group="' + item.key + '"]');
          
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'btn btn-sm w-100 text-start ' + (isHidden ? 'btn-outline-danger' : 'btn-outline-success');
          btn.innerHTML = (isHidden ? '<i class="bi bi-eye-slash"></i> ' : '<i class="bi bi-eye"></i> ') + '<strong>' + item.icon + ' ' + item.label + '</strong>';
          btn.addEventListener('click', function() {
            let h = (function() { try { return JSON.parse(localStorage.getItem('ui_hidden_bottomnav') || '[]'); } catch(e) { return []; } })();
            const idx = h.indexOf(item.key);
            if (idx !== -1) { h.splice(idx, 1); } else { h.push(item.key); }
            localStorage.setItem('ui_hidden_bottomnav', JSON.stringify(h));
            renderBottomNavVisibility();
            var navBtn = document.querySelector('.bottom-nav-item[data-nav-group="' + item.key + '"]');
            if (navBtn) navBtn.style.display = (idx !== -1) ? '' : 'none';
          });
          container.appendChild(btn);
        });
        // Botón para añadir grupos adicionales manualmente
        var addRow = document.createElement('div');
        addRow.className = 'd-flex gap-1 mt-1';
        var select = document.createElement('select');
        select.className = 'form-select form-select-sm flex-fill';
        select.innerHTML = '<option value="">+ Añadir grupo...</option>';
        document.querySelectorAll('.nav-group[data-group-key]').forEach(function(g) {
          var k = g.getAttribute('data-group-key');
          var l = (g.querySelector('[data-group-label]') || {}).textContent || k;
          // Solo mostrar grupos que NO están ya en la barra
          var already = document.querySelector('.bottom-nav-item[data-nav-group="' + k + '"]');
          if (!already) {
            var opt = document.createElement('option');
            opt.value = k;
            opt.textContent = l;
            select.appendChild(opt);
          }
        });
        select.addEventListener('change', function() {
          if (!this.value) return;
          var key = this.value;
          var group = document.querySelector('.nav-group[data-group-key="' + key + '"]');
          var label = (group ? (group.querySelector('[data-group-label]') || {}).textContent : null) || key;
          var iconEl = group ? group.querySelector('[data-group-icon]') : null;
          var icon = iconEl ? iconEl.textContent : '📌';
          var nav = document.getElementById('bottomNav');
          if (nav) {
            var newBtn = document.createElement('button');
            newBtn.className = 'bottom-nav-item';
            newBtn.setAttribute('data-nav-group', key);
            newBtn.setAttribute('onclick', "openNavGroup('" + key + "')");
            newBtn.innerHTML = '<span class="bottom-nav-icon">' + icon + '</span><span class="bottom-nav-label">' + label + '</span>';
            nav.appendChild(newBtn);
            renderBottomNavVisibility();
          }
          this.value = '';
        });
        addRow.appendChild(select);
        container.appendChild(addRow);
        
        const restoreBtn = document.createElement('button');
        restoreBtn.type = 'button';
        restoreBtn.className = 'btn btn-sm btn-outline-warning mt-1 w-100';
        restoreBtn.innerHTML = '<i class="bi bi-arrow-counterclockwise"></i> Restaurar barra inferior';
        restoreBtn.addEventListener('click', function() {
          localStorage.removeItem('ui_hidden_bottomnav');
          localStorage.removeItem('ui_bottomnav_bg');
          document.querySelectorAll('.bottom-nav-item').forEach(function(b) { b.style.display = ''; });
          // Eliminar botones añadidos dinámicamente
          var nav = document.getElementById('bottomNav');
          if (nav) {
            var originalKeys = ['tienda','clientes','isp','redes'];
            Array.from(nav.children).forEach(function(b) {
              var k = b.getAttribute('data-nav-group');
              if (k && originalKeys.indexOf(k) === -1) b.remove();
            });
          }
          document.getElementById('bottomNav')?.style.removeProperty('background');
          renderBottomNavVisibility();
          if (bottomNavBgInput) { bottomNavBgInput.value = '#ffffff'; if (bottomNavBgValue) bottomNavBgValue.textContent = '#ffffff'; }
        });
        container.appendChild(restoreBtn);
      }
      renderBottomNavVisibility();

      // Group visibility
      function renderGroupVisibility() {
        const container = document.getElementById('uiGroupVisibility');
        if (!container) return;
        var cfg = window.__UI_NAV_CONFIG;
        var serverHidden = {};
        var serverHiddenItems = {};
        if (cfg && Array.isArray(cfg.groups)) {
          cfg.groups.forEach(function(g) {
            if (g.hidden) serverHidden[g.key] = true;
            if (Array.isArray(g.hiddenItems)) serverHiddenItems[g.key] = g.hiddenItems;
          });
        }
        const hidden = (function() { try { return JSON.parse(localStorage.getItem('ui_hidden_groups') || '[]'); } catch(e) { return []; } })();
        const hiddenItems = (function() { try { return JSON.parse(localStorage.getItem('ui_hidden_items') || '{}'); } catch(e) { return {}; } })();
        container.innerHTML = '';
        document.querySelectorAll('.nav-group[data-group-key]').forEach(function(group) {
          const key = group.getAttribute('data-group-key');
          const label = (group.querySelector('[data-group-label]') || {}).textContent || key;
          const isHidden = hidden.indexOf(key) !== -1 || serverHidden[key];
          var serverHiddenForKey = serverHiddenItems[key] || [];
          
          const wrapper = document.createElement('div');
          wrapper.className = 'w-100 mb-1';
          
          // Group toggle button
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'btn btn-sm w-100 text-start ' + (isHidden ? 'btn-outline-danger' : 'btn-outline-success');
          btn.innerHTML = (isHidden ? '<i class="bi bi-eye-slash"></i> ' : '<i class="bi bi-eye"></i> ') + '<strong>' + label + '</strong>';
          btn.addEventListener('click', function() {
            let h = (function() { try { return JSON.parse(localStorage.getItem('ui_hidden_groups') || '[]'); } catch(e) { return []; } })();
            const idx = h.indexOf(key);
            if (idx !== -1) { h.splice(idx, 1); } else { h.push(key); }
            localStorage.setItem('ui_hidden_groups', JSON.stringify(h));
            renderGroupVisibility();
            if (idx !== -1) { group.style.display = ''; } else { group.style.display = 'none'; }
          });
          wrapper.appendChild(btn);
          
          // Item toggles within this group
          if (!isHidden) {
            var itemDiv = document.createElement('div');
            itemDiv.className = 'd-flex flex-wrap gap-1 mt-1 ms-2';
            group.querySelectorAll('.nav-submenu li[data-item-key]').forEach(function(li) {
              var itemKey = li.getAttribute('data-item-key');
              var itemLabel = (li.textContent || '').trim().substring(0, 20);
              var itemHidden = (hiddenItems[key] && hiddenItems[key].indexOf(itemKey) !== -1) || serverHiddenForKey.indexOf(itemKey) !== -1;
              var iBtn = document.createElement('button');
              iBtn.type = 'button';
              iBtn.className = 'btn btn-sm ' + (itemHidden ? 'btn-outline-secondary' : 'btn-outline-light');
              iBtn.style.fontSize = '0.65rem';
              iBtn.style.padding = '1px 6px';
              iBtn.innerHTML = (itemHidden ? '<i class="bi bi-eye-slash"></i> ' : '<i class="bi bi-eye"></i> ') + itemLabel;
              iBtn.addEventListener('click', function() {
                let hi = (function() { try { return JSON.parse(localStorage.getItem('ui_hidden_items') || '{}'); } catch(e) { return {}; } })();
                if (!hi[key]) hi[key] = [];
                var idx2 = hi[key].indexOf(itemKey);
                if (idx2 !== -1) { hi[key].splice(idx2, 1); } else { hi[key].push(itemKey); }
                if (!hi[key].length) delete hi[key];
                localStorage.setItem('ui_hidden_items', JSON.stringify(hi));
                renderGroupVisibility();
                if (idx2 !== -1) { li.style.display = ''; } else { li.style.display = 'none'; }
              });
              itemDiv.appendChild(iBtn);
            });
            wrapper.appendChild(itemDiv);
          }
          
          container.appendChild(wrapper);
        });
        const restoreBtn = document.createElement('button');
        restoreBtn.type = 'button';
        restoreBtn.className = 'btn btn-sm btn-outline-warning mt-1';
        restoreBtn.innerHTML = '<i class="bi bi-arrow-counterclockwise"></i> Restaurar todo';
        restoreBtn.addEventListener('click', function() {
          localStorage.removeItem('ui_hidden_groups');
          localStorage.removeItem('ui_hidden_items');
          document.querySelectorAll('.nav-group').forEach(function(g) { g.style.display = ''; });
          document.querySelectorAll('.nav-submenu li').forEach(function(li) { li.style.display = ''; });
          renderGroupVisibility();
          // Also reset bottom nav
          localStorage.removeItem('ui_hidden_bottomnav');
          localStorage.removeItem('ui_bottomnav_bg');
          document.querySelectorAll('.bottom-nav-item').forEach(function(b) { b.style.display = ''; });
          document.getElementById('bottomNav')?.style.removeProperty('background');
          renderBottomNavVisibility();
          if (bottomNavBgInput) { bottomNavBgInput.value = '#ffffff'; if (bottomNavBgValue) bottomNavBgValue.textContent = '#ffffff'; }
        });
        container.appendChild(restoreBtn);
      }
      renderGroupVisibility();

      document.addEventListener('click', function(e) {
        if (!editSwitch.checked) return;
        const target = e.target.closest('[data-ui-draggable]');
        if (target) {
          e.preventDefault();
          e.stopPropagation();
          setSelected(target);
        }
      }, true);

      const allSortables = [];

      function initDragDrop() {
        if (!window.Sortable) return;

        // Sidebar: reorder groups
        const groupsContainer = document.querySelector('.sidebar-scroll .sidebar-nav');
        if (groupsContainer) {
          allSortables.push(Sortable.create(groupsContainer, {
            animation: 120,
            draggable: '.nav-group[data-group-key]',
            handle: '.nav-group-toggle',
            disabled: true
          }));
          // Sidebar: drag items between groups (all li items)
          groupsContainer.querySelectorAll('.nav-submenu').forEach(sm => {
            allSortables.push(Sortable.create(sm, {
              group: 'sidebar-items',
              animation: 120,
              draggable: 'li',
              disabled: true
            }));
          });
        }

        // Page: stat card rows
        document.querySelectorAll('.row:has(.stat-card-item)').forEach(row => {
          allSortables.push(Sortable.create(row, {
            animation: 120,
            draggable: '.stat-card-item',
            disabled: true
          }));
        });

        // Page: section rows (movimientos, citas, nota diaria, etc.)
        const pageEl = document.querySelector('.page-container');
        if (pageEl) {
          allSortables.push(Sortable.create(pageEl, {
            animation: 120,
            draggable: '.row:has(.card.hideable-section)',
            disabled: true
          }));
        }

        // Toggle all with edit switch
        editSwitch.removeEventListener('change', toggleDragDrop);
        editSwitch.addEventListener('change', toggleDragDrop);
      }

      function toggleDragDrop() {
        const on = editSwitch.checked;
        allSortables.forEach(s => s.option('disabled', !on));
      }

      initDragDrop();

      reloadBtn && reloadBtn.addEventListener('click', function() { window.location.reload(); });

      saveBtn && saveBtn.addEventListener('click', async function() {
        try {
          const t = currentTheme;
          const payload = {
            navConfig: collectConfig(),
            customButtons: Array.isArray(window.__UI_CUSTOM_BUTTONS) ? window.__UI_CUSTOM_BUTTONS : [],
            theme: t,
            layout: liveLayout,
            sidebarBg: t.sidebarBg,
            sidebarActive: t.sidebarActive,
            primaryColor: t.primary,
            sidebarHover: t.sidebarHover,
            topbarBg: t.topbarBg,
            topbarBorder: t.topbarBorder,
            bgBody: t.bgBody,
            cardBg: t.cardBg,
            textPrimary: t.textPrimary,
            textSecondary: t.textSecondary,
            borderColor: t.borderColor,
            tableHoverBg: t.tableHoverBg,
            tableStripe: t.tableStripe,
            inputFocusShadow: t.inputFocusShadow,
            shadowSm: t.shadowSm,
            shadowMd: t.shadowMd,
            cardRadius: t.cardRadius,
            font: t.font,
            success: t.success,
            danger: t.danger,
            warning: t.warning,
            info: t.info
          };
          const r = await fetch('/configuracion/ui-editor-save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          if (!r.ok) throw new Error('No se pudo guardar');
          saveBtn.textContent = 'Guardado';
          setTimeout(() => { saveBtn.textContent = 'Guardar cambios'; }, 1000);
        } catch (e) {
          alert('Error guardando cambios de interfaz');
        }
      });

      applyOverrides();

      resetBtn && resetBtn.addEventListener('click', async function() {
        if (!confirm('¿Restaurar diseño original guardado?')) return;
        try {
          const r = await fetch('/configuracion/ui-editor-reset', { method: 'POST' });
          if (!r.ok) throw new Error('No reset');
          window.location.reload();
        } catch (e) {
          alert('No se pudo restaurar.');
        }
      });
    })();
  </script>
  <% } %>
  <script>
    // AI Chat Widget
    (function() {
      const toggle = document.getElementById('aiChatToggle');
      const panel = document.getElementById('aiChatPanel');
      const close = document.getElementById('aiChatClose');
      const input = document.getElementById('aiChatInput');
      const send = document.getElementById('aiChatSend');
      const messages = document.getElementById('aiChatMessages');

      if (!toggle || !panel) return;

      toggle.addEventListener('click', function(e) {
        e.stopPropagation();
        panel.classList.toggle('open');
        if (panel.classList.contains('open')) setTimeout(() => input?.focus(), 300);
      });

      close?.addEventListener('click', function() { panel.classList.remove('open'); });

      document.addEventListener('click', function(e) {
        if (panel.classList.contains('open') && !panel.contains(e.target) && e.target !== toggle && !toggle.contains(e.target)) {
          panel.classList.remove('open');
        }
      });

      function addMessage(text, isUser) {
        const div = document.createElement('div');
        div.className = isUser ? 'user-message' : 'ai-message';
        if (isUser) {
          div.innerHTML = '<div class="user-bubble">' + text + '</div>';
        } else {
          div.innerHTML = '<div class="ai-avatar"><i class="ri-robot-line"></i></div><div class="ai-bubble">' + text + '</div>';
        }
        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
      }

      function sendMessage() {
        const text = input.value.trim();
        if (!text) return;
        addMessage(text, true);
        input.value = '';

        fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: text })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          setTimeout(function() { addMessage(data.response, false); }, 300 + Math.random() * 300);
        })
        .catch(function() {
          setTimeout(function() { addMessage('Lo siento, hubo un error de conexión. Inténtalo de nuevo.', false); }, 500);
        });
      }

      send?.addEventListener('click', sendMessage);
      input?.addEventListener('keydown', function(e) { if (e.key === 'Enter') sendMessage(); });
    })();
  </script>
<script>
(function() {
  var input = document.getElementById('globalSearchInput');
  var dropdown = document.getElementById('globalSearchDropdown');
  if (!input || !dropdown) return;
  var timer = null;
  input.addEventListener('keyup', function() {
    clearTimeout(timer);
    var q = input.value.trim();
    if (q.length < 3) {
      dropdown.style.display = 'none';
      dropdown.innerHTML = '';
      return;
    }
    timer = setTimeout(function() {
      fetch('/api/search?q=' + encodeURIComponent(q))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data || data.length === 0) {
            dropdown.innerHTML = '<div class="text-muted text-center py-3 small" style="pointer-events:none;">Sin resultados</div>';
          } else {
            dropdown.innerHTML = data.map(function(r) {
              var badgeClass = r.origen === 'API' ? 'bg-info' : 'bg-success';
              var badgeLabel = r.origen === 'API' ? 'API' : 'Local';
              var href = r.id ? '/customers/' + r.id : '/customers?search=' + encodeURIComponent(r.telefono || r.nombre);
              return '<a href="' + href + '"><div class="d-flex justify-content-between align-items-start"><strong>' + r.nombre + '</strong> <span class="src-badge badge ' + badgeClass + '">' + badgeLabel + '</span></div><div class="small text-muted">' + (r.telefono ? r.telefono : '') + (r.fiscalId ? ' &middot; ' + r.fiscalId : '') + '</div></a>';
            }).join('');
          }
          dropdown.style.display = 'block';
        })
        .catch(function() {
          dropdown.innerHTML = '<div class="text-muted text-center py-3 small" style="pointer-events:none;">Error de b&uacute;squeda</div>';
          dropdown.style.display = 'block';
        });
    }, 300);
  });
  document.addEventListener('click', function(e) {
    if (!document.getElementById('globalSearchWrapper').contains(e.target)) {
      dropdown.style.display = 'none';
    }
  });
  input.addEventListener('blur', function() {
    setTimeout(function() { dropdown.style.display = 'none'; }, 200);
  });
  input.addEventListener('focus', function() {
    if (input.value.trim().length >= 3 && dropdown.innerHTML) {
      dropdown.style.display = 'block';
    }
  });
})();
</script>
</body>
