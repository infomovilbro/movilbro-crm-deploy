  <% if (user && user.rol === 'admin') { %>
  <button id="uiEditorToggle" class="btn btn-primary btn-sm ui-editor-fab">
    <i class="bi bi-magic"></i> Editar interfaz
  </button>
  <div id="uiEditorPanel" class="ui-editor-panel">
    <div class="head d-flex justify-content-between align-items-center">
      <span><i class="bi bi-sliders"></i> Modo diseñador</span>
      <button id="uiEditorClose" class="btn btn-sm btn-light">×</button>
    </div>
    <div class="body">
      <div class="form-check form-switch mb-2">
        <input class="form-check-input" type="checkbox" id="uiEditModeSwitch">
        <label class="form-check-label" for="uiEditModeSwitch">Activar arrastrar y editar</label>
