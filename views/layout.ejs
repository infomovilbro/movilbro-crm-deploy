      <div class="mb-2">
        <label class="form-label small mb-1">Elemento seleccionado</label>
        <input id="uiSelLabel" class="form-control form-control-sm mb-1" placeholder="Nombre">
        <input id="uiSelIcon" class="form-control form-control-sm mb-1" placeholder="Emoji/Icono">
        <input id="uiSelBg" type="color" class="form-control form-control-color mb-1" title="Color fondo elemento">
        <input id="uiSelText" type="color" class="form-control form-control-color mb-1" title="Color texto elemento">
        <button id="uiApplySel" class="btn btn-outline-primary btn-sm w-100">Aplicar al seleccionado</button>
