<div class="container py-4">
  <div class="text-center mb-4">
    <h2><span style="font-size:2.5rem;">🔌</span></h2>
    <h3>Regleta</h3>
  </div>

  <div class="row justify-content-center">
    <div class="col-md-6 col-12">
      <div class="card shadow-sm">
        <div class="card-body text-center py-5">
          <div style="font-size:4rem;margin-bottom:16px;" id="deviceEmoji">🔌</div>
          <h4 id="deviceStatus"><%= encendido ? 'Regleta Encendida' : 'Regleta Apagada' %></h4>
          <div class="mt-4">
            <button class="btn <%= encendido ? 'btn-danger' : 'btn-success' %> btn-lg px-5" id="btnToggle" style="border-radius:50px;font-size:1.2rem;">
              <i class="bi <%= encendido ? 'bi-power' : 'bi-play-circle' %>"></i>
              <%= encendido ? 'Apagar' : 'Encender' %>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.getElementById('btnToggle')?.addEventListener('click', function() {
  var btn = this;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>...';
  fetch('/neon/regleta/toggle', { method: 'POST' })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      var emoji = document.getElementById('deviceEmoji');
      var status = document.getElementById('deviceStatus');
      if (d.estado === 'on') {
        status.textContent = 'Regleta Encendida';
        btn.className = 'btn btn-danger btn-lg px-5';
        btn.innerHTML = '<i class="bi bi-power"></i> Apagar';
        if (emoji) emoji.textContent = '🔌';
      } else {
        status.textContent = 'Regleta Apagada';
        btn.className = 'btn btn-success btn-lg px-5';
        btn.innerHTML = '<i class="bi bi-play-circle"></i> Encender';
        if (emoji) emoji.textContent = '🔌';
      }
    })
    .catch(function() { alert('Error de conexión'); })
    .finally(function() { btn.disabled = false; });
});
</script>
