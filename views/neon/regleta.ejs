<div class="container py-4">
  <div class="text-center mb-4">
    <h2><span style="font-size:2.5rem;">🔌</span></h2>
    <h3>Regleta</h3>
  </div>

  <div class="row justify-content-center">
    <div class="col-md-6 col-12">
      <div class="card shadow-sm">
        <div class="card-body text-center py-5">
          <div style="font-size:4rem;margin-bottom:16px;">🔌</div>
          <h4 id="deviceStatus"><%= encendido ? 'Regleta Encendida' : 'Regleta Apagada' %></h4>
          <p class="text-muted small mt-2">Abre Google Home para encender o apagar el dispositivo</p>
          <div class="mt-4">
            <a href="https://home.google.com/u/0/home/1-6ff6f6e3b2b29773e29edbafcd1db17d58c465324c48d6150735a2be622099ee/devices" target="_blank" class="btn btn-primary btn-lg px-5" style="border-radius:50px;font-size:1.2rem;" onclick="event.stopPropagation();">
              <i class="bi bi-google"></i> <%= encendido ? 'Apagar' : 'Encender' %>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
