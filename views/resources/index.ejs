<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="ri-folders-line"></i> Recursos</h2>
    <div class="d-flex gap-2">
      <input type="text" id="resourceSearch" class="form-control form-control-sm" placeholder="Buscar documentos..." style="width:220px;">
    </div>
  </div>

  <% if (resources.length === 0) { %>
    <div class="text-center text-muted py-5">
      <i class="ri-inbox-line" style="font-size:3rem;"></i>
      <p class="mt-2">No hay recursos disponibles</p>
    </div>
  <% } else { %>

  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="card">
        <div class="card-header py-2"><small><i class="ri-pie-chart-2-line"></i> Documentos por categoría</small></div>
        <div class="card-body py-2" style="overflow:hidden;">
          <div style="height:180px;"><canvas id="chartCategory"></canvas></div>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card">
        <div class="card-header py-2"><small><i class="ri-bar-chart-grouped-line"></i> Documentos por mes</small></div>
        <div class="card-body py-2" style="overflow:hidden;">
          <div style="height:180px;"><canvas id="chartMonth"></canvas></div>
        </div>
      </div>
    </div>
  </div>

  <% resources.forEach(function(cat) { %>
  <div class="card mb-3 resource-category">
    <div class="card-header d-flex justify-content-between align-items-center py-2" data-bs-toggle="collapse" data-bs-target="#collapse<%= cat.title.replace(/[^a-zA-Z0-9]/g,'') %>" style="cursor:pointer;">
      <span><i class="ri-folder-5-line me-1"></i> <strong><%= cat.title %></strong> <span class="badge bg-secondary"><%= (cat.folders || []).reduce((s,f) => s + (f.documents||[]).length, 0) %></span></span>
      <i class="ri-arrow-down-s-line"></i>
    </div>
    <div class="collapse show" id="collapse<%= cat.title.replace(/[^a-zA-Z0-9]/g,'') %>">
      <div class="card-body p-0">
        <% if (!cat.folders || cat.folders.length === 0) { %>
          <div class="text-center text-muted py-3"><small>Sin carpetas</small></div>
        <% } else { %>
          <div class="accordion accordion-flush" id="accordion<%= cat.title.replace(/[^a-zA-Z0-9]/g,'') %>">
          <% cat.folders.forEach(function(folder, fi) { %>
            <div class="accordion-item">
              <h2 class="accordion-header">
                <button class="accordion-button collapsed py-2" type="button" data-bs-toggle="collapse" data-bs-target="#folder<%= cat.title.replace(/[^a-zA-Z0-9]/g,'') %><%= fi %>">
                  <i class="ri-folder-3-line me-2 text-warning"></i> <%= folder.title %>
                  <span class="badge bg-info ms-2"><%= (folder.documents||[]).length %></span>
                </button>
              </h2>
              <div id="folder<%= cat.title.replace(/[^a-zA-Z0-9]/g,'') %><%= fi %>" class="accordion-collapse collapse" data-bs-parent="#accordion<%= cat.title.replace(/[^a-zA-Z0-9]/g,'') %>">
                <div class="accordion-body p-0">
                  <% if (!folder.documents || folder.documents.length === 0) { %>
                    <div class="text-center text-muted py-2"><small>Sin documentos</small></div>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-sm table-hover mb-0 document-table">
                        <tbody>
                        <% folder.documents.forEach(function(doc) { %>
                          <tr class="document-row" data-name="<%= doc.toLowerCase() %>">
                            <td class="ps-3"><i class="ri-file-text-line me-1 text-muted"></i> <%= doc %></td>
                            <td class="text-end pe-3">
                              <a href="/resources/download?path=<%= encodeURIComponent(folder.path + '/' + doc) %>" class="btn btn-sm btn-outline-primary" title="Descargar" target="_blank">
                                <i class="ri-download-2-line"></i>
                              </a>
                            </td>
                          </tr>
                        <% }) %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
  <% }) %>

  <% } %>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var catLabels = <%= JSON.stringify(Object.keys(categoryCounts)) %>;
  var catData = <%= JSON.stringify(Object.values(categoryCounts)) %>;
  var catColors = ['#0d6efd','#198754','#ffc107','#dc3545','#6610f2','#fd7e14','#20c997','#0dcaf0','#6c757d','#d63384'];

  new Chart(document.getElementById('chartCategory'), {
    type: 'doughnut',
    data: {
      labels: catLabels,
      datasets: [{ data: catData, backgroundColor: catColors.slice(0, catLabels.length), borderWidth: 1 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      animation: false,
      plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, padding: 8, font: { size: 10 } } } }
    }
  });

  var monthEntries = <%= JSON.stringify(Object.entries(monthCounts).sort(function(a,b) { return a[0].localeCompare(b[0]); })) %>;
  var monthLabels = monthEntries.map(function(e) { return e[0]; });
  var monthData = monthEntries.map(function(e) { return e[1]; });

  new Chart(document.getElementById('chartMonth'), {
    type: 'bar',
    data: {
      labels: monthLabels,
      datasets: [{ label: 'Documentos', data: monthData, backgroundColor: '#0d6efd', borderRadius: 4 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      animation: false,
      plugins: { legend: { display: false } },
      scales: {
        y: { beginAtZero: true, grid: { color: '#eee' }, ticks: { font: { size: 9 } } },
        x: { grid: { display: false }, ticks: { font: { size: 9 } } }
      }
    }
  });

  document.getElementById('resourceSearch').addEventListener('input', function() {
    var q = this.value.toLowerCase().trim();
    document.querySelectorAll('.document-row').forEach(function(row) {
      var name = row.dataset.name || '';
      row.style.display = (!q || name.includes(q)) ? '' : 'none';
    });
    document.querySelectorAll('.accordion-item').forEach(function(item) {
      var visible = Array.from(item.querySelectorAll('.document-row')).some(function(r) { return r.style.display !== 'none'; });
      var noDocs = item.querySelectorAll('.document-row').length === 0;
      item.style.display = (!q || visible || noDocs) ? '' : 'none';
    });
  });
});
</script>
