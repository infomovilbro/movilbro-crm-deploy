<section>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2><i class="bi bi-ticket"></i> <%= ticket.asunto %></h2>
      <span class="text-muted"><%= new Date(ticket.created_at).toLocaleString('es-ES') %></span>
    </div>
    <a href="/tickets" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
  </div>
  <div class="row g-3">
    <div class="col-md-6">
      <div class="card">
        <div class="card-header">Detalles del Ticket</div>
        <div class="card-body">
          <table class="table table-sm">
            <tr><th>Asunto</th><td><%= ticket.asunto %></td></tr>
            <tr><th>Prioridad</th><td><span class="badge bg-<%= ticket.prioridad === 'alta' ? 'danger' : ticket.prioridad === 'baja' ? 'success' : 'warning' %>"><%= ticket.prioridad %></span></td></tr>
            <tr><th>Estado</th>
              <td>
                <span class="badge bg-<%= ticket.estado === 'abierto' ? 'warning' : ticket.estado === 'cerrado' ? 'success' : 'info' %> fs-6"><%= ticket.estado %></span>
              </td>
            </tr>
            <tr><th>Descripción</th><td><%= ticket.descripcion || '-' %></td></tr>
          </table>
          <form method="POST" action="/tickets/<%= ticket.id %>/estado" class="mt-3">
            <div class="input-group">
              <select name="estado" class="form-select">
                <option value="abierto" <%= ticket.estado === 'abierto' ? 'selected' : '' %>>Abierto</option>
                <option value="en_curso" <%= ticket.estado === 'en_curso' ? 'selected' : '' %>>En Curso</option>
                <option value="cerrado" <%= ticket.estado === 'cerrado' ? 'selected' : '' %>>Cerrado</option>
              </select>
              <button type="submit" class="btn btn-primary">Actualizar</button>
            </div>
          </form>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card">
        <div class="card-header">Cliente</div>
        <div class="card-body">
          <% if (ticket.client_id) { %>
          <table class="table table-sm">
            <tr><th>Nombre</th><td><%= ticket.cliente_nombre %></td></tr>
            <tr><th>Teléfono</th><td><a href="tel:<%= ticket.cliente_telefono %>"><%= ticket.cliente_telefono %></a></td></tr>
            <tr><th>Email</th><td><%= ticket.cliente_email || '-' %></td></tr>
          </table>
          <% } else { %>
          <p class="text-muted">Cliente no asociado</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>
