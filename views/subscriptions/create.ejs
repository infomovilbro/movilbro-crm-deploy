<section class="row justify-content-center">
  <div class="col-md-8">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2><i class="bi bi-plus-circle"></i> Nueva Suscripción</h2>
      <a href="/suscripciones" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
    </div>
    <% if (errors.length > 0) { %><div class="alert alert-danger"><%= errors.join(', ') %></div><% } %>
    <div class="card">
      <div class="card-body">
        <form method="POST">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Cliente *</label>
              <select name="client_id" class="form-select" required>
                <option value="">Seleccionar cliente...</option>
                <% clientes.forEach(c => { %>
                <option value="<%= c.id %>" <%= sub.client_id == c.id ? 'selected' : '' %>><%= c.nombre %> <%= c.apellidos || '' %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Número de línea</label>
              <input type="text" name="linea" class="form-control" value="<%= sub.linea || '' %>" placeholder="Ej: 694297048">
            </div>
            <div class="col-md-6">
              <label class="form-label">Producto *</label>
              <select name="producto" class="form-select" required>
                <option value="">Seleccionar...</option>
                <option value="Fibra 600" <%= sub.producto === 'Fibra 600' ? 'selected' : '' %>>Fibra 600</option>
                <option value="Fibra 1000" <%= sub.producto === 'Fibra 1000' ? 'selected' : '' %>>Fibra 1000</option>
                <option value="Móvil 30GB" <%= sub.producto === 'Móvil 30GB' ? 'selected' : '' %>>Móvil 30GB</option>
                <option value="Móvil 50GB" <%= sub.producto === 'Móvil 50GB' ? 'selected' : '' %>>Móvil 50GB</option>
                <option value="Móvil 100GB" <%= sub.producto === 'Móvil 100GB' ? 'selected' : '' %>>Móvil 100GB</option>
                <option value="Fibra+Móvil 600" <%= sub.producto === 'Fibra+Móvil 600' ? 'selected' : '' %>>Fibra + Móvil 600</option>
                <option value="Fibra+Móvil 1000" <%= sub.producto === 'Fibra+Móvil 1000' ? 'selected' : '' %>>Fibra + Móvil 1000</option>
                <option value="SuperPack" <%= sub.producto === 'SuperPack' ? 'selected' : '' %>>SuperPack</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Fecha de alta</label>
              <input type="date" name="fecha_alta" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
            </div>
          </div>
          <div class="mt-4">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Crear Suscripción</button>
            <a href="/suscripciones" class="btn btn-outline-secondary">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
