<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-tag"></i> Suscripciones <span class="badge bg-secondary fs-6"><%= totalItems %></span></h5>
    <div>
      <% if (apiCount > 0) { %>
        <span class="badge bg-info me-1"><i class="bi bi-cloud"></i> <%= apiCount %> API</span>
      <% } %>
      <% if (apiError) { %>
        <span class="badge bg-warning text-dark me-1" title="<%= apiError %>"><i class="bi bi-exclamation-triangle"></i></span>
      <% } %>
      <a href="/suscripciones/nueva" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg"></i> Nueva</a>
    </div>
  </div>

  <!-- Charts row: 4 charts compactos -->
  <div class="row g-2 mb-3">
    <div class="col-md-3">
      <div class="card cursor-pointer" style="cursor:pointer;" onclick="abrirDetalle('estado')"><div class="card-body p-2">
        <small class="text-muted">Estado global</small>
        <div class="chart-wrap" style="height:170px;overflow:hidden;position:relative;"><canvas id="chartEstado"></canvas></div>
        <div id="legendEstado" class="mt-1" style="font-size:0.55rem;line-height:1.3;"></div>
      </div></div>
    </div>
    <div class="col-md-3">
      <div class="card cursor-pointer" style="cursor:pointer;" onclick="abrirDetalle('familia')"><div class="card-body p-2">
        <small class="text-muted">Familia x Estado</small>
        <div class="chart-wrap" style="height:170px;overflow:hidden;position:relative;"><canvas id="chartFamilia"></canvas></div>
        <div id="legendFamilia" class="mt-1" style="font-size:0.55rem;line-height:1.3;"></div>
      </div></div>
    </div>
    <div class="col-md-3">
      <div class="card cursor-pointer" style="cursor:pointer;" onclick="abrirDetalle('productos')"><div class="card-body p-2">
        <small class="text-muted">Productos m&aacute;s contratados</small>
        <div class="chart-wrap" style="height:170px;overflow:hidden;position:relative;"><canvas id="chartProductos"></canvas></div>
      </div></div>
    </div>
    <div class="col-md-3">
      <div class="card cursor-pointer" style="cursor:pointer;" onclick="abrirDetalle('altas')"><div class="card-body p-2">
        <small class="text-muted">Altas por mes</small>
        <div class="chart-wrap" style="height:170px;overflow:hidden;position:relative;"><canvas id="chartAltas"></canvas></div>
      </div></div>
    </div>
  </div>

  <!-- Modal de detalle -->
  <div class="modal fade" id="detalleModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header py-2">
          <h6 class="modal-title" id="detalleTitulo"></h6>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body p-2" id="detalleBody"></div>
      </div>
    </div>
  </div>

  <!-- Filter -->
  <div class="card mb-2">
    <div class="card-body py-1 px-2">
      <form method="GET" action="/suscripciones" class="row g-1 align-items-center">
        <div class="col-auto">
          <label class="col-form-label fw-bold small">Estado:</label>
        </div>
        <div class="col-auto">
          <select name="estado" class="form-select form-select-sm" onchange="this.form.submit()">
            <option value="">Todos</option>
            <option value="activa" <%= estadoFilter === 'activa' ? 'selected' : '' %>>Activa</option>
            <option value="baja" <%= estadoFilter === 'baja' ? 'selected' : '' %>>Baja</option>
            <option value="suspendida" <%= estadoFilter === 'suspendida' ? 'selected' : '' %>>Suspendida</option>
            <option value="pendiente" <%= estadoFilter === 'pendiente' ? 'selected' : '' %>>Pendiente</option>
          </select>
        </div>
        <% if (estadoFilter) { %>
        <div class="col-auto">
          <a href="/suscripciones" class="btn btn-sm btn-outline-secondary"><i class="bi bi-x-circle"></i></a>
        </div>
        <% } %>
      </form>
    </div>
  </div>

  <!-- Table -->
  <div class="card">
    <div class="table-responsive">
      <table class="table table-sm table-hover mb-0 align-middle">
        <thead class="table-dark">
          <tr>
            <th>Cliente</th>
            <th>L&iacute;nea</th>
            <th>Producto</th>
            <th>Familia</th>
            <th>Estado</th>
            <th>Alta</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% if (suscripciones.length === 0) { %>
          <tr><td colspan="7" class="text-center text-muted py-3"><small><i class="bi bi-inbox"></i> No hay suscripciones</small></td></tr>
          <% } else { %>
            <% suscripciones.forEach(function(s) { %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-1">
                  <% if (s.cliente_nombre && s.cliente_nombre !== s.linea) { %>
                    <span class="small fw-semibold"><%= s.cliente_nombre %></span>
                  <% } else { %>
                    <span class="small text-muted"><%= s.linea || 'Sin cliente' %></span>
                  <% } %>
                  <% if (s.from_api) { %>
                    <small class="text-info" style="font-size:0.6rem;"><i class="bi bi-cloud"></i></small>
                  <% } %>
                </div>
              </td>
              <td class="small"><%= s.linea || '-' %></td>
              <td class="small"><%= s.producto || '-' %></td>
              <td><span class="badge bg-secondary" style="font-size:0.6rem;"><%= s.familia || '-' %></span></td>
              <td>
                <span class="badge" style="font-size:0.6rem!important;background:<%= s.estado === 'activa' ? '#198754' : s.estado === 'suspendida' ? '#ffc107' : s.estado === 'pendiente' ? '#0d6efd' : s.estado === 'cambio tarifa' ? '#6f42c1' : '#dc3545' %>">
                  <%= s.estado.charAt(0).toUpperCase() + s.estado.slice(1) %>
                </span>
              </td>
              <td class="small text-nowrap"><%= s.fecha_alta ? new Date(s.fecha_alta).toLocaleDateString('es-ES') : '-' %></td>
              <td class="text-end">
                <% if (!s.from_api && s.id) { %>
                <form method="POST" action="/suscripciones/<%= s.id %>/estado" class="d-inline">
                  <input type="hidden" name="fecha_baja" value="<%= new Date().toISOString() %>">
                  <% if (s.estado === 'activa') { %>
                  <button type="submit" name="estado" value="baja" class="btn btn-sm btn-outline-danger py-0 px-1" onclick="return confirm('\u00BFDar de baja?')"><i class="bi bi-x-circle"></i></button>
                  <% } else { %>
                  <button type="submit" name="estado" value="activa" class="btn btn-sm btn-outline-success py-0 px-1"><i class="bi bi-check-circle"></i></button>
                  <% } %>
                </form>
                <% } %>
              </td>
            </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
    <% if (totalPages > 1) { %>
    <div class="card-footer py-1">
      <nav>
        <ul class="pagination pagination-sm justify-content-center mb-0">
          <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
            <a class="page-link py-0 px-2" href="/suscripciones?page=<%= page - 1 %><%= estadoFilter ? '&estado=' + estadoFilter : '' %>"><i class="bi bi-chevron-left"></i></a>
          </li>
          <% var startPage = Math.max(1, page - 2); %>
          <% var endPage = Math.min(totalPages, page + 2); %>
          <% for (var p = startPage; p <= endPage; p++) { %>
          <li class="page-item <%= p === page ? 'active' : '' %>">
            <a class="page-link py-0 px-2" href="/suscripciones?page=<%= p %><%= estadoFilter ? '&estado=' + estadoFilter : '' %>"><%= p %></a>
          </li>
          <% } %>
          <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
            <a class="page-link py-0 px-2" href="/suscripciones?page=<%= page + 1 %><%= estadoFilter ? '&estado=' + estadoFilter : '' %>"><i class="bi bi-chevron-right"></i></a>
          </li>
        </ul>
      </nav>
    </div>
    <% } %>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var opts = { responsive: true, maintainAspectRatio: false, animation: false, resizeDelay: 0 };

  function buildLegend(containerId, labels, colors, data) {
    var html = '';
    for (var i = 0; i < labels.length; i++) {
      html += '<span style="display:inline-block;margin-right:8px;white-space:nowrap;">';
      html += '<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:' + colors[i] + ';margin-right:3px;vertical-align:middle;"></span>';
      html += '<span style="vertical-align:middle;">' + labels[i] + ': ' + data[i] + '</span>';
      html += '</span>';
    }
    var el = document.getElementById(containerId);
    if (el) el.innerHTML = html;
  }

  // Store chart data for detail modal
  var chartDataStore = {};

  // Chart 1: Estado global donut
  try {
    var labels = <%- JSON.stringify(charts.status.labels) %>;
    var data = <%- JSON.stringify(charts.status.data) %>;
    var colors = <%- JSON.stringify(charts.status.colors) %>;
    if (labels && labels.length) {
      var display = labels.map(function(l){ return l.charAt(0).toUpperCase() + l.slice(1); });
      new Chart(document.getElementById('chartEstado'), {
        type: 'doughnut',
        data: { labels: display, datasets: [{ data: data, backgroundColor: colors, borderWidth: 0 }] },
        options: Object.assign({}, opts, { cutout: '65%', plugins: { legend: { display: false }, tooltip: { enabled: true } } })
      });
      buildLegend('legendEstado', display, colors, data);
      chartDataStore.estado = { titulo: 'Estado global de suscripciones', labels: display, data: data, colors: colors, tipo: 'estado' };
    }
  } catch(e) { console.error('E1:', e); }

  // Chart 2: Familia x Estado stacked bar
  try {
    var famLabels = <%- JSON.stringify(charts.familyStacked.labels) %>;
    var famDatasets = <%- JSON.stringify(charts.familyStacked.datasets) %>;
    if (famLabels && famLabels.length && famDatasets && famDatasets.length) {
      new Chart(document.getElementById('chartFamilia'), {
        type: 'bar',
        data: { labels: famLabels, datasets: famDatasets },
        options: Object.assign({}, opts, { layout: { padding: { top: 2, bottom: 2 } }, scales: { x: { stacked: true, grid: { display: false }, ticks: { font: { size: 7 } } }, y: { stacked: true, beginAtZero: true, grid: { color: '#eee' }, ticks: { font: { size: 7 } } } }, plugins: { legend: { display: false }, tooltip: { enabled: true } } })
      });
      // External legend for familia
      (function() {
        var html = '';
        for (var dsIdx = 0; dsIdx < famDatasets.length; dsIdx++) {
          var ds = famDatasets[dsIdx];
          var total = ds.data.reduce(function(a,b){ return a+b; }, 0);
          html += '<span style="display:inline-block;margin-right:6px;white-space:nowrap;">';
          html += '<span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:' + ds.backgroundColor + ';margin-right:2px;vertical-align:middle;"></span>';
          html += '<span style="vertical-align:middle;">' + ds.label + ': ' + total + '</span>';
          html += '</span>';
        }
        var el = document.getElementById('legendFamilia');
        if (el) el.innerHTML = html;
      })();
      // Build detail table
      var detailHtml = '<table class="table table-sm table-bordered mb-0"><thead><tr><th>Familia</th>';
      famDatasets.forEach(function(ds) { detailHtml += '<th>' + ds.label + '</th>'; });
      detailHtml += '<th>Total</th></tr></thead><tbody>';
      for (var i = 0; i < famLabels.length; i++) {
        detailHtml += '<tr><td>' + famLabels[i] + '</td>';
        var total = 0;
        famDatasets.forEach(function(ds) { var v = ds.data[i]||0; detailHtml += '<td>' + v + '</td>'; total += v; });
        detailHtml += '<td><strong>' + total + '</strong></td></tr>';
      }
      detailHtml += '</tbody></table>';
      chartDataStore.familia = { titulo: 'Suscripciones por familia y estado', html: detailHtml };
    }
  } catch(e) { console.error('E2:', e); }

  // Chart 3: Productos bar
  try {
    var labels = <%- JSON.stringify(charts.products.labels) %>;
    var data = <%- JSON.stringify(charts.products.data) %>;
    if (labels && labels.length) {
      new Chart(document.getElementById('chartProductos'), {
        type: 'bar',
        data: { labels: labels, datasets: [{ label: '', data: data, backgroundColor: '#0d6efd', borderRadius: 3 }] },
        options: Object.assign({}, opts, { indexAxis: 'y', scales: { x: { beginAtZero: true, grid: { color: '#eee' }, ticks: { font: { size: 8 } } }, y: { grid: { display: false } } }, plugins: { legend: { display: false } } })
      });
      var detailHtml = '<table class="table table-sm table-bordered mb-0"><thead><tr><th>Producto</th><th>Contrataciones</th></tr></thead><tbody>';
      for (var i = 0; i < labels.length; i++) { detailHtml += '<tr><td>' + labels[i] + '</td><td>' + data[i] + '</td></tr>'; }
      detailHtml += '</tbody></table>';
      chartDataStore.productos = { titulo: 'Productos m\u00e1s contratados', html: detailHtml };
    }
  } catch(e) { console.error('E3:', e); }

  // Chart 4: Altas por mes bar
  try {
    var labels = <%- JSON.stringify(charts.monthly.labels) %>;
    var data = <%- JSON.stringify(charts.monthly.data) %>;
    if (labels && labels.length) {
      new Chart(document.getElementById('chartAltas'), {
        type: 'bar',
        data: { labels: labels, datasets: [{ label: '', data: data, backgroundColor: '#198754', borderRadius: 3 }] },
        options: Object.assign({}, opts, { scales: { y: { beginAtZero: true, grid: { color: '#eee' }, ticks: { font: { size: 8 } } }, x: { grid: { display: false }, ticks: { font: { size: 7 } } } }, plugins: { legend: { display: false } } })
      });
      var detailHtml = '<table class="table table-sm table-bordered mb-0"><thead><tr><th>Mes</th><th>Altas</th></tr></thead><tbody>';
      for (var i = 0; i < labels.length; i++) { detailHtml += '<tr><td>' + labels[i] + '</td><td>' + data[i] + '</td></tr>'; }
      detailHtml += '</tbody></table>';
      chartDataStore.altas = { titulo: 'Altas por mes', html: detailHtml };
    }
  } catch(e) { console.error('E4:', e); }

  // Store detail data for modal
  var statusDetail = <%- JSON.stringify(charts.status.detail) %>;

  // Expose abrirDetalle globally
  window.abrirDetalle = function(tipo) {
    var info = chartDataStore[tipo];
    if (!info) return;
    document.getElementById('detalleTitulo').textContent = info.titulo;
    var html = '';

    if (tipo === 'estado') {
      // Summary table
      html += '<table class="table table-sm table-bordered mb-2"><thead><tr><th>Categor\u00EDa</th><th>Cantidad</th><th></th></tr></thead><tbody>';
      for (var i = 0; i < info.labels.length; i++) {
        var key = info.labels[i].toLowerCase();
        // Normalize: "Pendiente baja" -> "pendiente baja", "Pendiente" -> "pendiente", etc.
        var normKey = key;
        var items = statusDetail[normKey] || [];
        if (!items.length) {
          // Try matching by partial name
          for (var sk in statusDetail) {
            if (info.labels[i].toLowerCase().indexOf(sk) >= 0 || sk.indexOf(info.labels[i].toLowerCase()) >= 0) {
              items = statusDetail[sk];
              break;
            }
          }
        }
        html += '<tr>';
        html += '<td><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:' + info.colors[i] + ';margin-right:5px;vertical-align:middle;"></span>' + info.labels[i] + '</td>';
        html += '<td><strong>' + info.data[i] + '</strong></td>';
        html += '<td><button class="btn btn-sm btn-outline-secondary py-0 px-1" onclick="mostrarDetalle(\'' + info.labels[i] + '\',' + info.data[i] + ')"><i class="bi bi-eye"></i></button></td>';
        html += '</tr>';
      }
      html += '</tbody></table>';
      html += '<div id="detalleSubs"></div>';
    } else if (info.html) {
      html = info.html;
    }

    document.getElementById('detalleBody').innerHTML = html;
    var modal = new bootstrap.Modal(document.getElementById('detalleModal'));
    modal.show();
  };

  window.mostrarDetalle = function(categoria, total) {
    var norm = categoria.toLowerCase().trim();
    var items = statusDetail[norm] || [];
    // Try matching
    if (!items.length) {
      for (var sk in statusDetail) {
        if (norm.indexOf(sk) >= 0 || sk.indexOf(norm) >= 0) {
          items = statusDetail[sk];
          break;
        }
      }
    }
    if (!items.length) {
      document.getElementById('detalleSubs').innerHTML = '<div class="text-muted small">Sin datos detallados para esta categor\u00EDa</div>';
      return;
    }
    var html = '<div class="fw-bold small mb-1">' + categoria + ' (' + total + '):</div>';
    html += '<div style="max-height:300px;overflow-y:auto;"><table class="table table-sm table-bordered mb-0"><thead><tr><th>L\u00EDnea</th><th>Producto</th><th>Familia</th><th>Alta</th></tr></thead><tbody>';
    for (var i = 0; i < items.length; i++) {
      var d = items[i].fecha_alta ? new Date(items[i].fecha_alta).toLocaleDateString('es-ES') : '-';
      html += '<tr><td class="small">' + (items[i].linea || '-') + '</td><td class="small">' + (items[i].producto || '-') + '</td><td class="small">' + (items[i].familia || '-') + '</td><td class="small">' + d + '</td></tr>';
    }
    if (total > items.length) html += '<tr><td colspan="4" class="text-muted small">... y ' + (total - items.length) + ' m\u00E1s</td></tr>';
    html += '</tbody></table></div>';
    document.getElementById('detalleSubs').innerHTML = html;
  };
});
</script>
