// Coverage check
function checkCoverage() {
  var dir = document.getElementById('wCoverageDir').value.trim();
  if (!dir) { alert('Introduce una dirección'); return; }
  var resultEl = document.getElementById('coverageResult');
  resultEl.innerHTML = '<span class="text-primary"><i class="bi bi-hourglass-split"></i> Verificando cobertura...</span>';

  fetch('/cobertura/address?q=' + encodeURIComponent(dir))
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data && data.addresses && data.addresses.length > 0) {
        var addr = data.addresses[0];
        resultEl.innerHTML =
          '<div class="alert alert-success mb-0"><i class="bi bi-check-circle"></i> Cobertura disponible<br>' +
          '<small>' + (addr.fullAddress || addr.address || addr.name || 'Dirección encontrada') + '</small></div>';
      } else {
        resultEl.innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-x-circle"></i> No hay cobertura en esta dirección</div>';
      }
    })
    .catch(function(e) {
      resultEl.innerHTML = '<div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle"></i> Error al verificar. Introduce una dirección más concreta.</div>';
    });
}

