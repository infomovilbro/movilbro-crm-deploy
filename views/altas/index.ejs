<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-plus"></i> <%= ui.moduleName.altas %></h2>
    <div>
      <button class="btn btn-outline-info btn-sm" onclick="location.href='/ordenes'"><i class="bi bi-list-check"></i> Órdenes pendientes</button>
    </div>
  </div>

  <% if (locals.success) { %><div class="alert alert-success"><i class="bi bi-check-circle"></i> <%= success %></div><% } %>
  <% if (locals.error) { %><div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> <%= error %></div><% } %>

  <ul class="nav nav-tabs mb-3" id="altasTab" role="tablist">
    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#nuevoCliente"><i class="bi bi-person-plus"></i> Nuevo Cliente</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#nuevaOrden"><i class="bi bi-cart-plus"></i> Orden Rápida</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#pendientes"><i class="bi bi-clock-history"></i> Pendientes <span class="badge bg-warning text-dark ms-1"><%= ordenesPendientes ? ordenesPendientes.length : 0 %></span></button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#recientes"><i class="bi bi-clock-history"></i> Recientes</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#portabilidades"><i class="bi bi-arrow-left-right"></i> Portabilidades</button></li>
  </ul>

  <div class="tab-content">
    <!-- NUEVO CLIENTE - Wizard multi-paso -->
    <div class="tab-pane fade show active" id="nuevoCliente">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span><i class="bi bi-person-plus"></i> Asistente de alta</span>
          <div class="wizard-progress" id="wizardSteps">
            <div class="wiz-step completed" id="ws1">
              <div class="wiz-circle">1</div>
              <div class="wiz-label">Datos del cliente</div>
            </div>
            <div class="wiz-step pending" id="ws2">
              <div class="wiz-circle">2</div>
              <div class="wiz-label">Producto / Cobertura</div>
            </div>
            <div class="wiz-step pending" id="ws3">
              <div class="wiz-circle">3</div>
              <div class="wiz-label">Portabilidad / Config</div>
            </div>
            <div class="wiz-step pending" id="ws4">
              <div class="wiz-circle">4</div>
              <div class="wiz-label">Resumen / Confirmación</div>
            </div>
          </div>
        </div>
        <div class="card-body">

          <!-- STEP 1: DATOS DEL CLIENTE -->
          <div id="wizardStep1">
            <h5 class="mb-3"><i class="bi bi-person-vcard"></i> Datos del cliente</h5>
            <form id="formStep1">
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">Nombre *</label>
                  <input type="text" id="wNombre" class="form-control" required placeholder="Nombre" oninput="validarPaso1()">
                </div>
                <div class="col-md-6">
                  <label class="form-label">Apellidos</label>
                  <input type="text" id="wApellidos" class="form-control" placeholder="Apellidos">
                </div>
                <div class="col-md-4">
                  <label class="form-label">DNI / NIF *</label>
                  <input type="text" id="wDni" class="form-control" required placeholder="12345678Z" onblur="validarDNI(this)" oninput="validarPaso1()">
                  <small class="text-muted" id="wDniVal"></small>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Teléfono *</label>
                  <input type="text" id="wTelefono" class="form-control" required placeholder="612345678" oninput="validarPaso1()">
                </div>
                <div class="col-md-4">
                  <label class="form-label">Email *</label>
                  <input type="email" id="wEmail" class="form-control" placeholder="cliente@email.com" oninput="validarPaso1()">
                </div>
                <div class="col-md-6">
                  <label class="form-label">Dirección</label>
                  <input type="text" id="wDireccion" class="form-control" placeholder="Calle, número, piso">
                </div>
                <div class="col-md-3">
                  <label class="form-label">Ciudad</label>
                  <input type="text" id="wCiudad" class="form-control" value="Antequera">
                </div>
                <div class="col-md-3">
                  <label class="form-label">Código Postal</label>
                  <input type="text" id="wCp" class="form-control" value="29200">
                </div>
                <div class="col-md-4">
                  <label class="form-label">Tipo de cliente</label>
                  <select id="wCustomerType" class="form-select">
                    <option value="Residential">Particular (Residential)</option>
                    <option value="Freelance">Autónomo (Freelance)</option>
                    <option value="Society">Empresa (Society)</option>
                  </select>
                </div>
                <div class="col-md-8">
                  <label class="form-label">Método de pago</label>
                  <div class="pago-cards">
                    <div class="pago-card">
                      <input type="radio" name="wMetodoPago" value="IBAN" id="pagoIBAN" onchange="togglePago()">
                      <label for="pagoIBAN">
                        <i class="bi bi-bank"></i>
                        <span>IBAN (Domiciliación)</span>
                      </label>
                    </div>
                    <div class="pago-card">
                      <input type="radio" name="wMetodoPago" value="TARJETA" id="pagoTarjeta" onchange="togglePago()">
                      <label for="pagoTarjeta">
                        <i class="bi bi-credit-card"></i>
                        <span>Tarjeta</span>
                      </label>
                    </div>
                    <div class="pago-card">
                      <input type="radio" name="wMetodoPago" value="NINGUNO" id="pagoNinguno" onchange="togglePago()">
                      <label for="pagoNinguno">
                        <i class="bi bi-x-circle"></i>
                        <span>Ninguno (Pagaré después)</span>
                      </label>
                    </div>
                  </div>
                  <div class="pago-content-area mt-2">
                    <div id="pagoIBANContent" class="pago-detail" style="display:none;">
                      <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-bank"></i></span>
                        <input type="text" id="wIban" class="form-control" placeholder="ES00 0000 0000 0000 0000 0000" oninput="formatearIBAN(this)">
                      </div>
                      <small class="text-muted"><i class="bi bi-info-circle"></i> Se realizará un cargo de 0,50€ para verificar tu IBAN, reembolsado en la primera factura.</small>
                    </div>
                    <div id="pagoTarjetaContent" class="pago-detail" style="display:none;">
                      <p class="mb-2"><i class="bi bi-shield-check text-primary"></i> Serás redirigido a Stripe para configurar el pago con tarjeta</p>
                      <a href="https://paymentlinks.movilbro.com/b/00g7su6jafByayIfZ1" target="_blank" class="btn btn-primary btn-sm"><i class="bi bi-box-arrow-up-right"></i> Ir a Stripe</a>
                    </div>
                    <div id="pagoNingunoContent" class="pago-detail" style="display:none;">
                      <p class="text-muted mb-0"><i class="bi bi-info-circle"></i> Podrás configurar el método de pago más tarde desde tu área de cliente</p>
                    </div>
                  </div>
                </div>
              </div>
              <div class="mt-4 d-flex justify-content-between">
                <div></div>
                <button type="button" class="btn btn-primary btn-lg btn-wizard-next" id="btnStep1Next" onclick="goWizardStep2()"><i class="bi bi-arrow-right"></i> Siguiente: Producto</button>
              </div>
            </form>
          </div>

          <!-- STEP 2: SELECCIÓN DE PRODUCTO -->
          <div id="wizardStep2" style="display:none;">
            <h5 class="mb-3"><i class="bi bi-cart"></i> Selección de producto</h5>
            <form id="formStep2">
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">Tipo de contratación</label>
                  <select id="wTipoContratacion" class="form-select" onchange="toggleTipoContratacion()">
                    <option value="NUEVA_ALTA">Nueva Alta (nuevo número)</option>
                    <option value="PORTABILIDAD">Portabilidad (mantener mi número)</option>
                    <option value="CAMBIO_PRODUCTO">Cambio de Producto</option>
                    <option value="BAJA">Baja</option>
                  </select>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Familia / Categoría</label>
                  <select id="wFamilia" class="form-select" onchange="filtrarProductos()">
                    <option value="">Todas las categorías</option>
                    <% (familias || []).forEach(function(fam) { %>
                    <option value="<%= fam.name %>"><%= fam.name %></option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-12">
                  <label class="form-label">Producto / Tarifa *</label>
                  <select id="wProducto" class="form-select" required size="5" style="height:auto;min-height:140px;" onchange="onProductoChange()">
                    <% if (products && products.length > 0) { %>
                      <% (familias || []).forEach(function(fam) { %>
                        <% var isFiber = fam.name.toUpperCase().includes('FIBRA'); %>
                        <optgroup label="<%= fam.name %>" class="prod-group" data-family="<%= fam.name %>" data-fiber="<%= isFiber %>">
                          <% (fam.items || []).forEach(function(p) { %>
                            <option value="<%= p.id || p.productId %>" data-family="<%= fam.name %>" data-fiber="<%= isFiber %>" data-precio="<%= p.price || 0 %>"><%= p.productName || p.name %><%= p.price ? ' - ' + p.price + '€' : '' %></option>
                          <% }); %>
                        </optgroup>
                      <% }); %>
                    <% } else { %>
                      <option value="">No hay productos disponibles (configura API)</option>
                    <% } %>
                  </select>
                </div>
              </div>

              <!-- Coverage check section (for fiber) -->
              <div id="coverageSection" class="mt-3 p-3 border rounded bg-light" style="display:none;">
                <h6 class="mb-2"><i class="bi bi-geo-alt-fill text-primary"></i> Verificar cobertura de fibra</h6>
                <div class="row g-2">
                  <div class="col-md-8">
                    <input type="text" id="wCoverageDir" class="form-control" placeholder="Dirección de instalación (calle y número)">
                  </div>
                  <div class="col-md-4">
                    <button type="button" class="btn btn-primary w-100 fw-semibold" id="btnCheckCoverage" onclick="checkCoverage()">
                      <i class="bi bi-search"></i> Verificar cobertura
                    </button>
                  </div>
                </div>
                <div id="coverageResult" class="mt-2">
                  <div class="text-muted small"><i class="bi bi-info-circle"></i> Introduce la dirección completa para verificar la disponibilidad de fibra.</div>
                </div>
              </div>

              <div class="mt-4 d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary btn-lg btn-wizard-prev" onclick="goWizardStep1()"><i class="bi bi-arrow-left"></i> Volver</button>
                <button type="button" class="btn btn-primary btn-lg btn-wizard-next" id="btnStep2Next" onclick="goWizardStep3()"><i class="bi bi-arrow-right"></i> Siguiente</button>
              </div>
            </form>
          </div>

          <!-- STEP 3: PORTABILIDAD / CONFIGURACIÓN ADICIONAL -->
          <div id="wizardStep3" style="display:none;">
            <h5 class="mb-3"><i class="bi bi-gear"></i> Configuración adicional</h5>
            <form id="formStep3">
              <div id="portabilidadConfig" style="display:none;">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label">Número a portar *</label>
                    <input type="text" id="wLineaPortar" class="form-control" placeholder="612345678" oninput="validarPaso3()">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Operador actual (donante) *</label>
                    <select id="wDonante" class="form-select" onchange="validarPaso3()">
                      <option value="">Seleccionar operador...</option>
                      <% if (donantes && donantes.length > 0) { %>
                        <% donantes.forEach(function(d) { %>
                        <option value="<%= d.Code || d.code || d.id %>"><%= d.Name || d.name || d.Code || d.code %></option>
                        <% }); %>
                      <% } else { %>
                        <option value="1">Orange</option>
                        <option value="2">Movistar</option>
                        <option value="3">Vodafone</option>
                        <option value="4">Yoigo</option>
                        <option value="5">MásMóvil</option>
                        <option value="6">Pepephone</option>
                        <option value="7">Lowi</option>
                        <option value="8">Digi</option>
                      <% } %>
                    </select>
                  </div>
                </div>
              </div>
              <div id="nuevaAltaConfig">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label">Tipo de SIM</label>
                    <select id="wSimType" class="form-select">
                      <option value="fisica">SIM física</option>
                      <option value="esim">eSIM</option>
                    </select>
                  </div>
                  <div class="col-md-6" id="wIccGroup" style="display:none;">
                    <label class="form-label">ICC (código de la SIM)</label>
                    <input type="text" id="wIcc" class="form-control" placeholder="8934... (opcional)">
                    <small class="text-muted">Si no se indica, quedará pendiente de envío</small>
                  </div>
                </div>
              </div>
              <div class="mt-4 d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary btn-lg btn-wizard-prev" onclick="goWizardStep2()"><i class="bi bi-arrow-left"></i> Volver</button>
                <button type="button" class="btn btn-primary btn-lg btn-wizard-next" id="btnStep3Next" onclick="goWizardStep4()"><i class="bi bi-arrow-right"></i> Siguiente: Resumen</button>
              </div>
            </form>
          </div>

          <!-- STEP 4: RESUMEN Y ENVÍO -->
          <div id="wizardStep4" style="display:none;">
            <h5 class="mb-3"><i class="bi bi-file-text"></i> Resumen y confirmación</h5>
            <div class="row">
              <div class="col-md-6">
                <div class="card mb-3">
                  <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Datos del cliente</span>
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="goWizardStep1()"><i class="bi bi-pencil"></i></button>
                  </div>
                  <div class="card-body" id="resumenCliente"></div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="card mb-3">
                  <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Producto y pago</span>
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="goWizardStep2()"><i class="bi bi-pencil"></i></button>
                  </div>
                  <div class="card-body" id="resumenProducto"></div>
                </div>
              </div>
            </div>

            <div class="d-flex gap-2 mb-3">
              <button type="button" class="btn btn-outline-primary" onclick="verContrato()" id="btnVerContrato">
                <i class="bi bi-file-text"></i> Ver contrato
              </button>
            </div>

            <div class="alert alert-info">
              <i class="bi bi-info-circle"></i> Al crear el cliente se enviará un email con el enlace de verificación KYC (documentación y firma del contrato).
            </div>

            <div id="resumenChecks" class="mb-3">
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="checkDatos" checked disabled>
                <label class="form-check-label">Datos del cliente completos <i class="bi bi-check-circle text-success"></i></label>
              </div>
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="checkProducto" checked disabled>
                <label class="form-check-label">Producto seleccionado <i class="bi bi-check-circle text-success"></i></label>
              </div>
              <div class="form-check mb-2" id="checkPortaRow" style="display:none;">
                <input class="form-check-input" type="checkbox" id="checkPorta" checked disabled>
                <label class="form-check-label">Configuración de portabilidad <i class="bi bi-check-circle text-success"></i></label>
              </div>
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="checkPago">
                <label class="form-check-label">Acepto las condiciones del servicio y la verificación de identidad (KYC)</label>
              </div>
            </div>

            <div class="d-flex justify-content-between">
              <button type="button" class="btn btn-outline-secondary btn-lg btn-wizard-prev" onclick="goWizardStep3()"><i class="bi bi-arrow-left"></i> Volver</button>
              <button type="button" class="btn btn-success btn-lg" id="btnCrearCliente" onclick="crearClienteAvanzado()" disabled>
                <i class="bi bi-check-lg"></i> Crear cliente y enviar KYC
              </button>
            </div>
            <div id="submitStatus" class="mt-2"></div>
          </div>

        </div>
      </div>
    </div>

    <!-- ORDEN RÁPIDA (simplificada) -->
    <div class="tab-pane fade" id="nuevaOrden">
      <div class="card">
        <div class="card-header"><i class="bi bi-cart-plus"></i> Crear orden rápida (sin KYC)</div>
        <div class="card-body">
          <form method="POST" action="/altas/crear-orden">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Cliente *</label>
                <select name="client_id" class="form-select" required>
                  <option value="">Seleccionar cliente...</option>
                  <% localCustomers.forEach(function(c) { %>
                  <option value="<%= c.id %>"><%= c.nombre %> <%= c.apellidos || '' %> - <%= c.telefono %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Tipo de contratación</label>
                <select name="tipo" class="form-select">
                  <option value="NUEVA_ALTA">Nueva Alta</option>
                  <option value="PORTABILIDAD">Portabilidad</option>
                  <option value="CAMBIO_PRODUCTO">Cambio de Producto</option>
                  <option value="BAJA">Baja</option>
                </select>
              </div>
              <div class="col-12">
                <label class="form-label">Producto / Servicio *</label>
                <select name="producto_id" class="form-select" required>
                  <option value="">Seleccionar producto...</option>
                  <% if (familias.length > 0) { familias.forEach(function(fam) { %>
                  <optgroup label="<%= fam.name %>">
                    <% (fam.items || []).forEach(function(p) { %>
                    <option value="<%= p.id || p.productId %>"><%= p.productName || p.name %><%= p.price ? ' - ' + p.price + '€' : '' %></option>
                    <% }); %>
                  </optgroup>
                  <% }); } else { %>
                  <option value="">No hay productos disponibles (configura API)</option>
                  <% } %>
                </select>
              </div>
            </div>
            <div class="mt-4">
              <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-check-lg"></i> Crear Orden</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- PENDIENTES -->
    <div class="tab-pane fade" id="pendientes">
      <div class="card">
        <div class="card-header"><i class="bi bi-clock-history"></i> Órdenes pendientes de KYC / aprobación</div>
        <div class="card-body p-0">
          <table class="table table-hover mb-0" id="pendientesTable">
            <thead>
              <tr>
                <th>#</th>
                <th>Cliente</th>
                <th>Producto</th>
                <th>Estado</th>
                <th>Email enviado</th>
                <th>Documentos</th>
                <th>Contrato firmado</th>
                <th>Fecha</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% if (!ordenesPendientes || ordenesPendientes.length === 0) { %>
              <tr><td colspan="9" class="text-center text-muted py-4"><i class="bi bi-inbox"></i> No hay órdenes pendientes</td></tr>
              <% } else { ordenesPendientes.forEach(function(o) { 
                var dc = JSON.parse(o.datos_cliente || '{}');
                var dp = JSON.parse(o.datos_producto || '{}');
              %>
              <tr>
                <td><%= o.id %></td>
                <td><strong><%= dc.nombre || '' %> <%= dc.apellidos || '' %></strong><br><small class="text-muted"><%= dc.telefono || '' %></small></td>
                <td><%= dp.producto_id || '-' %></td>
                <td>
                  <% var est = (o.estado || '').toLowerCase(); %>
                  <span class="badge bg-<%= est === 'pendiente_kyc' ? 'warning' : est === 'pendiente_aprobacion' ? 'info' : est === 'completada' ? 'success' : 'secondary' %>">
                    <%= est === 'pendiente_kyc' ? 'Pendiente KYC' : est === 'pendiente_aprobacion' ? 'Pendiente aprobación' : est === 'completada' ? 'Completada' : est === 'cancelada' ? 'Cancelada' : est %>
                  </span>
                </td>
                <td class="text-center">
                  <% if (o.email_enviado) { %>
                    <span class="badge bg-success"><i class="bi bi-check-lg"></i> Enviado</span>
                    <% if (o.email_leido) { %>
                      <br><small class="text-info">Leído: Sí (<%= o.email_veces_leido || 1 %> veces)</small>
                    <% } else { %>
                      <br><small class="text-muted">No leído</small>
                    <% } %>
                  <% } else { %>
                    <span class="badge bg-secondary"><i class="bi bi-x-lg"></i> Pendiente</span>
                  <% } %>
                </td>
                <td class="text-center">
                  <% if (o.kyc_completado) { %>
                    <span class="badge bg-success"><i class="bi bi-check-lg"></i> Completo</span>
                  <% } else { %>
                    <% var docsSubidos = o.kyc_docs_subidos || 0; %>
                    <span class="badge bg-<%= docsSubidos > 0 ? 'primary' : 'secondary' %>">
                      <%= docsSubidos %>/2
                    </span>
                  <% } %>
                </td>
                <td class="text-center">
                  <% if (o.kyc_contrato_firmado) { %>
                    <span class="badge bg-success"><i class="bi bi-check-lg"></i> Firmado</span>
                  <% } else { %>
                    <span class="badge bg-secondary"><i class="bi bi-x-lg"></i> Pendiente</span>
                  <% } %>
                </td>
                <td class="small"><%= new Date(o.created_at).toLocaleDateString('es-ES') %></td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <% if (!o.kyc_completado) { %>
                    <button class="btn btn-outline-primary" onclick="enviarKYC(<%= o.id %>)" title="Enviar email KYC"><i class="bi bi-envelope"></i></button>
                    <% } %>
                    <button class="btn btn-outline-success" onclick="completarOrden(<%= o.id %>)" title="Completar y enviar a API"><i class="bi bi-check-lg"></i></button>
                    <button class="btn btn-outline-danger" onclick="cancelarOrden(<%= o.id %>)" title="Cancelar"><i class="bi bi-x-lg"></i></button>
                  </div>
                </td>
              </tr>
              <% }); } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- RECIENTES -->
    <div class="tab-pane fade" id="recientes">
      <div class="card">
        <div class="card-header"><i class="bi bi-clock-history"></i> Altas recientes (API Likes Telecom)</div>
        <div class="row g-3 mb-4 px-3 pt-3">
          <div class="col-md-12">
            <div class="card"><div class="card-body">
              <h6 class="card-title"><span style="font-size:1.2rem;">📈</span> Altas por Mes</h6>
