// Create client via API
async function crearClienteAvanzado() {
  var btn = document.getElementById('btnCrearCliente');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Creando cliente...';
  document.getElementById('submitStatus').innerHTML = '';

  var data = {
    nombre: document.getElementById('wNombre').value.trim(),
    apellidos: document.getElementById('wApellidos').value.trim(),
    email: document.getElementById('wEmail').value.trim(),
    telefono: document.getElementById('wTelefono').value.trim(),
    dni: document.getElementById('wDni').value.trim(),
    direccion: document.getElementById('wDireccion').value.trim(),
    ciudad: document.getElementById('wCiudad').value.trim(),
    codigo_postal: document.getElementById('wCp').value.trim(),
    customerType: document.getElementById('wCustomerType').value,
    metodo_pago: document.getElementById('wMetodoPago').value,
    iban: document.getElementById('wIban').value.trim(),
    producto_id: document.getElementById('wProducto').value,
    tipo_contratacion: document.getElementById('wTipoContratacion').value,
    donante_id: document.getElementById('wDonante').value,
    linea_portabilidad: document.getElementById('wLineaPortar').value.trim(),
    cobertura_id: ''
  };

  try {
    var response = await fetch('/altas/crear-cliente-avanzado', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    var result = await response.json();

    if (result.ok) {
      document.getElementById('submitStatus').innerHTML =
        '<div class="alert alert-success"><i class="bi bi-check-circle"></i> Cliente creado correctamente</div>' +
        '<div class="mt-2">' +
        '<button class="btn btn-primary" onclick="enviarKYCToken(\'' + result.orderToken + '\',' + result.clientId + ')"><i class="bi bi-envelope"></i> Enviar email KYC ahora</button> ' +
        '<button class="btn btn-outline-secondary" onclick="location.href=\'/altas\'"><i class="bi bi-arrow-left"></i> Volver</button>' +
        '</div>';
      btn.style.display = 'none';
    } else {
      throw new Error(result.error || 'Error desconocido');
    }
  } catch(e) {
    document.getElementById('submitStatus').innerHTML = '<div class="alert alert-danger">Error: ' + e.message + '</div>';
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-check-lg"></i> Crear cliente y enviar KYC';
  }
}

// KYC email functions
async function enviarKYC(ordenId) {
  if (!confirm('¿Enviar email de verificación KYC al cliente?')) return;
  try {
    var r = await fetch('/altas/enviar-kyc', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ orden_id: ordenId })
    });
    var res = await r.json();
    if (res.ok) { alert('Email enviado: ' + res.message); location.reload(); }
    else { alert('Error: ' + res.error); }
  } catch(e) { alert('Error de conexión'); }
}

async function enviarKYCToken(token, clientId) {
  // Get order ID from token
  try {
    var r = await fetch('/altas/orden/' + token);
    var res = await r.json();
    if (res.ok && res.orden) {
      await enviarKYC(res.orden.id);
    }
  } catch(e) { alert('Error'); }
}

async function completarOrden(ordenId) {
  if (!confirm('¿Enviar esta orden a Likes Telecom y completar el alta?')) return;
  try {
    var r = await fetch('/altas/completar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ orden_id: ordenId })
    });
    var res = await r.json();
    if (res.ok) { alert('Orden completada. ID API: ' + (res.apiOrderId || '')); location.reload(); }
    else { alert('Error: ' + res.error); }
  } catch(e) { alert('Error de conexión'); }
}

async function cancelarOrden(ordenId) {
  if (!confirm('¿Cancelar esta orden?')) return;
  try {
    var r = await fetch('/altas/cancelar-orden', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ orden_id: ordenId })
    });
    var res = await r.json();
    if (res.ok) { alert('Orden cancelada'); location.reload(); }
  } catch(e) { alert('Error de conexión'); }
}

// Charts (same as before)
function buildMonthlySeries(arr, dateField, label, color) {
  var minDate = null, maxDate = null;
  arr.forEach(function(x) {
    var dt = x[dateField]; if (!dt) return;
    var d = new Date(dt); if (isNaN(d.getTime())) return;
    if (!minDate || d < minDate) minDate = d;
    if (!maxDate || d > maxDate) maxDate = d;
  });
  if (!minDate) return { labels: [], series: [{ name: label, data: [] }] };
  var months = {};
  var startY = minDate.getFullYear(), startM = minDate.getMonth();
  var now = new Date();
  var totalMonths = (now.getFullYear() - startY) * 12 + (now.getMonth() - startM) + 1;
  for (var i = 0; i < totalMonths; i++) {
    var d = new Date(startY, startM + i, 1);
    var key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    months[key] = { label: d.toLocaleDateString('es-ES', { month: 'short', year: '2-digit' }), count: 0 };
  }
  arr.forEach(function(x) {
    var dt = x[dateField]; if (!dt) return;
    var d = new Date(dt); if (isNaN(d.getTime())) return;
    var key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    if (months[key]) months[key].count++;
  });
  var labels = [], data = [];
  Object.keys(months).forEach(function(k) {
    labels.push(months[k].label);
    data.push(months[k].count);
  });
  return { labels: labels, series: [{ name: label, data: data }] };
}

function renderAreaChart(elId, chartData, color) {
  var el = document.getElementById(elId);
  if (!el) return;
  var hasData = chartData.series[0].data.some(function(v) { return v > 0; });
  if (!hasData) { el.innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px;"></i>Sin datos disponibles</div>'; return; }
  var opt = {
    chart: { type: 'area', height: 221, toolbar: { show: false }, zoom: { enabled: false } },
    colors: [color],
    fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.3, opacityTo: 0.05 } },
    dataLabels: { enabled: false },
    stroke: { curve: 'smooth', width: 2 },
    xaxis: { categories: chartData.labels, labels: { style: { fontSize: '10px' } } },
    yaxis: { labels: { style: { fontSize: '10px' } }, show: true },
    grid: { borderColor: '#f0f0f0' },
    tooltip: { theme: 'light' }
  };
  opt.series = chartData.series;
  new ApexCharts(el, opt).render();
}

