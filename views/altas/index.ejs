    externoLink.href = '/kyc/contrato/' + token;
  } else {
    frame.src = '';
    frame.srcdoc = '<div style="text-align:center;padding:60px 20px;color:#6c757d;font-family:sans-serif;"><i class="bi bi-file-text" style="font-size:2.5rem;display:block;margin-bottom:16px;color:#0d6efd;"></i><h5>Contrato no disponible</h5><p style="color:#6c757d;">Complete la creación del cliente para visualizar el contrato.</p><small>El contrato se generará automáticamente tras el registro del cliente.</small></div>';
    externoLink.href = '#';
    externoLink.style.display = 'none';
  }
  var modal = new bootstrap.Modal(document.getElementById('contratoModal'));
  modal.show();
}

// Create client via API
async function crearClienteAvanzado() {
  var btn = document.getElementById('btnCrearCliente');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Creando cliente...';
  document.getElementById('submitStatus').innerHTML = '';

  var metodoPagoEl = document.querySelector('input[name="wMetodoPago"]:checked');
  var metodoPago = metodoPagoEl ? metodoPagoEl.value : '';

  var data = {
    nombre: document.getElementById('wNombre').value.trim(),
    apellidos: document.getElementById('wApellidos').value.trim(),
    email: document.getElementById('wEmail').value.trim(),
    telefono: document.getElementById('wTelefono').value.trim(),
    dni: document.getElementById('wDni').value.trim(),
    direccion: document.getElementById('wDireccion').value.trim(),
    ciudad: document.getElementById('wCiudad').value.trim(),
    codigo_postal: document.getElementById('wCp').value.trim(),
    customerType: document.getElementById('wCustomerType').value,
    metodo_pago: metodoPago,
    iban: document.getElementById('wIban').value.trim(),
    producto_id: document.getElementById('wProducto').value,
    tipo_contratacion: document.getElementById('wTipoContratacion').value,
    donante_id: document.getElementById('wDonante').value,
    linea_portabilidad: document.getElementById('wLineaPortar').value.trim(),
    cobertura_id: ''
  };

  try {
    var response = await fetch('/altas/crear-cliente-avanzado', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    var result = await response.json();

    if (result.ok) {
      document.getElementById('orderTokenHolder').value = result.orderToken || '';
      document.getElementById('submitStatus').innerHTML =
        '<div class="alert alert-success"><i class="bi bi-check-circle"></i> Cliente creado correctamente</div>' +
        '<div class="mt-2 d-flex gap-2">' +
        '<button class="btn btn-primary" onclick="enviarKYCToken(\'' + result.orderToken + '\',' + result.clientId + ')"><i class="bi bi-envelope"></i> Enviar email KYC ahora</button> ' +
        '<button class="btn btn-outline-primary" onclick="verContrato()"><i class="bi bi-file-text"></i> Ver contrato</button> ' +
        '<button class="btn btn-outline-secondary" onclick="location.href=\'/altas\'"><i class="bi bi-arrow-left"></i> Volver</button>' +
        '</div>';
      btn.style.display = 'none';
    } else {
      throw new Error(result.error || 'Error desconocido');
    }
  } catch(e) {
    document.getElementById('submitStatus').innerHTML = '<div class="alert alert-danger">Error: ' + e.message + '</div>';
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-check-lg"></i> Crear cliente y enviar KYC';
  }
}

// KYC email functions
async function enviarKYC(ordenId) {
  if (!confirm('¿Enviar email de verificación KYC al cliente?')) return;
  try {
    var r = await fetch('/altas/enviar-kyc', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ orden_id: ordenId })
    });
    var res = await r.json();
    if (res.ok) { alert('Email enviado: ' + res.message); location.reload(); }
    else { alert('Error: ' + res.error); }
  } catch(e) { alert('Error de conexión'); }
}

async function enviarKYCToken(token, clientId) {
  try {
    var r = await fetch('/altas/orden/' + token);
    var res = await r.json();
    if (res.ok && res.orden) {
      await enviarKYC(res.orden.id);
    }
  } catch(e) { alert('Error'); }
}

async function completarOrden(ordenId) {
  if (!confirm('¿Enviar esta orden a Likes Telecom y completar el alta?')) return;
  try {
    var r = await fetch('/altas/completar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ orden_id: ordenId })
    });
    var res = await r.json();
    if (res.ok) { alert('Orden completada. ID API: ' + (res.apiOrderId || '')); location.reload(); }
    else { alert('Error: ' + res.error); }
  } catch(e) { alert('Error de conexión'); }
}

async function cancelarOrden(ordenId) {
  if (!confirm('¿Cancelar esta orden?')) return;
  try {
    var r = await fetch('/altas/cancelar-orden', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ orden_id: ordenId })
    });
    var res = await r.json();
    if (res.ok) { alert('Orden cancelada'); location.reload(); }
  } catch(e) { alert('Error de conexión'); }
}

// Charts (same as before)
function buildMonthlySeries(arr, dateField, label, color) {
  var minDate = null, maxDate = null;
  arr.forEach(function(x) {
    var dt = x[dateField]; if (!dt) return;
    var d = new Date(dt); if (isNaN(d.getTime())) return;
    if (!minDate || d < minDate) minDate = d;
    if (!maxDate || d > maxDate) maxDate = d;
  });
  if (!minDate) return { labels: [], series: [{ name: label, data: [] }] };
  var months = {};
  var startY = minDate.getFullYear(), startM = minDate.getMonth();
  var now = new Date();
  var totalMonths = (now.getFullYear() - startY) * 12 + (now.getMonth() - startM) + 1;
  for (var i = 0; i < totalMonths; i++) {
    var d = new Date(startY, startM + i, 1);
    var key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    months[key] = { label: d.toLocaleDateString('es-ES', { month: 'short', year: '2-digit' }), count: 0 };
  }
  arr.forEach(function(x) {
    var dt = x[dateField]; if (!dt) return;
    var d = new Date(dt); if (isNaN(d.getTime())) return;
    var key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    if (months[key]) months[key].count++;
  });
  var labels = [], data = [];
  Object.keys(months).forEach(function(k) {
    labels.push(months[k].label);
    data.push(months[k].count);
  });
  return { labels: labels, series: [{ name: label, data: data }] };
}

function renderAreaChart(elId, chartData, color) {
  var el = document.getElementById(elId);
  if (!el) return;
  var hasData = chartData.series[0].data.some(function(v) { return v > 0; });
  if (!hasData) { el.innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px;"></i>Sin datos disponibles</div>'; return; }
  var opt = {
    chart: { type: 'area', height: 221, toolbar: { show: false }, zoom: { enabled: false } },
    colors: [color],
    fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.3, opacityTo: 0.05 } },
    dataLabels: { enabled: false },
    stroke: { curve: 'smooth', width: 2 },
    xaxis: { categories: chartData.labels, labels: { style: { fontSize: '10px' } } },
    yaxis: { labels: { style: { fontSize: '10px' } }, show: true },
    grid: { borderColor: '#f0f0f0' },
    tooltip: { theme: 'light' }
  };
  opt.series = chartData.series;
  new ApexCharts(el, opt).render();
}

var chartAltasRendered = false, chartPortaRendered = false;

function initAltasChart() {
  if (chartAltasRendered) return;
  chartAltasRendered = true;
  var a1 = <%- JSON.stringify(recientes) %>;
  renderAreaChart('chartAltasEstado', buildMonthlySeries(a1, 'fecha', 'Altas', '#0050A1'), '#0050A1');
}

function buildPortaSeries(arr) {
  var dateField = 'portabilityDate';
  if (arr.length > 0 && !arr[0].portabilityDate) dateField = 'created';
  var minDate = null;
  arr.forEach(function(x) {
    var dt = x[dateField]; if (!dt) return;
    var d = new Date(dt); if (isNaN(d.getTime())) return;
    if (!minDate || d < minDate) minDate = d;
  });
  if (!minDate) return { labels: [], series: [] };
  var months = {};
  var startY = minDate.getFullYear(), startM = minDate.getMonth();
  var now = new Date();
  var totalMonths = (now.getFullYear() - startY) * 12 + (now.getMonth() - startM) + 1;
  for (var i = 0; i < totalMonths; i++) {
    var d = new Date(startY, startM + i, 1);
    var key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    months[key] = { label: d.toLocaleDateString('es-ES', { month: 'short', year: '2-digit' }), completadas: 0, canceladas: 0, pendientes: 0, otras: 0 };
  }
  var totalCompletadas = 0, totalCanceladas = 0, totalPendientes = 0, totalOtras = 0;
  arr.forEach(function(x) {
    var dt = x[dateField]; if (!dt) return;
    var d = new Date(dt); if (isNaN(d.getTime())) return;
    var key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    if (!months[key]) return;
    var s = (x.status || '').toUpperCase();
    if (s === 'COMPLETED' || s === 'ACCEPTED') { months[key].completadas++; totalCompletadas++; }
    else if (s === 'CANCELED' || s === 'CANCELLED') { months[key].canceladas++; totalCanceladas++; }
    else if (s === 'PENDING') { months[key].pendientes++; totalPendientes++; }
    else { months[key].otras++; totalOtras++; }
  });
  var labels = [], compData = [], cancData = [], pendData = [];
  Object.keys(months).forEach(function(k) {
    labels.push(months[k].label);
    compData.push(months[k].completadas);
    cancData.push(months[k].canceladas);
    pendData.push(months[k].pendientes);
  });
  return {
    labels: labels,
    series: [
      { name: 'Completadas', data: compData },
      { name: 'Canceladas', data: cancData },
      { name: 'Pendientes', data: pendData }
    ],
    totals: { completadas: totalCompletadas, canceladas: totalCanceladas, pendientes: totalPendientes }
  };
}

function renderPortaChart(elId, chartData) {
  var el = document.getElementById(elId);
  if (!el) return;
  var hasData = chartData.series.some(function(s) { return s.data.some(function(v) { return v > 0; }); });
  if (!hasData) { el.innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px;"></i>Sin datos disponibles</div>'; return; }
  var opt = {
    chart: { type: 'area', height: 221, toolbar: { show: false }, zoom: { enabled: false } },
    colors: ['#28a745', '#dc3545', '#ffc107'],
    fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.25, opacityTo: 0.02 } },
    dataLabels: { enabled: false },
    stroke: { curve: 'smooth', width: 2 },
    xaxis: { categories: chartData.labels, labels: { style: { fontSize: '10px' } } },
    yaxis: { labels: { style: { fontSize: '10px' } }, show: true },
    grid: { borderColor: '#f0f0f0' },
    tooltip: { theme: 'light' },
    legend: { position: 'top', horizontalAlign: 'right', fontSize: '11px', markers: { width: 10, height: 10, radius: 4 } }
  };
  opt.series = chartData.series;
  new ApexCharts(el, opt).render();
  var detailEl = document.getElementById('portaDetail');
  if (detailEl && chartData.totals) {
    detailEl.innerHTML =
      '<span class="badge bg-success me-2">Completadas: ' + chartData.totals.completadas + '</span>' +
      '<span class="badge bg-danger me-2">Canceladas: ' + chartData.totals.canceladas + '</span>' +
      '<span class="badge bg-warning text-dark">Pendientes: ' + chartData.totals.pendientes + '</span>';
  }
}

function initPortaChart() {
  if (chartPortaRendered) return;
  chartPortaRendered = true;
  var a2 = <%- JSON.stringify(portabilidades) %>;
  renderPortaChart('chartPortaEstado', buildPortaSeries(a2));
}

// Watch for tab switches for charts
document.querySelectorAll('[data-bs-toggle="tab"]').forEach(function(tab) {
  tab.addEventListener('shown.bs.tab', function(e) {
    if (e.target.getAttribute('data-bs-target') === '#recientes') initAltasChart();
    if (e.target.getAttribute('data-bs-target') === '#portabilidades') initPortaChart();
  });
});

if (document.querySelector('#recientes.tab-pane.active')) initAltasChart();
if (document.querySelector('#portabilidades.tab-pane.active')) initPortaChart();

// Init: disable validation
document.addEventListener('DOMContentLoaded', function() {
  validarPaso1();
  validarPaso2();
  validarPaso3();
});
</script>

