<input type="hidden" id="orderTokenHolder" value="">

<script>
// Wizard state
var WIZARD = { step: 1 };

function actualizarProgressBar(step) {
  for (var i = 1; i <= 4; i++) {
    var el = document.getElementById('ws' + i);
    el.classList.remove('completed', 'active', 'pending');
    if (i < step) el.classList.add('completed');
    else if (i === step) el.classList.add('active');
    else el.classList.add('pending');
  }
}

function validarPaso1() {
  var nombre = document.getElementById('wNombre').value.trim();
  var telefono = document.getElementById('wTelefono').value.trim();
  var dni = document.getElementById('wDni').value.trim();
  var btn = document.getElementById('btnStep1Next');
  btn.disabled = !(nombre && telefono && dni);
}

function validarPaso2() {
  var producto = document.getElementById('wProducto').value;
  document.getElementById('btnStep2Next').disabled = !producto;
}

function validarPaso3() {
  var tipo = document.getElementById('wTipoContratacion').value;
  var btn = document.getElementById('btnStep3Next');
  if (tipo === 'PORTABILIDAD') {
    var linea = document.getElementById('wLineaPortar').value.trim();
    var donante = document.getElementById('wDonante').value;
    btn.disabled = !(linea && donante);
  } else {
    btn.disabled = false;
  }
}

function goWizardStep1() {
  document.getElementById('wizardStep1').style.display = 'block';
  document.getElementById('wizardStep2').style.display = 'none';
  document.getElementById('wizardStep3').style.display = 'none';
  document.getElementById('wizardStep4').style.display = 'none';
  actualizarProgressBar(1);
  WIZARD.step = 1;
  validarPaso1();
}

function goWizardStep2() {
  var nombre = document.getElementById('wNombre').value.trim();
  var telefono = document.getElementById('wTelefono').value.trim();
  var dni = document.getElementById('wDni').value.trim();
  if (!nombre) { alert('El nombre es obligatorio'); return; }
  if (!telefono) { alert('El teléfono es obligatorio'); return; }
  if (!dni) { alert('El DNI/NIF es obligatorio'); return; }

  document.getElementById('wizardStep1').style.display = 'none';
  document.getElementById('wizardStep2').style.display = 'block';
  document.getElementById('wizardStep3').style.display = 'none';
  document.getElementById('wizardStep4').style.display = 'none';
  actualizarProgressBar(2);
  WIZARD.step = 2;
  validarPaso2();
}

function goWizardStep3() {
  var producto = document.getElementById('wProducto').value;
  if (!producto) { alert('Selecciona un producto'); return; }

  document.getElementById('wizardStep1').style.display = 'none';
  document.getElementById('wizardStep2').style.display = 'none';
  document.getElementById('wizardStep3').style.display = 'block';
  document.getElementById('wizardStep4').style.display = 'none';
  actualizarProgressBar(3);
  WIZARD.step = 3;
  validarPaso3();
}

function goWizardStep4() {
  var nombre = document.getElementById('wNombre').value.trim();
  var apellidos = document.getElementById('wApellidos').value.trim();
  var dni = document.getElementById('wDni').value.trim();
  var telefono = document.getElementById('wTelefono').value.trim();
  var email = document.getElementById('wEmail').value.trim();
  var direccion = document.getElementById('wDireccion').value.trim();
  var ciudad = document.getElementById('wCiudad').value.trim();
  var cp = document.getElementById('wCp').value.trim();
  var customerType = document.getElementById('wCustomerType').value;
  var metodoPagoEl = document.querySelector('input[name="wMetodoPago"]:checked');
  var metodoPago = metodoPagoEl ? metodoPagoEl.value : '';
  var iban = document.getElementById('wIban').value.trim();
  var producto = document.getElementById('wProducto');
  var prodText = producto.options[producto.selectedIndex] ? producto.options[producto.selectedIndex].text : '';
  var tipoCont = document.getElementById('wTipoContratacion').value;
  var lineaPortar = document.getElementById('wLineaPortar').value.trim();
  var donante = document.getElementById('wDonante');
  var donanteText = donante.options[donante.selectedIndex] ? donante.options[donante.selectedIndex].text : '';

  document.getElementById('resumenCliente').innerHTML =
    '<p><strong>' + nombre + ' ' + apellidos + '</strong><br>' +
    'DNI: ' + dni + '<br>' +
    'Tel: ' + telefono + '<br>' +
    (email ? 'Email: ' + email + '<br>' : '') +
    (direccion ? direccion + ', ' + ciudad + ' ' + cp + '<br>' : '') +
    'Tipo: ' + customerType + '</p>' +
    '<p><strong>Método de pago:</strong> ' + (metodoPago ? ({
      'IBAN': 'IBAN (Domiciliación)',
      'TARJETA': 'Tarjeta',
      'NINGUNO': 'Ninguno (Pagaré después)'
    })[metodoPago] || metodoPago : 'No seleccionado') + (metodoPago === 'IBAN' && iban ? '<br>IBAN: ' + iban : '') + '</p>';

  document.getElementById('resumenProducto').innerHTML =
    '<p><strong>Producto:</strong> ' + prodText + '<br>' +
    '<strong>Tipo:</strong> ' + (tipoCont === 'PORTABILIDAD' ? 'Portabilidad' : tipoCont === 'NUEVA_ALTA' ? 'Nueva Alta' : tipoCont) +
    (tipoCont === 'PORTABILIDAD' && lineaPortar ? '<br><strong>Línea a portar:</strong> ' + lineaPortar : '') +
    (tipoCont === 'PORTABILIDAD' && donanteText ? '<br><strong>Operador donante:</strong> ' + donanteText : '') +
    '</p>';

  var portaRow = document.getElementById('checkPortaRow');
  if (tipoCont === 'PORTABILIDAD') {
    portaRow.style.display = '';
  } else {
    portaRow.style.display = 'none';
  }

  document.getElementById('wizardStep1').style.display = 'none';
  document.getElementById('wizardStep2').style.display = 'none';
  document.getElementById('wizardStep3').style.display = 'none';
  document.getElementById('wizardStep4').style.display = 'block';
  actualizarProgressBar(4);
  WIZARD.step = 4;

  document.getElementById('checkPago').addEventListener('change', function() {
    document.getElementById('btnCrearCliente').disabled = !this.checked;
  });
}

// Payment methods
function togglePago() {
  var metodoEl = document.querySelector('input[name="wMetodoPago"]:checked');
  var metodo = metodoEl ? metodoEl.value : '';
  document.getElementById('pagoIBANContent').style.display = metodo === 'IBAN' ? '' : 'none';
  document.getElementById('pagoTarjetaContent').style.display = metodo === 'TARJETA' ? '' : 'none';
  document.getElementById('pagoNingunoContent').style.display = metodo === 'NINGUNO' ? '' : 'none';
  document.querySelectorAll('.pago-card').forEach(function(c) {
    c.classList.toggle('active', c.querySelector('input') && c.querySelector('input').checked);
  });
}

function formatearIBAN(input) {
  var val = input.value.replace(/[^a-zA-Z0-9]/g, '').toUpperCase();
  var formatted = '';
  for (var i = 0; i < val.length && i < 24; i += 4) {
    formatted += val.substring(i, i + 4) + ' ';
  }
  input.value = formatted.trim();
}

function validarDNI(input) {
  var val = input.value.trim();
  var valEl = document.getElementById('wDniVal');
  if (val.length < 5) { valEl.textContent = ''; return; }
  var dniRegex = /^[0-9]{8}[A-Z]$/;
  var nieRegex = /^[XYZ][0-9]{7}[A-Z]$/;
  if (dniRegex.test(val) || nieRegex.test(val)) {
    valEl.innerHTML = '<span class="text-success"><i class="bi bi-check-circle"></i> Formato correcto</span>';
  } else {
    valEl.innerHTML = '<span class="text-warning"><i class="bi bi-exclamation-triangle"></i> Formato incorrecto (ej: 12345678Z)</span>';
  }
}

// Product filtering
function filtrarProductos() {
  var familia = document.getElementById('wFamilia').value;
  document.querySelectorAll('.prod-group').forEach(function(g) {
    g.style.display = (!familia || g.dataset.family === familia) ? '' : 'none';
  });
}

function toggleTipoContratacion() {
  var tipo = document.getElementById('wTipoContratacion').value;
  document.getElementById('portabilidadConfig').style.display = tipo === 'PORTABILIDAD' ? '' : 'none';
  document.getElementById('nuevaAltaConfig').style.display = tipo === 'NUEVA_ALTA' ? '' : 'none';
  validarPaso3();
}

// Product change - show coverage for fiber
function onProductoChange() {
  var select = document.getElementById('wProducto');
  var opt = select.options[select.selectedIndex];
  var isFiber = opt ? (opt.getAttribute('data-fiber') === 'true' || (opt.parentElement && opt.parentElement.getAttribute('data-fiber') === 'true')) : false;
  document.getElementById('coverageSection').style.display = isFiber ? '' : 'none';
  if (!isFiber) {
    document.getElementById('coverageResult').innerHTML = '<div class="text-muted small"><i class="bi bi-info-circle"></i> Introduce la dirección completa para verificar la disponibilidad de fibra.</div>';
  }
  validarPaso2();
}

// Coverage check
function checkCoverage() {
  var dir = document.getElementById('wCoverageDir').value.trim();
  if (!dir) { alert('Introduce una dirección'); return; }
  var resultEl = document.getElementById('coverageResult');
  var btn = document.getElementById('btnCheckCoverage');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Verificando...';
  resultEl.innerHTML = '<div class="text-center py-3"><span class="spinner-border text-primary spinner-border-sm"></span> <span class="text-muted">Consultando cobertura...</span></div>';

  fetch('/cobertura/address?q=' + encodeURIComponent(dir))
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data && data.addresses && data.addresses.length > 0) {
        var addr = data.addresses[0];
        resultEl.innerHTML =
          '<div class="alert alert-success mb-0 d-flex align-items-center gap-2"><i class="bi bi-check-circle-fill fs-5"></i> <span><strong>Cobertura disponible</strong><br><small>' + (addr.fullAddress || addr.address || addr.name || 'Dirección encontrada') + '</small></span></div>';
      } else {
        resultEl.innerHTML = '<div class="alert alert-danger mb-0 d-flex align-items-center gap-2"><i class="bi bi-x-circle-fill fs-5"></i> <span><strong>Sin cobertura</strong><br><small>No hay cobertura de fibra disponible en esta dirección</small></span></div>';
      }
    })
    .catch(function(e) {
      resultEl.innerHTML = '<div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle"></i> Error al verificar. Introduce una dirección más concreta.</div>';
    })
    .finally(function() {
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-search"></i> Verificar cobertura';
    });
}

// Update sim type switch
document.getElementById('wSimType').addEventListener('change', function() {
  document.getElementById('wIccGroup').style.display = this.value === 'fisica' ? '' : 'none';
});

// Contract preview modal
function verContrato() {
  var frame = document.getElementById('contratoIframe');
  var token = document.getElementById('orderTokenHolder').value;
  var externoLink = document.getElementById('contratoAbrirExterno');
  if (token) {
