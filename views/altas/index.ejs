<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-plus"></i> <%= ui.moduleName.altas %></h2>
  </div>

  <% if (success) { %><div class="alert alert-success"><i class="bi bi-check-circle"></i> <%= success %></div><% } %>
  <% if (error) { %><div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> <%= error %></div><% } %>

  <ul class="nav nav-tabs mb-3" id="altasTab" role="tablist">
    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#nuevoCliente"><i class="bi bi-person-plus"></i> Nuevo Cliente</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#nuevaOrden"><i class="bi bi-cart-plus"></i> Nueva Orden</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#recientes"><i class="bi bi-clock-history"></i> Recientes</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#portabilidades"><i class="bi bi-arrow-left-right"></i> Portabilidades</button></li>
  </ul>

  <div class="tab-content">
    <!-- NUEVO CLIENTE -->
    <div class="tab-pane fade show active" id="nuevoCliente">
      <div class="card">
        <div class="card-header"><i class="bi bi-person-plus"></i> Dar de alta un nuevo cliente</div>
        <div class="card-body">
          <form method="POST" action="/altas/crear-cliente">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Nombre *</label>
                <input type="text" name="nombre" class="form-control" required>
              </div>
              <div class="col-md-6">
                <label class="form-label">Apellidos</label>
                <input type="text" name="apellidos" class="form-control">
              </div>
              <div class="col-md-6">
                <label class="form-label">Telefono *</label>
                <input type="text" name="telefono" class="form-control" required placeholder="Ej: 612345678">
              </div>
              <div class="col-md-6">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" placeholder="cliente@email.com">
              </div>
              <div class="col-md-4">
                <label class="form-label">DNI / NIF</label>
                <input type="text" name="dni" class="form-control" placeholder="12345678Z">
              </div>
              <div class="col-md-8">
                <label class="form-label">Direccion</label>
                <input type="text" name="direccion" class="form-control" placeholder="Calle, numero, piso">
              </div>
              <div class="col-md-6">
                <label class="form-label">Ciudad</label>
                <input type="text" name="ciudad" class="form-control" value="Antequera">
              </div>
              <div class="col-md-6">
                <label class="form-label">Codigo Postal</label>
                <input type="text" name="codigo_postal" class="form-control" value="29200">
              </div>
            </div>
            <div class="mt-4">
              <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-check-lg"></i> Dar de Alta</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- NUEVA ORDEN -->
    <div class="tab-pane fade" id="nuevaOrden">
      <div class="card">
        <div class="card-header"><i class="bi bi-cart-plus"></i> Crear nueva orden / contratacion</div>
        <div class="card-body">
          <form method="POST" action="/altas/crear-orden">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Cliente *</label>
                <select name="client_id" class="form-select" required>
                  <option value="">Seleccionar cliente...</option>
                  <% localCustomers.forEach(c => { %>
                  <option value="<%= c.id %>"><%= c.nombre %> <%= c.apellidos || '' %> - <%= c.telefono %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Tipo de contratacion</label>
                <select name="tipo" class="form-select">
                  <option value="NUEVA_ALTA">Nueva Alta</option>
                  <option value="PORTABILIDAD">Portabilidad</option>
                  <option value="CAMBIO_PRODUCTO">Cambio de Producto</option>
                  <option value="BAJA">Baja</option>
                </select>
              </div>
              <div class="col-12">
                <label class="form-label">Producto / Servicio *</label>
                <select name="producto_id" class="form-select" required>
                  <option value="">Seleccionar producto...</option>
                  <% if (familias.length > 0) { familias.forEach(fam => { %>
                  <optgroup label="<%= fam.name %>">
                    <% (fam.items || []).forEach(p => { %>
                    <option value="<%= p.id || p.productId %>"><%= p.productName || p.name %> <%= p.price ? '- ' + p.price + '€' : '' %></option>
                    <% }) %>
                  </optgroup>
                  <% }); } else { %>
                  <option value="">No hay productos disponibles (configura API)</option>
                  <% } %>
                </select>
              </div>
            </div>
            <div class="mt-4">
              <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-check-lg"></i> Crear Orden</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- RECIENTES -->
    <div class="tab-pane fade" id="recientes">
      <div class="card">
        <div class="card-header"><i class="bi bi-clock-history"></i> Altas recientes (API Likes Telecom)</div>
        <div class="row g-3 mb-4">
          <div class="col-md-12">
            <div class="card"><div class="card-body">
              <h6 class="card-title"><span style="font-size:1.2rem;">📈</span> Altas por Mes</h6>
              <div id="chartAltasEstado"></div>
            </div></div>
          </div>
        </div>
        <div class="card-body p-0">
          <table class="table table-hover mb-0">
            <thead><tr><th>Nombre</th><th>Telefono</th><th>Tipo</th><th>Estado</th><th>Fecha</th><th></th></tr></thead>
            <tbody>
              <% if (recientes.length === 0) { %>
              <tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-inbox"></i> Sin datos</td></tr>
              <% } else { recientes.forEach(a => { %>
              <tr>
                <td><strong><%= a.nombre %></strong></td>
                <td><%= a.telefono %></td>
                <td><span class="badge bg-info"><%= a.tipo %></span></td>
                <% var aStatus = (a.estado || '').toUpperCase(); %>
                <td><span class="badge bg-<%= aStatus === 'ACTIVE' || aStatus === 'CREATED' ? 'success' : aStatus === 'ERROR' ? 'danger' : 'warning' %>"><%= aStatus === 'ACTIVE' ? 'Activo' : aStatus === 'CREATED' ? 'Creado' : aStatus === 'ERROR' ? 'Error' : a.estado %></span></td>
                <td class="small"><%= new Date(a.fecha).toLocaleDateString('es-ES', { day:'2-digit', month:'short', year:'numeric' }) %></td>
                <td><a href="https://wa.me/<%= a.telefono.replace(/[^\d]/g, '') %>" target="_blank" class="btn btn-sm btn-outline-success"><i class="bi bi-whatsapp"></i></a></td>
              </tr>
              <% }); } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- PORTABILIDADES -->
    <div class="tab-pane fade" id="portabilidades">
      <div class="card">
        <div class="card-header"><i class="bi bi-arrow-left-right"></i> Portabilidades registradas</div>
        <div class="row g-3 mb-4">
          <div class="col-md-12">
            <div class="card"><div class="card-body">
              <h6 class="card-title"><span style="font-size:1.2rem;">📈</span> Portabilidades por Mes</h6>
              <div id="chartPortaEstado"></div>
              <div id="portaDetail" class="mt-2 text-center"></div>
            </div></div>
          </div>
        </div>
        <div class="card-body p-0">
          <table class="table table-hover mb-0">
            <thead><tr><th>Cliente</th><th>Telefono</th><th>Donante</th><th>Estado</th><th>Fecha</th></tr></thead>
            <tbody>
              <% if (portabilidades.length === 0) { %>
              <tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-inbox"></i> Sin datos</td></tr>
              <% } else { portabilidades.forEach(p => { %>
              <tr>
                <td><%= p.customerName || p.name || 'N/A' %></td>
                <td><%= p.phoneNumber || p.phone || '-' %></td>
                <td><%= p.donorOperator || '-' %></td>
                <% var pStatus = (p.status || 'PENDING').toUpperCase(); %>
                <td><span class="badge bg-<%= pStatus === 'COMPLETED' || pStatus === 'ACCEPTED' ? 'success' : pStatus === 'PENDING' ? 'warning' : pStatus === 'CANCELED' || pStatus === 'CANCELLED' ? 'danger' : 'success' %>"><%= pStatus === 'COMPLETED' || pStatus === 'ACCEPTED' ? 'Completada' : pStatus === 'PENDING' ? 'Pendiente' : pStatus === 'CANCELED' || pStatus === 'CANCELLED' ? 'Cancelada' : pStatus %></span></td>
                <td class="small"><%= p.portabilityDate || p.created ? new Date(p.portabilityDate || p.created).toLocaleDateString('es-ES') : '-' %></td>
              </tr>
              <% }); } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
<script>
function buildMonthlySeries(arr, dateField, label, color) {
  // Find min and max date from data
  var minDate = null, maxDate = null;
  arr.forEach(function(x) {
    var dt = x[dateField];
    if (!dt) return;
    var d = new Date(dt);
    if (isNaN(d.getTime())) return;
    if (!minDate || d < minDate) minDate = d;
    if (!maxDate || d > maxDate) maxDate = d;
  });
  if (!minDate) return { labels: [], series: [{ name: label, data: [] }] };
  // Build months from min to max
  var months = {};
  var startY = minDate.getFullYear(), startM = minDate.getMonth();
  var now = new Date();
  var totalMonths = (now.getFullYear() - startY) * 12 + (now.getMonth() - startM) + 1;
  for (var i = 0; i < totalMonths; i++) {
    var d = new Date(startY, startM + i, 1);
    var key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    months[key] = { label: d.toLocaleDateString('es-ES', { month: 'short', year: '2-digit' }), count: 0 };
  }
  arr.forEach(function(x) {
    var dt = x[dateField];
    if (!dt) return;
    var d = new Date(dt);
    if (isNaN(d.getTime())) return;
    var key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    if (months[key]) months[key].count++;
  });
  var labels = [], data = [];
  Object.keys(months).forEach(function(k) {
    labels.push(months[k].label);
    data.push(months[k].count);
  });
  return { labels: labels, series: [{ name: label, data: data }] };
}

function renderAreaChart(elId, chartData, color) {
  var el = document.getElementById(elId);
  if (!el) return;
  var hasData = chartData.series[0].data.some(function(v) { return v > 0; });
  if (!hasData) { el.innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px;"></i>Sin datos disponibles</div>'; return; }
  var opt = {
    chart: { type: 'area', height: 221, toolbar: { show: false }, zoom: { enabled: false } },
    colors: [color],
    fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.3, opacityTo: 0.05 } },
    dataLabels: { enabled: false },
    stroke: { curve: 'smooth', width: 2 },
    xaxis: { categories: chartData.labels, labels: { style: { fontSize: '10px' } } },
    yaxis: { labels: { style: { fontSize: '10px' } }, show: true },
    grid: { borderColor: '#f0f0f0' },
    tooltip: { theme: 'light' }
  };
  opt.series = chartData.series;
  new ApexCharts(el, opt).render();
}

var chartAltasRendered = false, chartPortaRendered = false;

function initAltasChart() {
  if (chartAltasRendered) return;
  chartAltasRendered = true;
  var a1 = <%- JSON.stringify(recientes) %>;
  renderAreaChart('chartAltasEstado', buildMonthlySeries(a1, 'fecha', 'Altas', '#0050A1'), '#0050A1');
}

function buildPortaSeries(arr) {
  var dateField = 'portabilityDate';
  if (arr.length > 0 && !arr[0].portabilityDate) dateField = 'created';
  var minDate = null;
  arr.forEach(function(x) {
    var dt = x[dateField]; if (!dt) return;
    var d = new Date(dt); if (isNaN(d.getTime())) return;
    if (!minDate || d < minDate) minDate = d;
  });
  if (!minDate) return { labels: [], series: [] };
  var months = {};
  var startY = minDate.getFullYear(), startM = minDate.getMonth();
  var now = new Date();
  var totalMonths = (now.getFullYear() - startY) * 12 + (now.getMonth() - startM) + 1;
  for (var i = 0; i < totalMonths; i++) {
    var d = new Date(startY, startM + i, 1);
    var key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    months[key] = { label: d.toLocaleDateString('es-ES', { month: 'short', year: '2-digit' }), completadas: 0, canceladas: 0, pendientes: 0, otras: 0 };
  }
  var totalCompletadas = 0, totalCanceladas = 0, totalPendientes = 0, totalOtras = 0;
  arr.forEach(function(x) {
    var dt = x[dateField]; if (!dt) return;
    var d = new Date(dt); if (isNaN(d.getTime())) return;
    var key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    if (!months[key]) return;
    var s = (x.status || '').toUpperCase();
    if (s === 'COMPLETED' || s === 'ACCEPTED') { months[key].completadas++; totalCompletadas++; }
    else if (s === 'CANCELED' || s === 'CANCELLED') { months[key].canceladas++; totalCanceladas++; }
    else if (s === 'PENDING') { months[key].pendientes++; totalPendientes++; }
    else { months[key].otras++; totalOtras++; }
  });
  var labels = [], compData = [], cancData = [], pendData = [];
  Object.keys(months).forEach(function(k) {
    labels.push(months[k].label);
    compData.push(months[k].completadas);
    cancData.push(months[k].canceladas);
    pendData.push(months[k].pendientes);
  });
  return {
    labels: labels,
    series: [
      { name: 'Completadas', data: compData },
      { name: 'Canceladas', data: cancData },
      { name: 'Pendientes', data: pendData }
    ],
    totals: { completadas: totalCompletadas, canceladas: totalCanceladas, pendientes: totalPendientes }
  };
}

function renderPortaChart(elId, chartData) {
  var el = document.getElementById(elId);
  if (!el) return;
  var hasData = chartData.series.some(function(s) { return s.data.some(function(v) { return v > 0; }); });
  if (!hasData) { el.innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px;"></i>Sin datos disponibles</div>'; return; }
  var opt = {
    chart: { type: 'area', height: 221, toolbar: { show: false }, zoom: { enabled: false } },
    colors: ['#28a745', '#dc3545', '#ffc107'],
    fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.25, opacityTo: 0.02 } },
    dataLabels: { enabled: false },
    stroke: { curve: 'smooth', width: 2 },
    xaxis: { categories: chartData.labels, labels: { style: { fontSize: '10px' } } },
    yaxis: { labels: { style: { fontSize: '10px' } }, show: true },
    grid: { borderColor: '#f0f0f0' },
    tooltip: { theme: 'light' },
    legend: { position: 'top', horizontalAlign: 'right', fontSize: '11px', markers: { width: 10, height: 10, radius: 4 } }
  };
  opt.series = chartData.series;
  new ApexCharts(el, opt).render();
  // Render totals below
  var detailEl = document.getElementById('portaDetail');
  if (detailEl && chartData.totals) {
    detailEl.innerHTML =
      '<span class="badge bg-success me-2">Completadas: ' + chartData.totals.completadas + '</span>' +
      '<span class="badge bg-danger me-2">Canceladas: ' + chartData.totals.canceladas + '</span>' +
      '<span class="badge bg-warning text-dark">Pendientes: ' + chartData.totals.pendientes + '</span>';
  }
}

function initPortaChart() {
  if (chartPortaRendered) return;
  chartPortaRendered = true;
  var a2 = <%- JSON.stringify(portabilidades) %>;
  renderPortaChart('chartPortaEstado', buildPortaSeries(a2));
}

// Init charts when their tab is shown (handles hidden container issue)
document.querySelectorAll('[data-bs-toggle="tab"]').forEach(function(tab) {
  tab.addEventListener('shown.bs.tab', function(e) {
    if (e.target.getAttribute('data-bs-target') === '#recientes') initAltasChart();
    if (e.target.getAttribute('data-bs-target') === '#portabilidades') initPortaChart();
  });
});

// If tab is already active on page load
if (document.querySelector('#recientes.tab-pane.active')) initAltasChart();
if (document.querySelector('#portabilidades.tab-pane.active')) initPortaChart();
</script>
</section>
