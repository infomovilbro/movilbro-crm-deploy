function buildPortaSeries(arr) {
  var dateField = 'portabilityDate';
  if (arr.length > 0 && !arr[0].portabilityDate) dateField = 'created';
  var minDate = null;
  arr.forEach(function(x) {
    var dt = x[dateField]; if (!dt) return;
    var d = new Date(dt); if (isNaN(d.getTime())) return;
    if (!minDate || d < minDate) minDate = d;
  });
  if (!minDate) return { labels: [], series: [] };
  var months = {};
  var startY = minDate.getFullYear(), startM = minDate.getMonth();
  var now = new Date();
  var totalMonths = (now.getFullYear() - startY) * 12 + (now.getMonth() - startM) + 1;
  for (var i = 0; i < totalMonths; i++) {
    var d = new Date(startY, startM + i, 1);
    var key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    months[key] = { label: d.toLocaleDateString('es-ES', { month: 'short', year: '2-digit' }), completadas: 0, canceladas: 0, pendientes: 0, otras: 0 };
  }
  var totalCompletadas = 0, totalCanceladas = 0, totalPendientes = 0, totalOtras = 0;
  arr.forEach(function(x) {
    var dt = x[dateField]; if (!dt) return;
    var d = new Date(dt); if (isNaN(d.getTime())) return;
    var key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    if (!months[key]) return;
    var s = (x.status || '').toUpperCase();
    if (s === 'COMPLETED' || s === 'ACCEPTED') { months[key].completadas++; totalCompletadas++; }
    else if (s === 'CANCELED' || s === 'CANCELLED') { months[key].canceladas++; totalCanceladas++; }
    else if (s === 'PENDING') { months[key].pendientes++; totalPendientes++; }
    else { months[key].otras++; totalOtras++; }
  });
  var labels = [], compData = [], cancData = [], pendData = [];
  Object.keys(months).forEach(function(k) {
    labels.push(months[k].label);
    compData.push(months[k].completadas);
    cancData.push(months[k].canceladas);
    pendData.push(months[k].pendientes);
  });
  return {
    labels: labels,
    series: [
      { name: 'Completadas', data: compData },
      { name: 'Canceladas', data: cancData },
      { name: 'Pendientes', data: pendData }
    ],
    totals: { completadas: totalCompletadas, canceladas: totalCanceladas, pendientes: totalPendientes }
  };
}

function renderPortaChart(elId, chartData) {
  var el = document.getElementById(elId);
  if (!el) return;
  var hasData = chartData.series.some(function(s) { return s.data.some(function(v) { return v > 0; }); });
  if (!hasData) { el.innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px;"></i>Sin datos disponibles</div>'; return; }
  var opt = {
    chart: { type: 'area', height: 221, toolbar: { show: false }, zoom: { enabled: false } },
    colors: ['#28a745', '#dc3545', '#ffc107'],
    fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.25, opacityTo: 0.02 } },
    dataLabels: { enabled: false },
    stroke: { curve: 'smooth', width: 2 },
    xaxis: { categories: chartData.labels, labels: { style: { fontSize: '10px' } } },
    yaxis: { labels: { style: { fontSize: '10px' } }, show: true },
    grid: { borderColor: '#f0f0f0' },
    tooltip: { theme: 'light' },
    legend: { position: 'top', horizontalAlign: 'right', fontSize: '11px', markers: { width: 10, height: 10, radius: 4 } }
  };
  opt.series = chartData.series;
  new ApexCharts(el, opt).render();
  var detailEl = document.getElementById('portaDetail');
  if (detailEl && chartData.totals) {
    detailEl.innerHTML =
      '<span class="badge bg-success me-2">Completadas: ' + chartData.totals.completadas + '</span>' +
      '<span class="badge bg-danger me-2">Canceladas: ' + chartData.totals.canceladas + '</span>' +
      '<span class="badge bg-warning text-dark">Pendientes: ' + chartData.totals.pendientes + '</span>';
  }
}

