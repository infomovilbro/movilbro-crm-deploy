<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title><%= title %></title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<style>
body { background: #f5f7fa; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; min-height: 100vh; }
.kyc-card { max-width: 640px; margin: 40px auto; background: #fff; border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); overflow: hidden; }
.kyc-header { background: linear-gradient(135deg, #0050A1, #003d7a); color: #fff; padding: 32px; text-align: center; }
.kyc-header h1 { font-size: 22px; margin: 0; font-weight: 600; }
.kyc-header p { opacity: 0.85; margin: 8px 0 0; font-size: 14px; }
.kyc-body { padding: 32px; }
.kyc-step { display: none; }
.kyc-step.active { display: block; }

/* Animations */
.kyc-step { animation: none; }
.kyc-step.active { animation: fadeIn 0.4s ease-out; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
@keyframes pulse { 0%, 100% { opacity: 0.6; } 50% { opacity: 1; } }
@keyframes slideDown { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
@keyframes popIn { 0% { transform: scale(0); opacity: 0; } 70% { transform: scale(1.15); } 100% { transform: scale(1); opacity: 1; } }
@keyframes checkmark { 0% { stroke-dashoffset: 100; } 100% { stroke-dashoffset: 0; } }
.animate-slide { animation: slideDown 0.3s ease-out; }
.animate-pop { animation: popIn 0.5s ease-out; }

/* Progress bar */
.progress-steps { margin-bottom: 20px; }
.progress-steps .progress { height: 6px; border-radius: 3px; margin-bottom: 8px; overflow: hidden; background: #e9ecef; }
.progress-steps .progress-bar { background: #0050A1; transition: width 0.6s ease; }
.progress-labels { display: flex; justify-content: space-between; font-size: 12px; color: #6c757d; }
.progress-labels .label { transition: color 0.3s; }
.progress-labels .label.active { color: #0050A1; font-weight: 600; }
.progress-labels .label.done { color: #28a745; font-weight: 600; }

.step-indicator { display: flex; justify-content: center; gap: 12px; margin-bottom: 24px; }
.step-dot { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px; background: #e9ecef; color: #6c757d; transition: all 0.3s ease; position: relative; }
.step-dot.active { background: #0050A1; color: #fff; transform: scale(1.1); }
.step-dot.done { background: #28a745; color: #fff; }
.step-dot.done::after { content: '\2713'; font-size: 18px; }
.step-dot.done span { display: none; }
.step-dot .step-label { position: absolute; top: 44px; font-size: 11px; color: #6c757d; width: 80px; text-align: center; white-space: nowrap; }

/* Camera box with guide overlay */
.camera-box { width: 100%; max-width: 480px; margin: 0 auto; border: 2px dashed #dee2e6; border-radius: 12px; overflow: hidden; position: relative; background: #000; aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; }
.camera-box video { width: 100%; height: 100%; object-fit: cover; display: block; }
.camera-box .placeholder { color: #fff; text-align: center; padding: 20px; }
.camera-box .placeholder i { font-size: 48px; opacity: 0.5; }
.camera-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none; }
.camera-overlay canvas { width: 100%; height: 100%; }

/* Manual upload fallback */
.upload-manual-area { border: 2px dashed #dee2e6; border-radius: 12px; padding: 24px; text-align: center; cursor: pointer; transition: all 0.3s ease; }
.upload-manual-area:hover { border-color: #0050A1; background: #f0f4ff; transform: translateY(-1px); }
.upload-manual-area input[type="file"] { display: none; }
.upload-fallback-msg { background: #fff3cd; border: 1px solid #ffc107; border-radius: 8px; padding: 12px 16px; margin-bottom: 12px; font-size: 14px; color: #856404; display: none; align-items: center; gap: 8px; }
.upload-fallback-msg i { font-size: 18px; }

.capture-actions { display: flex; gap: 8px; justify-content: center; margin-top: 12px; flex-wrap: wrap; }
.preview-img { max-width: 100%; border-radius: 8px; border: 2px solid #dee2e6; transition: border-color 0.3s; }
.preview-img.preview-valid { border-color: #28a745; }
.preview-img.preview-invalid { border-color: #dc3545; }
canvas.signature-pad { width: 100%; height: 180px; border: 2px solid #dee2e6; border-radius: 8px; cursor: crosshair; touch-action: none; }
.quality-badge { position: absolute; top: 8px; right: 8px; padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; z-index: 10; }
.quality-badge.good { background: rgba(40,167,69,0.9); color: #fff; }
.quality-badge.bad { background: rgba(220,53,69,0.9); color: #fff; }
.status-icon { font-size: 64px; display: block; margin-bottom: 16px; }
.tracking-pixel { position: absolute; width: 1px; height: 1px; opacity: 0; }

/* Status messages */
.status-msg { display: flex; align-items: center; gap: 8px; padding: 10px 14px; border-radius: 8px; font-size: 14px; margin-top: 8px; animation: slideDown 0.3s ease-out; }
.status-msg.success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
.status-msg.error { background: #d1ecf1; color: #0c5460; border: 1px solid #bee5eb; }
.status-msg.error i { color: #17a2b8; }
.status-msg.success i { color: #28a745; }
.status-msg .status-icon-big { font-size: 20px; flex-shrink: 0; }
.status-msg .status-text { flex: 1; }
.status-msg .status-sub { font-size: 12px; opacity: 0.8; display: block; }

/* Quality error alerts */
.quality-error { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; border-radius: 8px; padding: 8px 12px; font-size: 13px; margin-top: 6px; display: none; animation: slideDown 0.3s ease-out; }
.quality-error i { margin-right: 6px; }

/* Success screen */
.success-screen { text-align: center; padding: 40px 20px; }
.success-screen .checkmark-circle { width: 96px; height: 96px; border-radius: 50%; background: #28a745; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; animation: popIn 0.6s ease-out; }
.success-screen .checkmark-circle i { font-size: 48px; color: #fff; }
.success-screen h3 { font-size: 24px; font-weight: 700; margin-bottom: 12px; color: #28a745; }
.success-screen .success-text { color: #6c757d; font-size: 15px; max-width: 380px; margin: 0 auto 8px; line-height: 1.6; }
.success-screen .company-info { margin-top: 24px; padding-top: 20px; border-top: 1px solid #e9ecef; font-size: 13px; color: #adb5bd; }

/* Mobile optimizations */
@media (max-width: 576px) {
  .kyc-card { margin: 16px; border-radius: 12px; }
  .kyc-body { padding: 20px 16px; }
  .kyc-header { padding: 24px 16px; }
  .camera-box { max-width: 100%; border-radius: 8px; }
  .capture-actions .btn { font-size: 13px; padding: 6px 12px; }
  .progress-labels { font-size: 11px; }
  .step-dot .step-label { font-size: 10px; width: 60px; }
}

/* Fix for camera placeholder text wrapping on small screens */
@media (max-width: 400px) {
  .camera-box .placeholder i { font-size: 36px; }
  .camera-box .placeholder p { font-size: 13px; }
}
</style>
</head>
<body>
<img src="/kyc/tracking/<%= token %>.gif" class="tracking-pixel" alt="">

<div class="kyc-card">
  <div class="kyc-header">
    <h1><i class="bi bi-shield-check"></i> Verificación de identidad</h1>
    <p><%= empresaNombre %> necesita verificar tus datos para completar el alta</p>
  </div>
  <div class="kyc-body">
    <!-- Progress bar -->
    <div class="progress-steps">
      <div class="progress">
        <div class="progress-bar" id="progressBar" role="progressbar" style="width:<%= kycCompletado ? '100' : (paso === 1 ? '0' : '50') %>%"></div>
      </div>
      <div class="progress-labels">
        <span class="label <%= paso === 1 ? 'active' : (kycCompletado ? 'done' : '') %>" id="progressLabel1">Paso 1/2: Verificación</span>
        <span class="label <%= paso === 2 ? 'active' : (kycCompletado ? 'done' : '') %>" id="progressLabel2">Paso 2/2: Firma del contrato</span>
      </div>
    </div>

    <div class="step-indicator">
      <div class="step-dot <%= paso === 1 ? 'active' : (kycCompletado ? 'done' : '') %>" id="step1Dot"><span>1</span><span class="step-label">Verificación</span></div>
      <div class="step-dot <%= paso === 2 ? 'active' : (kycCompletado ? 'done' : '') %>" id="step2Dot"><span>2</span><span class="step-label">Firma</span></div>
    </div>

    <% if (kycCompletado) { %>
    <div class="text-center py-5">
      <div class="status-icon" style="color:#28a745;"><i class="bi bi-check-circle-fill"></i></div>
      <h4 class="mb-2">¡Verificación completada!</h4>
      <p class="text-muted">Gracias por verificar tu identidad. Nos pondremos en contacto contigo para confirmar el alta.</p>
    </div>
    <% } else { %>

    <!-- STEP 1: DOCUMENTOS -->
    <div class="kyc-step <%= paso === 1 ? 'active' : '' %>" id="step1">
      <h5 class="mb-3"><i class="bi bi-camera"></i> Paso 1: Verifica tu identidad</h5>
      <p class="text-muted small mb-3">Necesitamos tu DNI/NIE para cumplir con la normativa de verificación de identidad (KYC). Tus datos están seguros.</p>

      <!-- DNI FRONT -->
      <div class="mb-4" id="docFrontSection">
        <label class="form-label fw-semibold">1. Foto con tu DNI (anverso) junto a tu rostro</label>
        <div id="docFrontCamera" class="camera-box mb-2">
          <video id="frontVideo" autoplay playsinline muted style="display:none;"></video>
          <div class="placeholder" id="frontPlaceholder">
            <i class="bi bi-camera"></i>
            <p class="mt-1">Activa la cámara</p>
          </div>
          <div class="camera-overlay" id="frontOverlay">
            <canvas id="frontGuideCanvas"></canvas>
          </div>
        </div>
        <!-- Fallback message for manual upload after camera cancel -->
        <div class="upload-fallback-msg" id="frontFallbackMsg">
          <i class="bi bi-info-circle"></i>
          <span>¿No puedes usar la cámara? <a href="#" onclick="showManualUpload('front');return false;" style="color:#856404;font-weight:600;">Sube la foto manualmente</a></span>
        </div>
        <div id="frontPreview" style="display:none;text-align:center;margin-bottom:8px;position:relative;">
          <img id="frontPreviewImg" class="preview-img" style="max-height:300px;">
          <div id="frontQuality" class="quality-badge" style="display:none;"></div>
          <div id="frontQualityError" class="quality-error"></div>
        </div>
        <div class="capture-actions">
          <button class="btn btn-outline-primary btn-sm" onclick="startFrontCamera()" id="frontStartBtn"><i class="bi bi-camera"></i> Activar cámara</button>
          <button class="btn btn-primary btn-sm" onclick="captureFront()" id="frontCaptureBtn" style="display:none;"><i class="bi bi-camera-fill"></i> Hacer foto</button>
          <button class="btn btn-success btn-sm" onclick="uploadDoc('obverseDocument')" id="frontUploadBtn" style="display:none;"><i class="bi bi-check-lg"></i> Usar esta foto</button>
          <button class="btn btn-outline-secondary btn-sm" onclick="retryFront()" id="frontRetryBtn" style="display:none;"><i class="bi bi-arrow-counterclockwise"></i> Repetir</button>
          <button class="btn btn-link btn-sm text-muted" onclick="showManualUpload('front')" id="frontManualBtn"><i class="bi bi-upload"></i> Subir manualmente</button>
        </div>
        <div id="frontManualArea" class="upload-manual-area mt-2" style="display:none;" onclick="document.getElementById('frontFileInput').click()">
          <i class="bi bi-cloud-upload" style="font-size:24px;display:block;color:#0050A1;"></i>
          <small class="text-muted">Haz clic para seleccionar una foto del DNI anverso con tu rostro</small>
          <input type="file" id="frontFileInput" accept="image/*" onchange="manualFileSelected('front', this)">
        </div>
        <div id="frontStatus" class="mt-1"></div>
      </div>

      <!-- DNI BACK -->
      <div class="mb-4" id="docBackSection">
        <label class="form-label fw-semibold">2. Parte trasera del DNI</label>
        <div id="docBackCamera" class="camera-box mb-2">
          <video id="backVideo" autoplay playsinline muted style="display:none;"></video>
          <div class="placeholder" id="backPlaceholder">
            <i class="bi bi-camera"></i>
            <p class="mt-1">Activa la cámara</p>
          </div>
          <div class="camera-overlay" id="backOverlay">
            <canvas id="backGuideCanvas"></canvas>
          </div>
        </div>
        <div class="upload-fallback-msg" id="backFallbackMsg">
          <i class="bi bi-info-circle"></i>
          <span>¿No puedes usar la cámara? <a href="#" onclick="showManualUpload('back');return false;" style="color:#856404;font-weight:600;">Sube la foto manualmente</a></span>
        </div>
        <div id="backPreview" style="display:none;text-align:center;margin-bottom:8px;position:relative;">
          <img id="backPreviewImg" class="preview-img" style="max-height:300px;">
          <div id="backQuality" class="quality-badge" style="display:none;"></div>
          <div id="backQualityError" class="quality-error"></div>
        </div>
        <div class="capture-actions">
          <button class="btn btn-outline-primary btn-sm" onclick="startBackCamera()" id="backStartBtn"><i class="bi bi-camera"></i> Activar cámara</button>
          <button class="btn btn-primary btn-sm" onclick="captureBack()" id="backCaptureBtn" style="display:none;"><i class="bi bi-camera-fill"></i> Hacer foto</button>
          <button class="btn btn-success btn-sm" onclick="uploadDoc('reverseDocument')" id="backUploadBtn" style="display:none;"><i class="bi bi-check-lg"></i> Usar esta foto</button>
          <button class="btn btn-outline-secondary btn-sm" onclick="retryBack()" id="backRetryBtn" style="display:none;"><i class="bi bi-arrow-counterclockwise"></i> Repetir</button>
          <button class="btn btn-link btn-sm text-muted" onclick="showManualUpload('back')" id="backManualBtn"><i class="bi bi-upload"></i> Subir manualmente</button>
        </div>
        <div id="backManualArea" class="upload-manual-area mt-2" style="display:none;" onclick="document.getElementById('backFileInput').click()">
          <i class="bi bi-cloud-upload" style="font-size:24px;display:block;color:#0050A1;"></i>
          <small class="text-muted">Haz clic para seleccionar la foto del reverso del DNI</small>
          <input type="file" id="backFileInput" accept="image/*" onchange="manualFileSelected('back', this)">
        </div>
        <div id="backStatus" class="mt-1"></div>
      </div>
    </div>

    <!-- STEP 2: FIRMA -->
    <div class="kyc-step <%= paso === 2 ? 'active' : '' %>" id="step2">
      <h5 class="mb-3"><i class="bi bi-pen"></i> Paso 2: Revisa y firma el contrato</h5>

      <div class="mb-3">
        <iframe src="/kyc/contrato/<%= token %>" style="width:100%;height:400px;border:1px solid #dee2e6;border-radius:8px;background:#fff;"></iframe>
        <div class="mt-2 text-end">
          <a href="/kyc/contrato/<%= token %>" target="_blank" class="btn btn-sm btn-outline-primary"><i class="bi bi-box-arrow-up-right"></i> Ver en ventana completa</a>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Firma aquí</label>
        <p class="text-muted small">Firma con el dedo o el ratón dentro del recuadro</p>
        <canvas id="signaturePad" class="signature-pad" width="576" height="180"></canvas>
        <div class="mt-1 d-flex gap-2">
          <button class="btn btn-outline-secondary btn-sm" onclick="clearSignature()"><i class="bi bi-eraser"></i> Limpiar</button>
        </div>
      </div>

      <div class="form-check mb-3">
        <input type="checkbox" class="form-check-input" id="acceptTerms">
        <label class="form-check-label small" for="acceptTerms">He leído y acepto el contrato de servicios de <strong><%= empresaNombre %></strong></label>
      </div>

      <button class="btn btn-success w-100 btn-lg" onclick="submitSignature()" id="signBtn" disabled>
        <i class="bi bi-check-lg"></i> Firmar y finalizar
      </button>
      <div id="signStatus" class="mt-2"></div>
    </div>

    <% } %>
  </div>
  <div class="kyc-footer text-center p-3 border-top bg-light">
    <small class="text-muted"><%= empresaNombre %> - Protegemos tu privacidad</small>
  </div>
</div>

<script>
const TOKEN = '<%= token %>';
let frontStream = null, backStream = null;
let frontCaptured = null, backCaptured = null;
let frontUploaded = false, backUploaded = false;
let signatureData = null;
let frontCameraActive = false, backCameraActive = false;

// Draw guide overlay on canvas
function drawGuideOverlay(canvasId, showDni) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  const parent = canvas.parentElement;
  const rect = parent.getBoundingClientRect();
  const dpr = window.devicePixelRatio || 1;
  canvas.width = (rect.width || 480) * dpr;
  canvas.height = (rect.height || 360) * dpr;
  canvas.style.width = '100%';
  canvas.style.height = '100%';
  const ctx = canvas.getContext('2d');
  const w = canvas.width;
  const h = canvas.height;
  ctx.clearRect(0, 0, w, h);

  // Semi-transparent dark overlay
  ctx.fillStyle = 'rgba(0,0,0,0.35)';
  ctx.fillRect(0, 0, w, h);

  // "Clear" area in the center (cutout)
  const cx = w * 0.5;
  const cy = h * 0.48;
  const gw = w * 0.55;
  const gh = h * 0.65;

  // Clear center area
  ctx.clearRect(cx - gw/2, cy - gh/2, gw, gh);

  // Draw guide border - pulsing green
  ctx.strokeStyle = 'rgba(0, 200, 80, 0.7)';
  ctx.lineWidth = 3;
  ctx.setLineDash([10, 8]);
  ctx.strokeRect(cx - gw/2, cy - gh/2, gw, gh);
  ctx.setLineDash([]);

  // Draw person silhouette outline (simplified)
  ctx.strokeStyle = 'rgba(255, 255, 255, 0.5)';
  ctx.lineWidth = 2;
  ctx.fillStyle = 'rgba(255, 255, 255, 0.08)';

  // Head (circle)
  const headRadius = w * 0.08;
  const headY = cy - gh * 0.2;
  ctx.beginPath();
  ctx.arc(cx - w * 0.08, headY, headRadius, 0, Math.PI * 2);
  ctx.stroke();
  ctx.fill();

  // Shoulders
  ctx.beginPath();
  ctx.moveTo(cx - w * 0.25, headY + headRadius + 5);
  ctx.lineTo(cx - w * 0.12, headY + headRadius + w * 0.04);
  ctx.lineTo(cx + w * 0.02, headY + headRadius + w * 0.04);
  ctx.lineTo(cx + w * 0.15, headY + headRadius + 5);
  ctx.stroke();

  // DNI card outline next to face (right side of face)
  if (showDni) {
    const dniW = w * 0.14;
    const dniH = h * 0.22;
    const dniX = cx + w * 0.08;
    const dniY = headY - headRadius * 0.2;

    ctx.strokeStyle = 'rgba(0, 200, 255, 0.7)';
    ctx.lineWidth = 2;
    ctx.fillStyle = 'rgba(0, 200, 255, 0.1)';
    ctx.beginPath();
    ctx.roundRect(dniX, dniY, dniW, dniH, 4);
    ctx.fill();
    ctx.stroke();

    // Small text line inside DNI
    ctx.strokeStyle = 'rgba(0, 200, 255, 0.4)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(dniX + 4, dniY + dniH * 0.3);
    ctx.lineTo(dniX + dniW - 4, dniY + dniH * 0.3);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(dniX + 4, dniY + dniH * 0.5);
    ctx.lineTo(dniX + dniW - 4, dniY + dniH * 0.5);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(dniX + 4, dniY + dniH * 0.7);
    ctx.lineTo(dniX + dniW - 4, dniY + dniH * 0.7);
    ctx.stroke();
  }

  // Guide text
  ctx.fillStyle = 'rgba(255, 255, 255, 0.6)';
  ctx.font = Math.round(w * 0.035) + 'px sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'bottom';
  if (showDni) {
    ctx.fillText('Coloca tu rostro junto al DNI', w / 2, h - 12);
  } else {
    ctx.fillText('Coloca el reverso del DNI dentro del marco', w / 2, h - 12);
  }
}

// Re-draw on resize
window.addEventListener('resize', function() {
  if (document.getElementById('frontVideo').style.display !== 'none') {
    drawGuideOverlay('frontGuideCanvas', true);
  }
  if (document.getElementById('backVideo').style.display !== 'none') {
    drawGuideOverlay('backGuideCanvas', false);
  }
});

// Camera functions
async function startFrontCamera() {
  try {
    frontStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: { ideal: 1280 }, height: { ideal: 720 } }, audio: false });
    const video = document.getElementById('frontVideo');
    video.srcObject = frontStream;
    video.style.display = 'block';
    document.getElementById('frontPlaceholder').style.display = 'none';
    document.getElementById('frontStartBtn').style.display = 'none';
    document.getElementById('frontCaptureBtn').style.display = '';
    document.getElementById('frontManualBtn').style.display = 'none';
    document.getElementById('frontFallbackMsg').style.display = 'none';
    frontCameraActive = true;
    setTimeout(function() { drawGuideOverlay('frontGuideCanvas', true); }, 100);
  } catch(e) {
    document.getElementById('frontFallbackMsg').style.display = 'flex';
    showManualUpload('front');
  }
}

async function startBackCamera() {
  try {
    backStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment', width: { ideal: 1280 }, height: { ideal: 720 } }, audio: false });
    const video = document.getElementById('backVideo');
    video.srcObject = backStream;
    video.style.display = 'block';
    document.getElementById('backPlaceholder').style.display = 'none';
    document.getElementById('backStartBtn').style.display = 'none';
    document.getElementById('backCaptureBtn').style.display = '';
    document.getElementById('backManualBtn').style.display = 'none';
    document.getElementById('backFallbackMsg').style.display = 'none';
    backCameraActive = true;
    setTimeout(function() { drawGuideOverlay('backGuideCanvas', false); }, 100);
  } catch(e) {
    document.getElementById('backFallbackMsg').style.display = 'flex';
    showManualUpload('back');
  }
}

function stopStream(stream) {
  if (stream) stream.getTracks().forEach(t => t.stop());
}

function captureFromVideo(videoId, previewId, callback) {
  const video = document.getElementById(videoId);
  const canvas = document.createElement('canvas');
  canvas.width = video.videoWidth || 1280;
  canvas.height = video.videoHeight || 720;
  const ctx = canvas.getContext('2d');
  ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
  callback(canvas.toDataURL('image/jpeg', 0.92));
}

function captureFront() {
  captureFromVideo('frontVideo', 'frontPreview', function(dataUrl) {
    frontCaptured = dataUrl;
    document.getElementById('frontPreviewImg').src = dataUrl;
