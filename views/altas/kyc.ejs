// Laplacian variance for blur detection
function calculateLaplacianVariance(imageData, width, height) {
  const data = imageData.data;
  const laplacianKernel = [
    0,  1, 0,
    1, -4, 1,
    0,  1, 0
  ];
  let sumSquared = 0;
  let count = 0;
  // Skip border pixels
  for (let y = 1; y < height - 1; y++) {
    for (let x = 1; x < width - 1; x++) {
      let laplacian = 0;
      for (let ky = -1; ky <= 1; ky++) {
        for (let kx = -1; kx <= 1; kx++) {
          const idx = ((y + ky) * width + (x + kx)) * 4;
          const gray = 0.299 * data[idx] + 0.587 * data[idx + 1] + 0.114 * data[idx + 2];
          laplacian += gray * laplacianKernel[(ky + 1) * 3 + (kx + 1)];
        }
      }
      sumSquared += laplacian * laplacian;
      count++;
    }
  }
  return count > 0 ? sumSquared / count : 0;
}

function checkImageQuality(side) {
  const img = new Image();
  img.onload = function() {
    const canvas = document.createElement('canvas');
    canvas.width = img.width;
    canvas.height = img.height;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0);
    const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
    const data = imageData.data;
    let sum = 0;
    const pixelCount = data.length / 4;
    for (let i = 0; i < data.length; i += 4) {
      const brightness = 0.299 * data[i] + 0.587 * data[i + 1] + 0.114 * data[i + 2];
      sum += brightness;
    }
    const avg = sum / pixelCount;

    // Contrast
    let contrastSum = 0;
    for (let i = 0; i < data.length; i += 4) {
      const brightness = 0.299 * data[i] + 0.587 * data[i + 1] + 0.114 * data[i + 2];
      contrastSum += Math.pow(brightness - avg, 2);
    }
    const contrast = Math.sqrt(contrastSum / pixelCount);

    // Blur detection via Laplacian variance
    const laplacianVar = calculateLaplacianVariance(imageData, canvas.width, canvas.height);

    const previewImg = document.getElementById(side + 'PreviewImg');
    const qualityError = document.getElementById(side + 'QualityError');
    const badge = document.getElementById(side + 'Quality');
    let errors = [];
    let isGood = true;

    // Check blur
    if (laplacianVar < 100) {
      isGood = false;
      errors.push('La imagen está borrosa');
    }

    // Check brightness
    if (avg < 60) {
      isGood = false;
      errors.push('La imagen está demasiado oscura');
    } else if (avg > 220) {
      isGood = false;
      errors.push('La imagen está demasiado clara');
    }

    // Check contrast / visibility of DNI
    if (contrast < 35) {
      isGood = false;
      if (errors.length < 3) {
        errors.push('No se ve el DNI correctamente');
      }
    }

    // Show quality badge
    if (badge) {
      badge.style.display = 'block';
      if (isGood) {
        badge.className = 'quality-badge good';
        badge.textContent = 'Buena calidad';
        previewImg.className = 'preview-img preview-valid';
      } else {
        badge.className = 'quality-badge bad';
        badge.textContent = 'Baja calidad';
        previewImg.className = 'preview-img preview-invalid';
      }
    }

    // Show specific error messages
    if (qualityError) {
      if (errors.length > 0) {
        qualityError.style.display = 'block';
        qualityError.innerHTML = errors.map(function(e) { return '<i class="bi bi-exclamation-triangle"></i> ' + e; }).join('<br>');
      } else {
        qualityError.style.display = 'none';
      }
    }
  };
  if (side === 'front' && frontCaptured) img.src = frontCaptured;
  else if (side === 'back' && backCaptured) img.src = backCaptured;
}

function dataURLtoBlob(dataUrl) {
  const parts = dataUrl.split(',');
  const mime = parts[0].match(/:(.*?);/)[1];
  const bytes = atob(parts[1]);
  const ab = new ArrayBuffer(bytes.length);
  const ia = new Uint8Array(ab);
  for (let i = 0; i < bytes.length; i++) ia[i] = bytes.charCodeAt(i);
  return new Blob([ab], { type: mime });
}

async function uploadDoc(tipo) {
  const side = tipo === 'obverseDocument' ? 'front' : 'back';
  const dataUrl = side === 'front' ? frontCaptured : backCaptured;
  if (!dataUrl) return;

  const statusEl = document.getElementById(side + 'Status');
  statusEl.innerHTML = '<div class="status-msg" style="background:#cce5ff;color:#004085;border:1px solid #b8daff;"><span class="spinner-border spinner-border-sm"></span> Subiendo documento...</div>';

  try {
    const blob = dataURLtoBlob(dataUrl);
    const formData = new FormData();
    formData.append('file', blob, tipo + '.jpg');
    formData.append('tipo', tipo);

    const response = await fetch('/kyc/' + TOKEN + '/subir-doc', {
      method: 'POST',
      body: formData
    });
    const result = await response.json();

    if (result.ok) {
      statusEl.innerHTML = '<div class="status-msg success animate-slide"><span class="status-icon-big"><i class="bi bi-check-circle-fill"></i></span><span class="status-text">Documento recibido correctamente</span></div>';
      if (side === 'front') {
        frontUploaded = true;
        document.getElementById('frontUploadBtn').style.display = 'none';
        document.getElementById('frontRetryBtn').style.display = 'none';
        document.getElementById('frontManualBtn').style.display = 'none';
        document.getElementById('frontManualArea').style.display = 'none';
      } else {
        backUploaded = true;
        document.getElementById('backUploadBtn').style.display = 'none';
        document.getElementById('backRetryBtn').style.display = 'none';
        document.getElementById('backManualBtn').style.display = 'none';
        document.getElementById('backManualArea').style.display = 'none';
      }

      if (frontUploaded && backUploaded) {
        setTimeout(function() {
          goToStep2();
        }, 800);
      }
    } else {
      statusEl.innerHTML = '<div class="status-msg error animate-slide"><span class="status-icon-big"><i class="bi bi-x-circle"></i></span><span class="status-text">' + (result.error || 'Error al subir el documento') + '</span></div>';
    }
  } catch(e) {
    statusEl.innerHTML = '<div class="status-msg error animate-slide"><span class="status-icon-big"><i class="bi bi-x-circle"></i></span><span class="status-text">Error de conexión. Intenta de nuevo.</span></div>';
  }
}

function goToStep2() {
  // Update progress bar to 50%
  document.getElementById('progressBar').style.width = '50%';
  document.getElementById('progressLabel1').classList.remove('active');
  document.getElementById('progressLabel1').classList.add('done');
  document.getElementById('progressLabel2').classList.add('active');

  document.getElementById('step1').classList.remove('active');
  document.getElementById('step2').classList.add('active');
  document.getElementById('step1Dot').classList.remove('active');
  document.getElementById('step1Dot').classList.add('done');
  document.getElementById('step2Dot').classList.add('active');
  initSignaturePad();
}

// Signature pad
let sigCanvas, sigCtx, isDrawing = false;

function initSignaturePad() {
  sigCanvas = document.getElementById('signaturePad');
  if (!sigCanvas) return;
  sigCtx = sigCanvas.getContext('2d');
  sigCanvas.addEventListener('mousedown', startDraw);
  sigCanvas.addEventListener('mousemove', draw);
  sigCanvas.addEventListener('mouseup', stopDraw);
  sigCanvas.addEventListener('touchstart', startDrawTouch);
  sigCanvas.addEventListener('touchmove', drawTouch);
  sigCanvas.addEventListener('touchend', stopDraw);
  sigCtx.strokeStyle = '#0050A1';
  sigCtx.lineWidth = 2;
  sigCtx.lineCap = 'round';
}

function startDraw(e) { isDrawing = true; sigCtx.beginPath(); sigCtx.moveTo(e.offsetX, e.offsetY); }
function draw(e) { if (!isDrawing) return; sigCtx.lineTo(e.offsetX, e.offsetY); sigCtx.stroke(); }
function stopDraw() { isDrawing = false; }
function startDrawTouch(e) { e.preventDefault(); const rect = sigCanvas.getBoundingClientRect(); const touch = e.touches[0]; isDrawing = true; sigCtx.beginPath(); sigCtx.moveTo(touch.clientX - rect.left, touch.clientY - rect.top); }
function drawTouch(e) { e.preventDefault(); if (!isDrawing) return; const rect = sigCanvas.getBoundingClientRect(); const touch = e.touches[0]; sigCtx.lineTo(touch.clientX - rect.left, touch.clientY - rect.top); sigCtx.stroke(); }

function clearSignature() {
  sigCtx.clearRect(0, 0, sigCanvas.width, sigCanvas.height);
  signatureData = null;
}

document.getElementById('acceptTerms')?.addEventListener('change', function() {
  document.getElementById('signBtn').disabled = !this.checked;
});

async function submitSignature() {
  if (!sigCanvas) return;
  signatureData = sigCanvas.toDataURL('image/png');
  if (!signatureData || signatureData.length < 100) {
    document.getElementById('signStatus').innerHTML = '<div class="status-msg" style="background:#fff3cd;color:#856404;border:1px solid #ffeeba;"><i class="bi bi-exclamation-triangle"></i> Por favor, dibuja tu firma</div>';
    return;
  }

  document.getElementById('signBtn').disabled = true;
  document.getElementById('signBtn').innerHTML = '<span class="spinner-border spinner-border-sm"></span> Enviando...';
  document.getElementById('signStatus').innerHTML = '';

  try {
    const response = await fetch('/kyc/' + TOKEN + '/firmar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ firma: signatureData })
    });
    const result = await response.json();
    if (result.ok) {
      // Update progress bar to 100%
      document.getElementById('progressBar').style.width = '100%';
      document.getElementById('progressLabel2').classList.remove('active');
      document.getElementById('progressLabel2').classList.add('done');
      document.getElementById('step2Dot').classList.remove('active');
      document.getElementById('step2Dot').classList.add('done');

      document.getElementById('signStatus').innerHTML =
        '<div class="success-screen">' +
          '<div class="checkmark-circle"><i class="bi bi-check-lg"></i></div>' +
          '<h3>¡Todo completado!</h3>' +
          '<p class="success-text">Hemos recibido tu documentación y firma. Te notificaremos cuando tu línea esté activa.</p>' +
          '<div class="company-info"><i class="bi bi-building"></i> <%= empresaNombre %> - Todo listo</div>' +
        '</div>';
      document.getElementById('signBtn').style.display = 'none';
    } else {
      document.getElementById('signStatus').innerHTML = '<div class="status-msg error animate-slide"><span class="status-icon-big"><i class="bi bi-x-circle"></i></span><span class="status-text">Error: ' + (result.error || 'desconocido') + '</span></div>';
      document.getElementById('signBtn').disabled = false;
      document.getElementById('signBtn').innerHTML = '<i class="bi bi-check-lg"></i> Firmar y finalizar';
    }
  } catch(e) {
    document.getElementById('signStatus').innerHTML = '<div class="status-msg error animate-slide"><span class="status-icon-big"><i class="bi bi-x-circle"></i></span><span class="status-text">Error de conexión. Intenta de nuevo.</span></div>';
    document.getElementById('signBtn').disabled = false;
    document.getElementById('signBtn').innerHTML = '<i class="bi bi-check-lg"></i> Firmar y finalizar';
  }
}

// Auto-start front camera on load
setTimeout(startFrontCamera, 500);
