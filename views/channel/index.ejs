<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="ri-team-line"></i> Distribuidores</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#crearModal">
      <i class="ri-add-line"></i> Nuevo Distribuidor
    </button>
  </div>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-warning"><%= error %></div><% } %>

  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card bg-light border-0 shadow-sm p-3" style="cursor:pointer;filter:grayscale(1)" onclick="filtrar('todos')">
        <div class="d-flex justify-content-between">
          <span class="text-muted">Total Distribuidores</span>
          <i class="ri-group-line text-secondary"></i>
        </div>
        <h3 class="mb-0"><%= total %></h3>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card bg-light border-0 shadow-sm p-3" style="cursor:pointer;filter:grayscale(1)" onclick="filtrar('activos')">
        <div class="d-flex justify-content-between">
          <span class="text-muted">Activos</span>
          <i class="ri-user-smile-line text-secondary"></i>
        </div>
        <h3 class="mb-0 text-success"><%= activos %></h3>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card bg-light border-0 shadow-sm p-3" style="cursor:pointer;filter:grayscale(1)" onclick="filtrar('inactivos')">
        <div class="d-flex justify-content-between">
          <span class="text-muted">Inactivos</span>
          <i class="ri-user-forbid-line text-secondary"></i>
        </div>
        <h3 class="mb-0 text-danger"><%= total - activos %></h3>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card bg-light border-0 shadow-sm p-3" style="filter:grayscale(1)">
        <div class="d-flex justify-content-between">
          <span class="text-muted">Total Ventas</span>
          <i class="ri-money-euro-circle-line text-secondary"></i>
        </div>
        <h3 class="mb-0"><%= Number(totalVentas).toLocaleString('es-ES', {minimumFractionDigits:2}) %> €</h3>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Distribuidores Activos vs Inactivos</h6>
        <div class="chart-wrap" style="height:170px;overflow:hidden;position:relative;"><canvas id="chartEstado"></canvas></div>
      </div></div>
    </div>
    <div class="col-md-6">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Top Distribuidores por Ventas</h6>
        <div class="chart-wrap" style="height:170px;overflow:hidden;position:relative;"><canvas id="chartTop"></canvas></div>
      </div></div>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0" id="distribuidoresTable">
          <thead class="table-light">
            <tr>
              <th>Nombre</th>
              <th>Contacto</th>
              <th>Teléfono</th>
              <th>Email</th>
              <th>Comisión</th>
              <th>Ventas</th>
              <th>Total €</th>
              <th>Estado</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (!distributors || distributors.length === 0) { %>
            <tr><td colspan="9" class="text-center text-muted py-4">No hay distribuidores registrados</td></tr>
            <% } else { distributors.forEach(function(d) { %>
            <tr data-estado="<%= d.activo ? 'activo' : 'inactivo' %>" class="<%= d.activo ? '' : 'table-danger' %>">
              <td><strong><%= d.nombre %></strong></td>
              <td><%= d.contacto || '-' %></td>
              <td><%= d.telefono || '-' %></td>
              <td><%= d.email || '-' %></td>
              <td><%= Number(d.comision).toFixed(2) %>%</td>
              <td><%= d.total_ventas || 0 %></td>
              <td><%= Number(d.total_importe || 0).toLocaleString('es-ES', {minimumFractionDigits:2}) %> €</td>
              <td>
                <span class="badge <%= d.activo ? 'bg-success' : 'bg-secondary' %>">
                  <%= d.activo ? 'Activo' : 'Inactivo' %>
                </span>
              </td>
              <td class="text-end">
                <button class="btn btn-sm btn-outline-primary" onclick="editar(<%= d.id %>)" title="Editar">
                  <i class="ri-pencil-line"></i>
                </button>
                <button class="btn btn-sm btn-outline-<%= d.activo ? 'warning' : 'success' %>" onclick="cambiarEstado(<%= d.id %>)" title="<%= d.activo ? 'Desactivar' : 'Activar' %>">
                  <i class="ri-<%= d.activo ? 'pause-line' : 'play-line' %>"></i>
                </button>
                <button class="btn btn-sm btn-outline-danger" onclick="eliminar(<%= d.id %>)" title="Eliminar">
                  <i class="ri-delete-bin-line"></i>
                </button>
              </td>
            </tr>
            <% }); } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<!-- Crear Modal -->
<div class="modal fade" id="crearModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form id="crearForm">
        <div class="modal-header">
          <h5 class="modal-title">Nuevo Distribuidor</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Nombre <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="nombre" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Persona de Contacto</label>
            <input type="text" class="form-control" name="contacto">
          </div>
          <div class="row mb-3">
            <div class="col">
              <label class="form-label">Teléfono</label>
              <input type="text" class="form-control" name="telefono">
            </div>
            <div class="col">
              <label class="form-label">Email</label>
              <input type="email" class="form-control" name="email">
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Comisión (%)</label>
            <input type="number" step="0.01" class="form-control" name="comision" value="0">
          </div>
          <div class="mb-3">
            <label class="form-label">Dirección</label>
            <input type="text" class="form-control" name="direccion">
          </div>
          <div class="mb-3">
            <label class="form-label">Notas</label>
            <textarea class="form-control" name="notas" rows="2"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Crear Distribuidor</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Editar Modal -->
<div class="modal fade" id="editarModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form id="editarForm">
        <input type="hidden" name="id" id="edit-id">
        <div class="modal-header">
          <h5 class="modal-title">Editar Distribuidor</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Nombre <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="nombre" id="edit-nombre" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Persona de Contacto</label>
            <input type="text" class="form-control" name="contacto" id="edit-contacto">
          </div>
          <div class="row mb-3">
            <div class="col">
              <label class="form-label">Teléfono</label>
              <input type="text" class="form-control" name="telefono" id="edit-telefono">
            </div>
            <div class="col">
              <label class="form-label">Email</label>
              <input type="email" class="form-control" name="email" id="edit-email">
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Comisión (%)</label>
            <input type="number" step="0.01" class="form-control" name="comision" id="edit-comision">
          </div>
          <div class="mb-3">
            <label class="form-label">Dirección</label>
            <input type="text" class="form-control" name="direccion" id="edit-direccion">
          </div>
          <div class="mb-3">
            <label class="form-label">Notas</label>
            <textarea class="form-control" name="notas" id="edit-notas" rows="2"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Guardar Cambios</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
const distributors = <%- JSON.stringify(distributors) %>;

function filtrar(tipo) {
  const rows = document.querySelectorAll('#distribuidoresTable tbody tr[data-estado]');
  rows.forEach(r => {
    if (tipo === 'todos') r.style.display = '';
    else if (tipo === 'activos') r.style.display = r.dataset.estado === 'activo' ? '' : 'none';
    else if (tipo === 'inactivos') r.style.display = r.dataset.estado === 'inactivo' ? '' : 'none';
  });
}

document.getElementById('crearForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const fd = new FormData(this);
  const data = Object.fromEntries(fd.entries());
  try {
    const res = await fetch('/channel/crear', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data) });
    const json = await res.json();
    if (json.error) return alert('Error: ' + json.error);
    location.reload();
  } catch(err) { alert('Error de red'); }
});

document.getElementById('editarForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const fd = new FormData(this);
  const data = Object.fromEntries(fd.entries());
  try {
    const res = await fetch('/channel/editar', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data) });
    const json = await res.json();
    if (json.error) return alert('Error: ' + json.error);
    location.reload();
  } catch(err) { alert('Error de red'); }
});

function editar(id) {
  const d = distributors.find(x => x.id === id);
  if (!d) return;
  document.getElementById('edit-id').value = d.id;
  document.getElementById('edit-nombre').value = d.nombre;
  document.getElementById('edit-contacto').value = d.contacto || '';
  document.getElementById('edit-telefono').value = d.telefono || '';
  document.getElementById('edit-email').value = d.email || '';
  document.getElementById('edit-comision').value = d.comision;
  document.getElementById('edit-direccion').value = d.direccion || '';
  document.getElementById('edit-notas').value = d.notas || '';
  new bootstrap.Modal(document.getElementById('editarModal')).show();
}

function cambiarEstado(id) {
  if (!confirm('¿Cambiar estado del distribuidor?')) return;
  fetch('/channel/' + id + '/estado', { method:'POST' })
    .then(r => r.json()).then(j => { if (j.error) alert(j.error); else location.reload(); })
    .catch(() => alert('Error de red'));
}

function eliminar(id) {
  if (!confirm('¿Eliminar este distribuidor? Esta acción no se puede deshacer.')) return;
  fetch('/channel/eliminar', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({id}) })
    .then(r => r.json()).then(j => { if (j.error) alert(j.error); else location.reload(); })
    .catch(() => alert('Error de red'));
}
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  new Chart(document.getElementById('chartEstado'), {
    type: 'bar',
    data: {
      labels: ['Activos', 'Inactivos'],
      datasets: [{
        label: 'Distribuidores',
        data: [<%= activos %>, <%= total - activos %>],
        backgroundColor: ['#198754', '#dc3545'],
        borderRadius: 4
      }]
    },
      options: {
      responsive: true, maintainAspectRatio: false, animation: false, resizeDelay: 0,
      plugins: { legend: { display: false } },
      scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
    }
  });

  var top = [<% distributors.sort(function(a,b){return (b.total_importe||0)-(a.total_importe||0)}).slice(0,8).forEach(function(d,i){%>{nombre:'<%= d.nombre.replace(/'/g,"\\'") %>',ventas:<%= d.total_importe||0 %>,comision:<%= d.comision||0 %>}<% if(i<7){%>,<%}%><%})%>];
  var greens = ['#004d26','#006b37','#198754','#219f5e','#2db872','#52c88a','#7ed9a3','#abe9be'];
  new Chart(document.getElementById('chartTop'), {
    type: 'bar',
    data: {
      labels: top.map(function(t){return t.nombre}),
      datasets: [{
        label: 'Total €',
        data: top.map(function(t){return t.ventas}),
        backgroundColor: greens.slice(0, top.length),
        borderRadius: 4
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false, resizeDelay: 0,
      indexAxis: 'y',
      plugins: { legend: { display: false } },
      scales: { x: { beginAtZero: true } }
    }
  });
});
</script>