<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="ri-kanban-view"></i> Leads</h2>
  </div>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-warning"><%= error %></div><% } %>
  <div class="row g-3 mb-3">
    <a href="/leads" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle primary"><span>🎯</span></div><div><div class="stat-value"><%= leads.length %></div><div class="stat-label">Total Leads</div></div></div></div></a>
    <a href="/leads" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle success"><span>✅</span></div><div><div class="stat-value"><%= leads.filter(l => (l.status||'').toUpperCase() === 'CONVERTED').length %></div><div class="stat-label">Convertidos</div></div></div></div></a>
    <a href="/leads" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle warning"><span>🆕</span></div><div><div class="stat-value"><%= leads.filter(l => (l.status||'').toUpperCase() === 'NEW' || (l.status||'').toUpperCase() === 'PENDING').length %></div><div class="stat-label">Nuevos</div></div></div></div></a>
    <a href="/leads" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle danger"><span>❌</span></div><div><div class="stat-value"><%= leads.filter(l => (l.status||'').toUpperCase() === 'LOST').length %></div><div class="stat-label">Perdidos</div></div></div></div></a>
  </div>
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">🍩</span> Estado</h6>
        <div class="chart-container" style="height:200px;overflow:hidden;"><canvas id="leadsStatusChart"></canvas></div>
      </div></div>
    </div>
    <div class="col-md-3">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Top 5 Fuentes</h6>
        <div class="chart-container" style="height:200px;overflow:hidden;"><canvas id="leadsSourceChart"></canvas></div>
      </div></div>
    </div>
    <div class="col-md-3">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📈</span> Leads por Mes</h6>
        <div class="chart-container" style="height:200px;overflow:hidden;"><canvas id="leadsMonthlyChart"></canvas></div>
      </div></div>
    </div>
    <div class="col-md-3">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📉</span> Tasa Conversión</h6>
        <div class="chart-container" style="height:200px;overflow:hidden;"><canvas id="leadsConvChart"></canvas></div>
      </div></div>
    </div>
  </div>
  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover">
          <thead><tr><th>Nombre</th><th>Teléfono</th><th>Email</th><th>Interés</th><th>Origen</th><th>Estado</th><th>Fecha</th><th></th></tr></thead>
          <tbody>
            <% if (!leads || leads.length === 0) { %>
            <tr><td colspan="8" class="text-center text-muted py-4">No hay leads</td></tr>
            <% } else { leads.forEach(l => { 
              const st = (l.status||'').toUpperCase();
              const sc = st === 'CONVERTED' ? 'success' : st === 'NEW' ? 'info' : st === 'LOST' ? 'danger' : st === 'CONTACTED' ? 'warning' : 'secondary';
            %>
            <tr>
              <td><%= l.name || l.nombre || l.fullName || '-' %></td>
              <td><%= l.phone || l.telefono || '-' %></td>
              <td><%= l.email || '-' %></td>
              <td><%= l.interest || l.interes || l.product || '-' %></td>
              <td><%= l.source || l.origen || '-' %></td>
              <td><span class="badge bg-<%= sc %>"><%= st %></span></td>
              <td class="small"><%= l.created || l.fecha ? new Date(l.created || l.fecha).toLocaleDateString('es-ES') : '-' %></td>
              <td><button class="btn btn-sm btn-outline-primary"><i class="ri-arrow-right-line"></i></button></td>
            </tr>
            <% }); } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<div class="modal fade" id="chartDetailModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-sm"><div class="modal-content"><div class="modal-header"><h6 class="modal-title" id="chartDetailTitle"></h6><button class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body p-2"><table class="table table-sm mb-0"><thead><tr><th>Etiqueta</th><th class="text-end">Valor</th></tr></thead><tbody id="chartDetailBody"></tbody></table></div></div></div></div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var stLabels = <%- JSON.stringify(charts.status.labels) %>;
  var stData = <%- JSON.stringify(charts.status.data) %>;
  var soLabels = <%- JSON.stringify(charts.sources.labels) %>;
  var soData = <%- JSON.stringify(charts.sources.data) %>;
  var moLabels = <%- JSON.stringify(charts.monthly.labels) %>;
  var moData = <%- JSON.stringify(charts.monthly.data) %>;
  var coLabels = <%- JSON.stringify(charts.conversion.labels) %>;
  var coData = <%- JSON.stringify(charts.conversion.data) %>;

  function makeModal(canvasId, title, labels, data) {
    var el = document.getElementById(canvasId);
    if (!el || labels.length === 0) return;
    el.style.cursor = 'pointer';
    el.addEventListener('click', function() {
      document.getElementById('chartDetailTitle').textContent = title;
      var tbody = document.getElementById('chartDetailBody');
      tbody.innerHTML = '';
      labels.forEach(function(l, i) {
        var tr = document.createElement('tr');
        tr.innerHTML = '<td>' + l + '</td><td class="text-end fw-bold">' + data[i] + '</td>';
        tbody.appendChild(tr);
      });
      var modal = new bootstrap.Modal(document.getElementById('chartDetailModal'));
      modal.show();
    });
  }

  try {
    new Chart(document.getElementById('leadsStatusChart'), {
      type: 'doughnut',
      data: { labels: stLabels, datasets: [{ label: 'Leads', data: stData, backgroundColor: ['#198754', '#0d6efd', '#dc3545'], borderWidth: 0 }] },
      options: { responsive: true, maintainAspectRatio: false, animation: false, resizeDelay: 0, plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, padding: 8 } } } }
    });
    makeModal('leadsStatusChart', 'Estado de Leads', stLabels, stData);
  } catch(e) { console.error(e); }

  try {
    new Chart(document.getElementById('leadsSourceChart'), {
      type: 'bar',
      data: { labels: soLabels, datasets: [{ label: 'Leads', data: soData, backgroundColor: '#0d6efd', borderRadius: 6 }] },
      options: { responsive: true, maintainAspectRatio: false, animation: false, resizeDelay: 0, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } }
    });
    makeModal('leadsSourceChart', 'Top 5 Fuentes', soLabels, soData);
  } catch(e) { console.error(e); }

  try {
    new Chart(document.getElementById('leadsMonthlyChart'), {
      type: 'bar',
      data: { labels: moLabels, datasets: [{ label: 'Leads', data: moData, backgroundColor: '#6c757d', borderRadius: 6 }] },
      options: { responsive: true, maintainAspectRatio: false, animation: false, resizeDelay: 0, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } }
    });
    makeModal('leadsMonthlyChart', 'Leads por Mes', moLabels, moData);
  } catch(e) { console.error(e); }

  try {
    new Chart(document.getElementById('leadsConvChart'), {
      type: 'line',
      data: { labels: coLabels, datasets: [{ label: '% Conversión', data: coData, borderColor: '#198754', backgroundColor: 'rgba(25,135,84,0.08)', fill: true, tension: 0.3, pointRadius: 4 }] },
      options: { responsive: true, maintainAspectRatio: false, animation: false, resizeDelay: 0, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, max: 100, grid: { color: '#eee' } }, x: { grid: { display: false } } } }
    });
    makeModal('leadsConvChart', 'Tasa Conversión (%)', coLabels, coData);
  } catch(e) { console.error(e); }
});
</script>