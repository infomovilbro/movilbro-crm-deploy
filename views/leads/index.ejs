<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="ri-kanban-view"></i> Leads</h2>
  </div>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-warning"><%= error %></div><% } %>
  <div class="row g-3 mb-3">
    <a href="/leads" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle primary"><span>🎯</span></div><div><div class="stat-value"><%= leads.length %></div><div class="stat-label">Total Leads</div></div></div></div></a>
    <a href="/leads" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle success"><span>✅</span></div><div><div class="stat-value"><%= leads.filter(l => (l.status||'').toUpperCase() === 'CONVERTED').length %></div><div class="stat-label">Convertidos</div></div></div></div></a>
    <a href="/leads" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle warning"><span>🆕</span></div><div><div class="stat-value"><%= leads.filter(l => (l.status||'').toUpperCase() === 'NEW' || (l.status||'').toUpperCase() === 'PENDING').length %></div><div class="stat-label">Nuevos</div></div></div></div></a>
    <a href="/leads" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle danger"><span>❌</span></div><div><div class="stat-value"><%= leads.filter(l => (l.status||'').toUpperCase() === 'LOST').length %></div><div class="stat-label">Perdidos</div></div></div></div></a>
  </div>
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Estado de Leads</h6>
        <canvas id="leadsStatusChart" style="height:221px;"></canvas>
      </div></div>
    </div>
    <div class="col-md-6">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Leads por Fuente/Origen</h6>
        <canvas id="leadsSourceChart" style="height:221px;"></canvas>
      </div></div>
    </div>
  </div>
  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover">
          <thead><tr><th>Nombre</th><th>Teléfono</th><th>Email</th><th>Interés</th><th>Origen</th><th>Estado</th><th>Fecha</th><th></th></tr></thead>
          <tbody>
            <% if (!leads || leads.length === 0) { %>
            <tr><td colspan="8" class="text-center text-muted py-4">No hay leads</td></tr>
            <% } else { leads.forEach(l => { 
              const st = (l.status||'').toUpperCase();
              const sc = st === 'CONVERTED' ? 'success' : st === 'NEW' ? 'info' : st === 'LOST' ? 'danger' : st === 'CONTACTED' ? 'warning' : 'secondary';
            %>
            <tr>
              <td><%= l.name || l.nombre || l.fullName || '-' %></td>
              <td><%= l.phone || l.telefono || '-' %></td>
              <td><%= l.email || '-' %></td>
              <td><%= l.interest || l.interes || l.product || '-' %></td>
              <td><%= l.source || l.origen || '-' %></td>
              <td><span class="badge bg-<%= sc %>"><%= st %></span></td>
              <td class="small"><%= l.created || l.fecha ? new Date(l.created || l.fecha).toLocaleDateString('es-ES') : '-' %></td>
              <td><button class="btn btn-sm btn-outline-primary"><i class="ri-arrow-right-line"></i></button></td>
            </tr>
            <% }); } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<script>
var leadsData = <%- JSON.stringify(leads) %>;
var convertidos = leadsData.filter(function(l) { return (l.status||'').toUpperCase() === 'CONVERTED'; }).length;
var nuevos = leadsData.filter(function(l) { var s = (l.status||'').toUpperCase(); return s === 'NEW' || s === 'PENDING'; }).length;
var perdidos = leadsData.filter(function(l) { return (l.status||'').toUpperCase() === 'LOST'; }).length;

var ctx1 = document.getElementById('leadsStatusChart').getContext('2d');
new Chart(ctx1, {
  type: 'bar',
  data: {
    labels: ['Convertidos', 'Nuevos/Pendientes', 'Perdidos'],
    datasets: [{
      label: 'Leads',
      data: [convertidos, nuevos, perdidos],
      backgroundColor: ['#198754', '#0d6efd', '#dc3545'],
      borderRadius: 6
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } }
  }
});

var sourceCounts = {};
leadsData.forEach(function(l) {
  var src = l.source || l.origen || 'Otro';
  sourceCounts[src] = (sourceCounts[src] || 0) + 1;
});
var sortedSources = Object.keys(sourceCounts).sort(function(a, b) { return sourceCounts[b] - sourceCounts[a]; });
var top5Sources = sortedSources.slice(0, 5);
var top5Counts = top5Sources.map(function(s) { return sourceCounts[s]; });

var ctx2 = document.getElementById('leadsSourceChart').getContext('2d');
new Chart(ctx2, {
  type: 'bar',
  data: {
    labels: top5Sources,
    datasets: [{
      label: 'Leads',
      data: top5Counts,
      backgroundColor: top5Counts.map(function(v, i) { return i > 0 && v < top5Counts[i-1] ? '#dc3545' : '#198754'; }),
      borderRadius: 6
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } }
  }
});
</script>
</section>
