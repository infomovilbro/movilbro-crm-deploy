<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-camera-video"></i> Cámara - iCam365</h5>
    <div>
      <span class="badge bg-success me-1">UID: <%= camUid %></span>
      <span class="badge bg-info">IP: <%= camIp %></span>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-md-8">
      <div class="card">
        <div class="card-body p-2 text-center" style="background:#000;min-height:400px;display:flex;align-items:center;justify-content:center;">
          <div id="cameraPlaceholder">
            <i class="bi bi-camera-video-off" style="font-size:4rem;color:#555;"></i>
            <p class="text-muted mt-2">Stream no disponible en la nube</p>
            <p class="small text-muted">Configura la URL del stream en los ajustes</p>
          </div>
          <img id="camImage" style="display:none;max-width:100%;max-height:500px;" crossorigin="anonymous" />
        </div>
        <div class="card-footer text-center py-1 d-flex justify-content-between align-items-center">
          <span class="badge bg-secondary" id="camStatus">No conectado</span>
          <small class="text-muted" id="camFps"></small>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card mb-2">
        <div class="card-header py-1"><small class="fw-semibold"><i class="bi bi-link"></i> Acceso directo</small></div>
        <div class="card-body py-2">
          <button class="btn btn-outline-success btn-sm w-100 mb-1" onclick="conectarCamara()"><i class="bi bi-play-btn"></i> Conectar cámara</button>
          <button class="btn btn-outline-primary btn-sm w-100 mb-1" onclick="abrirLocal()"><i class="bi bi-house-door"></i> Abrir iCam365 Player</button>
        </div>
      </div>
      <div class="card mb-2">
        <div class="card-header py-1"><small class="fw-semibold"><i class="bi bi-gear"></i> Configuración stream</small></div>
        <div class="card-body py-2">
          <div class="mb-1">
            <label class="small text-muted">URL del snapshot (HTTP/MJPEG)</label>
            <input type="text" id="inputStreamUrl" class="form-control form-control-sm" value="<%= streamUrl %>" placeholder="http://ip:puerto/snapshot.jpg">
          </div>
          <div class="mb-1">
            <label class="small text-muted">IP local</label>
            <input type="text" id="inputCamIp" class="form-control form-control-sm" value="<%= camIp %>">
          </div>
          <div class="mb-1">
            <label class="small text-muted">UID</label>
            <input type="text" id="inputCamUid" class="form-control form-control-sm" value="<%= camUid %>">
          </div>
          <button class="btn btn-sm btn-primary w-100" onclick="guardarConfig()"><i class="bi bi-save"></i> Guardar configuración</button>
        </div>
      </div>
      <div class="card">
        <div class="card-header py-1"><small class="fw-semibold"><i class="bi bi-info-circle"></i> Información</small></div>
        <div class="card-body py-2 small">
          <div class="mb-1"><strong>UID:</strong> <%= camUid %></div>
          <div class="mb-1"><strong>IP Local:</strong> <%= camIp %></div>
          <div class="mb-1"><strong>Estado:</strong> <span class="badge bg-success">Online</span></div>
          <hr class="my-1">
          <p class="text-muted mb-0" style="font-size:11px;">
            Para ver la cámara desde fuera de la red local, necesitas una URL pública de snapshot o MJPEG.<br>
            <strong>iCam365 Player</strong> usa conexión P2P y solo funciona en local.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
function abrirLocal() {
  try { window.location.href = 'icam365://'; } catch(e) {}
  alert('Abre iCam365 Player desde el escritorio o Inicio');
}

function conectarCamara() {
  var status = document.getElementById('camStatus');
  var placeholder = document.getElementById('cameraPlaceholder');
  var img = document.getElementById('camImage');
  var url = document.getElementById('inputStreamUrl').value.trim();

  if (!url) {
    status.textContent = 'No hay URL configurada';
    status.className = 'badge bg-warning';
    return;
  }

  status.textContent = 'Conectando...';
  status.className = 'badge bg-warning';

  var tryUrl = url + (url.indexOf('?') === -1 ? '?' : '&') + '_t=' + Date.now();

  img.onload = function() {
    placeholder.style.display = 'none';
    img.style.display = 'block';
    status.textContent = 'Conectado';
    status.className = 'badge bg-success';
    iniciarAutoRefresh(url);
  };

  img.onerror = function() {
    status.textContent = 'Error de conexión';
    status.className = 'badge bg-danger';
  };

  img.src = tryUrl;
}

var refreshTimer = null;
function iniciarAutoRefresh(baseUrl) {
  if (refreshTimer) clearInterval(refreshTimer);
  refreshTimer = setInterval(function() {
    var img = document.getElementById('camImage');
    img.src = baseUrl + (baseUrl.indexOf('?') === -1 ? '?' : '&') + '_t=' + Date.now();
  }, 2000);
}

function guardarConfig() {
  var streamUrl = document.getElementById('inputStreamUrl').value.trim();
  var camIp = document.getElementById('inputCamIp').value.trim();
  var camUid = document.getElementById('inputCamUid').value.trim();

  fetch('/camera/settings', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ stream_url: streamUrl, cam_ip: camIp, cam_uid: camUid })
  })
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.ok) alert('Configuración guardada');
  })
  .catch(function() { alert('Error al guardar'); });
}

if ('<%= streamUrl %>') {
  conectarCamara();
}
</script>
<style>
.card-body img { object-fit: contain; }
</style>
