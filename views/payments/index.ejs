<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="ri-wallet-line"></i> Pagos</h2>
  </div>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-warning"><%= error %></div><% } %>
  <div class="row g-3 mb-3">
    <a href="/payments" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle primary"><span>💳</span></div><div><div class="stat-value"><%= payments.length %></div><div class="stat-label">Total Pagos</div></div></div></div></a>
    <a href="/payments" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle success"><span>✅</span></div><div><div class="stat-value"><%= payments.filter(p => (p.status||'').toUpperCase() === 'COMPLETED' || (p.status||'').toUpperCase() === 'SUCCEEDED').length %></div><div class="stat-label">Completados</div></div></div></div></a>
    <a href="/payments" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle warning"><span>⏳</span></div><div><div class="stat-value"><%= payments.filter(p => (p.status||'').toUpperCase() === 'PENDING').length %></div><div class="stat-label">Pendientes</div></div></div></div></a>
    <a href="/payments" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle danger"><span>❌</span></div><div><div class="stat-value"><%= payments.filter(p => (p.status||'').toUpperCase() === 'FAILED').length %></div><div class="stat-label">Fallidos</div></div></div></div></a>
  </div>
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="card" style="cursor:pointer;" onclick="showPaymentDetail('status')">
        <div class="card-body">
          <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Estado de Pagos</h6>
          <div class="chart-wrapper" style="height:160px;overflow:hidden;"><canvas id="paymentStatusChart"></canvas></div>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card" style="cursor:pointer;" onclick="showPaymentDetail('method')">
        <div class="card-body">
          <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Pagos por Método</h6>
          <div class="chart-wrapper" style="height:160px;overflow:hidden;"><canvas id="paymentMethodChart"></canvas></div>
        </div>
      </div>
    </div>
  </div>
  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover">
          <thead><tr><th>Cliente</th><th>Concepto</th><th>Importe</th><th>Método</th><th>Estado</th><th>Fecha</th></tr></thead>
          <tbody>
            <% if (!payments || payments.length === 0) { %>
            <tr><td colspan="6" class="text-center text-muted py-4">No hay pagos</td></tr>
            <% } else { payments.forEach(p => {
              const st = (p.status||'').toUpperCase();
              const sc = st === 'COMPLETED' || st === 'SUCCEEDED' ? 'success' : st === 'PENDING' ? 'warning' : st === 'FAILED' ? 'danger' : 'secondary';
            %>
            <tr>
              <td><%= p.customerName || p.name || '-' %></td>
              <td><%= p.concept || p.descripcion || p.description || '-' %></td>
              <td><%= p.amount || p.importe ? (p.amount || p.importe) + '€' : '-' %></td>
              <td><%= p.method || p.metodo || p.paymentMethod || '-' %></td>
              <td><span class="badge bg-<%= sc %>"><%= st %></span></td>
              <td class="small"><%= p.date || p.fecha ? new Date(p.date || p.fecha).toLocaleDateString('es-ES') : '-' %></td>
            </tr>
            <% }); } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<div class="modal fade" id="paymentDetailModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title" id="payDetailTitle">Detalle</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body" id="payDetailBody"></div>
  </div></div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var paymentsData = <%- JSON.stringify(payments) %>;
  var completados = paymentsData.filter(function(p) { var s = (p.status||'').toUpperCase(); return s === 'COMPLETED' || s === 'SUCCEEDED'; }).length;
  var pendientes = paymentsData.filter(function(p) { return (p.status||'').toUpperCase() === 'PENDING'; }).length;
  var fallidos = paymentsData.filter(function(p) { return (p.status||'').toUpperCase() === 'FAILED'; }).length;

  new Chart(document.getElementById('paymentStatusChart'), {
    type: 'bar',
    data: {
      labels: ['Completados', 'Pendientes', 'Fallidos'],
      datasets: [{ label: 'Pagos', data: [completados, pendientes, fallidos], backgroundColor: ['#198754', '#ffc107', '#dc3545'], borderRadius: 6 }]
    },
    options: { responsive: true, maintainAspectRatio: false, animation: false, resizeDelay: 0, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } }
  });

  var methodCounts = {};
  paymentsData.forEach(function(p) {
    var m = p.method || p.metodo || p.paymentMethod || 'Otro';
    methodCounts[m] = (methodCounts[m] || 0) + 1;
  });
  var sortedMethods = Object.keys(methodCounts).sort(function(a, b) { return methodCounts[b] - methodCounts[a]; });
  var methodLabels = sortedMethods;
  var methodData = sortedMethods.map(function(m) { return methodCounts[m]; });

  new Chart(document.getElementById('paymentMethodChart'), {
    type: 'bar',
    data: {
      labels: methodLabels,
      datasets: [{ label: 'Pagos', data: methodData, backgroundColor: methodData.map(function(v, i) { return i > 0 && v < methodData[i-1] ? '#dc3545' : '#198754'; }), borderRadius: 6 }]
    },
    options: { responsive: true, maintainAspectRatio: false, animation: false, resizeDelay: 0, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } }
  });
});

function showPaymentDetail(type) {
  var title = '', body = '';
  if (type === 'status') {
    title = 'Estado de Pagos';
    var completados = paymentsData.filter(function(p) { var s = (p.status||'').toUpperCase(); return s === 'COMPLETED' || s === 'SUCCEEDED'; }).length;
    var pendientes = paymentsData.filter(function(p) { return (p.status||'').toUpperCase() === 'PENDING'; }).length;
    var fallidos = paymentsData.filter(function(p) { return (p.status||'').toUpperCase() === 'FAILED'; }).length;
    body = '<table class="table table-sm"><thead><tr><th>Estado</th><th>Cantidad</th></tr></thead><tbody>' +
      '<tr><td>Completados</td><td><strong>' + completados + '</strong></td></tr>' +
      '<tr><td>Pendientes</td><td><strong>' + pendientes + '</strong></td></tr>' +
      '<tr><td>Fallidos</td><td><strong>' + fallidos + '</strong></td></tr>' +
      '</tbody></table>';
  } else if (type === 'method') {
    title = 'Pagos por Método';
    var methodCounts = {};
    paymentsData.forEach(function(p) {
      var m = p.method || p.metodo || p.paymentMethod || 'Otro';
      methodCounts[m] = (methodCounts[m] || 0) + 1;
    });
    var rows = Object.keys(methodCounts).map(function(m) { return '<tr><td>' + m + '</td><td><strong>' + methodCounts[m] + '</strong></td></tr>'; }).join('');
    body = '<table class="table table-sm"><thead><tr><th>Método</th><th>Cantidad</th></tr></thead><tbody>' + rows + '</tbody></table>';
  }
  document.getElementById('payDetailTitle').textContent = title;
  document.getElementById('payDetailBody').innerHTML = body;
  var modal = new bootstrap.Modal(document.getElementById('paymentDetailModal'));
  modal.show();
}
</script>
