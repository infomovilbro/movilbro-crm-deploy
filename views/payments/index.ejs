<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="ri-wallet-line"></i> Pagos</h2>
  </div>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-warning"><%= error %></div><% } %>
  <div class="row g-3 mb-3">
    <a href="/payments" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card" style="background:#f8f9fa;border-left:3px solid var(--primary);border-radius:10px;padding:16px;"><div style="display:flex;align-items:center;gap:12px;"><span style="font-size:2rem;">💳</span><div><div class="stat-value" style="font-size:24px;font-weight:700;color:#222;"><%= payments.length %></div><div class="stat-label" style="font-size:13px;color:#6c757d;font-weight:500;">Total Pagos</div></div></div></div></a>
    <a href="/payments" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card" style="background:#f8f9fa;border-left:3px solid #28a745;border-radius:10px;padding:16px;"><div style="display:flex;align-items:center;gap:12px;"><span style="font-size:2rem;">✅</span><div><div class="stat-value" style="font-size:24px;font-weight:700;color:#222;"><%= payments.filter(p => (p.status||'').toUpperCase() === 'COMPLETED' || (p.status||'').toUpperCase() === 'SUCCEEDED').length %></div><div class="stat-label" style="font-size:13px;color:#6c757d;font-weight:500;">Completados</div></div></div></div></a>
    <a href="/payments" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card" style="background:#f8f9fa;border-left:3px solid #ffc107;border-radius:10px;padding:16px;"><div style="display:flex;align-items:center;gap:12px;"><span style="font-size:2rem;">⏳</span><div><div class="stat-value" style="font-size:24px;font-weight:700;color:#222;"><%= payments.filter(p => (p.status||'').toUpperCase() === 'PENDING').length %></div><div class="stat-label" style="font-size:13px;color:#6c757d;font-weight:500;">Pendientes</div></div></div></div></a>
    <a href="/payments" class="text-decoration-none col-md-3 col-6 stat-card-item"><div class="stat-card" style="background:#f8f9fa;border-left:3px solid #dc3545;border-radius:10px;padding:16px;"><div style="display:flex;align-items:center;gap:12px;"><span style="font-size:2rem;">❌</span><div><div class="stat-value" style="font-size:24px;font-weight:700;color:#222;"><%= payments.filter(p => (p.status||'').toUpperCase() === 'FAILED').length %></div><div class="stat-label" style="font-size:13px;color:#6c757d;font-weight:500;">Fallidos</div></div></div></div></a>
  </div>
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Estado de Pagos</h6>
        <canvas id="paymentStatusChart" style="height:221px;"></canvas>
      </div></div>
    </div>
    <div class="col-md-6">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Pagos por Método</h6>
        <canvas id="paymentMethodChart" style="height:221px;"></canvas>
      </div></div>
    </div>
  </div>
  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover">
          <thead><tr><th>Cliente</th><th>Concepto</th><th>Importe</th><th>Método</th><th>Estado</th><th>Fecha</th></tr></thead>
          <tbody>
            <% if (!payments || payments.length === 0) { %>
            <tr><td colspan="6" class="text-center text-muted py-4">No hay pagos</td></tr>
            <% } else { payments.forEach(p => { 
              const st = (p.status||'').toUpperCase();
              const sc = st === 'COMPLETED' || st === 'SUCCEEDED' ? 'success' : st === 'PENDING' ? 'warning' : st === 'FAILED' ? 'danger' : 'secondary';
            %>
            <tr>
              <td><%= p.customerName || p.name || '-' %></td>
              <td><%= p.concept || p.descripcion || p.description || '-' %></td>
              <td><%= p.amount || p.importe ? (p.amount || p.importe) + '€' : '-' %></td>
              <td><%= p.method || p.metodo || p.paymentMethod || '-' %></td>
              <td><span class="badge bg-<%= sc %>"><%= st %></span></td>
              <td class="small"><%= p.date || p.fecha ? new Date(p.date || p.fecha).toLocaleDateString('es-ES') : '-' %></td>
            </tr>
            <% }); } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<script>
var paymentsData = <%- JSON.stringify(payments) %>;
var completados = paymentsData.filter(function(p) { var s = (p.status||'').toUpperCase(); return s === 'COMPLETED' || s === 'SUCCEEDED'; }).length;
var pendientes = paymentsData.filter(function(p) { return (p.status||'').toUpperCase() === 'PENDING'; }).length;
var fallidos = paymentsData.filter(function(p) { return (p.status||'').toUpperCase() === 'FAILED'; }).length;

var ctx1 = document.getElementById('paymentStatusChart').getContext('2d');
new Chart(ctx1, {
  type: 'bar',
  data: {
    labels: ['Completados', 'Pendientes', 'Fallidos'],
    datasets: [{
      label: 'Pagos',
      data: [completados, pendientes, fallidos],
      backgroundColor: ['#198754', '#ffc107', '#dc3545'],
      borderRadius: 6
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } }
  }
});

var methodCounts = {};
paymentsData.forEach(function(p) {
  var m = p.method || p.metodo || p.paymentMethod || 'Otro';
  methodCounts[m] = (methodCounts[m] || 0) + 1;
});
var sortedMethods = Object.keys(methodCounts).sort(function(a, b) { return methodCounts[b] - methodCounts[a]; });
var methodLabels = sortedMethods;
var methodData = sortedMethods.map(function(m) { return methodCounts[m]; });

var ctx2 = document.getElementById('paymentMethodChart').getContext('2d');
new Chart(ctx2, {
  type: 'bar',
  data: {
    labels: methodLabels,
    datasets: [{
      label: 'Pagos',
      data: methodData,
      backgroundColor: methodData.map(function(v, i) { return i > 0 && v < methodData[i-1] ? '#dc3545' : '#198754'; }),
      borderRadius: 6
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } }
  }
});
</script>
</section>
