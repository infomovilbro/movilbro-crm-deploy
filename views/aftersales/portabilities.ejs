<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="ri-arrow-left-right-line"></i> Portabilidades</h2>
    <div>
      <button class="btn btn-sm btn-outline-secondary me-1" id="toggleStats" title="Mostrar/ocultar estadísticas"><i class="ri-bar-chart-2-line"></i></button>
      <a href="/altas" class="btn btn-primary btn-sm"><i class="ri-add-line"></i> Nueva Portabilidad</a>
    </div>
  </div>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-warning"><%= error %></div><% } %>

  <div class="row g-3 mb-3" id="statsRow">
    <div class="col-md-3 col-6"><div class="stat-card" data-filter="all"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle primary"><span>📊</span></div><div><div class="stat-value"><%= portabilities.length %></div><div class="stat-label">Total</div></div></div></div></div>
    <div class="col-md-3 col-6"><div class="stat-card" data-filter="entrantes"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle success"><span>📥</span></div><div><div class="stat-value"><%= portabilities.filter(p => (p.type||'').toUpperCase() === 'IN').length %></div><div class="stat-label">Entrantes</div></div></div></div></div>
    <div class="col-md-3 col-6"><div class="stat-card" data-filter="salientes"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle warning"><span>📤</span></div><div><div class="stat-value"><%= portabilities.filter(p => (p.type||'').toUpperCase() === 'OUT').length %></div><div class="stat-label">Salientes</div></div></div></div></div>
    <div class="col-md-3 col-6"><div class="stat-card" data-filter="error"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle danger"><span>❌</span></div><div><div class="stat-value"><%= portabilities.filter(p => (p.status||'').toUpperCase() === 'ERRORED').length %></div><div class="stat-label">Error</div></div></div></div></div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Portabilidades por Tipo</h6>
        <div class="chart-wrap" style="height:150px;overflow:hidden;position:relative;"><canvas id="chartTipo"></canvas></div>
        <div class="chart-legend mt-2 d-flex flex-wrap gap-3 justify-content-center" id="legend-chartTipo"></div>
      </div></div>
    </div>
    <div class="col-md-6">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Estado de Portabilidades</h6>
        <div class="chart-wrap" style="height:150px;overflow:hidden;position:relative;"><canvas id="chartEstadoPort"></canvas></div>
      </div></div>
    </div>
  </div>

  <div class="card hideable-section" data-card-id="portabilidades-tabla">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover">
          <thead><tr><th>Tipo</th><th>Cliente</th><th>Línea</th><th>Operador Donante</th><th>Estado</th><th>Fecha Portabilidad</th><th>ICC</th></tr></thead>
          <tbody>
            <% if (!portabilities || portabilities.length === 0) { %>
            <tr><td colspan="7" class="text-center text-muted py-4">No hay portabilidades</td></tr>
            <% } else { portabilities.forEach(p => { 
              const type = (p.type || '').toUpperCase();
              const status = (p.status || p.estado || '').toUpperCase();
              const typeLabel = type === 'IN' ? 'Entrante' : type === 'OUT' ? 'Saliente' : type;
              const typeColor = type === 'IN' ? 'success' : 'danger';
              const statusColor = status === 'COMPLETED' || status === 'COMPLETADA' ? 'success' : 
                                  status === 'INITIATED' || status === 'INICIADA' || status === 'PENDING' ? 'info' :
                                  status === 'ERRORED' || status === 'ERROR' ? 'danger' :
                                  status === 'CANCELED' || status === 'CANCELADA' ? 'secondary' : 'warning';
              const fv = [];
              if (type === 'IN') fv.push('entrantes');
              if (type === 'OUT') fv.push('salientes');
              if (status === 'ERRORED') fv.push('error');
            %>
            <tr data-filter-values="<%= fv.join(' ') %>">
              <td><span class="badge bg-<%= typeColor %>"><%= typeLabel %></span></td>
              <td><%= p.customerName || p.cliente_nombre || p.name || p.nombre || '-' %></td>
              <td><%= p.lineNumber || p.linea || p.phone || '-' %></td>
              <td><%= p.donorOperator || p.operador_donante || '-' %></td>
              <td><span class="badge bg-<%= statusColor %>"><%= status %></span></td>
              <td class="small"><%= p.portabilityDate || p.fecha ? new Date(p.portabilityDate || p.fecha).toLocaleDateString('es-ES') : '-' %></td>
              <td class="small"><%= p.icc || '-' %></td>
            </tr>
            <% }); } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<div class="modal fade" id="chartDetailModal" tabindex="-1">
  <div class="modal-dialog modal-lg"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title" id="chartDetailTitle"></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body p-0"><div class="table-responsive"><table class="table table-hover mb-0" id="chartDetailTable"><thead></thead><tbody></tbody></table></div></div>
    <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button></div>
  </div></div>
</div>

<script>
document.querySelectorAll('#statsRow .stat-card').forEach(function(c) {
  c.addEventListener('click', function() {
    var filter = this.getAttribute('data-filter');
    document.querySelectorAll('#statsRow .stat-card').forEach(function(x) { x.style.outline = ''; });
    if (filter !== 'all') this.style.outline = '2px solid #495057';
    document.querySelectorAll('table tbody tr').forEach(function(row) {
      if (filter === 'all') { row.style.display = ''; return; }
      if (!row.hasAttribute('data-filter-values')) { row.style.display = 'none'; return; }
      var vals = (row.getAttribute('data-filter-values') || '').split(' ');
      row.style.display = vals.indexOf(filter) !== -1 ? '' : 'none';
    });
  });
});
document.getElementById('toggleStats').addEventListener('click', function() {
  var r = document.getElementById('statsRow');
  r.style.display = r.style.display === 'none' ? '' : 'none';
});

document.addEventListener('DOMContentLoaded', function() {
  var portabilities = <%- JSON.stringify(portabilities) %>;
  if (!Array.isArray(portabilities)) portabilities = [];

  var entrantes = portabilities.filter(function(p){ return (p.type||'').toUpperCase() === 'IN'; }).length;
  var salientes = portabilities.filter(function(p){ return (p.type||'').toUpperCase() === 'OUT'; }).length;
  var chartTipo = new Chart(document.getElementById('chartTipo'), {
    type: 'doughnut',
    data: { labels: ['Entrantes','Salientes'], datasets: [{ data: [entrantes, salientes], backgroundColor: ['#198754','#dc3545'], borderWidth: 0 }] },
    options: { responsive: true, maintainAspectRatio: false, animation: false, resizeDelay: 0, cutout: '60%', plugins: { legend: { display: false }, tooltip: { enabled: true } }, onClick: function(e, elements) { if (elements.length > 0) showChartDetail(this, elements[0].index); } }
  });
  makeLegend(chartTipo, 'legend-chartTipo');

  var estCount = {}; portabilities.forEach(function(p){ var s = (p.status||p.estado||'desconocido').toUpperCase(); estCount[s] = (estCount[s]||0) + 1; });
  var chartEst = new Chart(document.getElementById('chartEstadoPort'), {
    type: 'bar',
    data: { labels: Object.keys(estCount), datasets: [{ label: 'Portabilidades', data: Object.values(estCount), backgroundColor: Object.keys(estCount).map(function(s){ return s==='COMPLETED'?'#198754':s==='PENDING'?'#ffc107':s==='ERRORED'?'#dc3545':s==='CANCELED'?'#6c757d':'#0d6efd'; }), borderRadius: 6 }] },
    options: { responsive: true, maintainAspectRatio: false, animation: false, resizeDelay: 0, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } }, onClick: function(e, elements) { if (elements.length > 0) showChartDetail(this, elements[0].index); } }
  });

  function makeLegend(chart, id) {
    var html = '', colors = chart.data.datasets[0].backgroundColor, data = chart.data.datasets[0].data;
    chart.data.labels.forEach(function(l, i) { var c = Array.isArray(colors) ? colors[i] : '#0d6efd'; html += '<span class="d-inline-flex align-items-center gap-1 small me-3"><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:'+c+';"></span> '+l+' ('+data[i]+')</span>'; });
    document.getElementById(id).innerHTML = html;
  }

  function showChartDetail(chart, idx) {
    var label = chart.data.labels[idx];
    var records;
    if (chart.canvas.id === 'chartTipo') {
      var tf = label === 'Entrantes' ? 'IN' : 'OUT';
      records = portabilities.filter(function(p){ return (p.type||'').toUpperCase() === tf; });
    } else {
      var sf = label;
      records = portabilities.filter(function(p){ return ((p.status||p.estado||'').toUpperCase()) === sf; });
    }
    var h = '<tr><th>Tipo</th><th>Cliente</th><th>Línea</th><th>Operador</th><th>Estado</th><th>Fecha</th></tr>';
    var b = '';
    records.forEach(function(p){ b += '<tr><td>'+(p.type||'-')+'</td><td>'+(p.customerName||p.name||'-')+'</td><td>'+(p.lineNumber||p.linea||'-')+'</td><td>'+(p.donorOperator||'-')+'</td><td>'+(p.status||p.estado||'-')+'</td><td>'+(p.portabilityDate||p.fecha?new Date(p.portabilityDate||p.fecha).toLocaleDateString('es-ES'):'-')+'</td></tr>'; });
    document.getElementById('chartDetailTitle').textContent = label + ' (' + records.length + ')';
    document.getElementById('chartDetailTable').querySelector('thead').innerHTML = h;
    document.getElementById('chartDetailTable').querySelector('tbody').innerHTML = b;
    new bootstrap.Modal(document.getElementById('chartDetailModal')).show();
  }
});
</script>
