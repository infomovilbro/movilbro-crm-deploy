<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="ri-truck-line"></i> Envíos</h2>
    <div>
      <button class="btn btn-sm btn-outline-secondary" id="toggleStats" title="Mostrar/ocultar estadísticas"><i class="ri-bar-chart-2-line"></i></button>
    </div>
  </div>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-warning"><%= error %></div><% } %>
  <% 
    const total = shipments.length;
    const completed = shipments.filter(s => (s.status||'').toUpperCase() === 'COMPLETED' || (s.status||'').toUpperCase() === 'DELIVERED').length;
    const inTransit = shipments.filter(s => (s.status||'').toUpperCase() === 'IN_DELIVERY' || (s.status||'').toUpperCase() === 'SENT').length;
    const pending = shipments.filter(s => (s.status||'').toUpperCase() === 'CREATED' || (s.status||'').toUpperCase() === 'PENDING').length;
    const errored = shipments.filter(s => (s.status||'').toUpperCase() === 'ERRORED').length;
    const canceled = shipments.filter(s => (s.status||'').toUpperCase() === 'CANCELED').length;
  %>
  <div class="row g-3 mb-3" id="statsRow">
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="all"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle primary"><span>📊</span></div><div><div class="stat-value"><%= total %></div><div class="stat-label">Total</div></div></div></div></div>
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="completados"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle success"><span>✅</span></div><div><div class="stat-value"><%= completed %></div><div class="stat-label">Completados</div></div></div></div></div>
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="transito"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle info"><span>🚚</span></div><div><div class="stat-value"><%= inTransit %></div><div class="stat-label">En tránsito</div></div></div></div></div>
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="pendientes"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle warning"><span>⏳</span></div><div><div class="stat-value"><%= pending %></div><div class="stat-label">Pendientes</div></div></div></div></div>
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="error"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle danger"><span>❌</span></div><div><div class="stat-value"><%= errored %></div><div class="stat-label">Error</div></div></div></div></div>
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="cancelados"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle secondary"><span>🚫</span></div><div><div class="stat-value"><%= canceled %></div><div class="stat-label">Cancelados</div></div></div></div></div>
  </div>
  <div class="row g-3 mb-4">
    <div class="col-md-12">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Estado de Envíos</h6>
        <canvas id="shipmentsStatus" style="height:221px;"></canvas>
      </div></div>
    </div>
  </div>
  <div class="card hideable-section" data-card-id="envios-tabla">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover">
          <thead><tr><th>Cliente</th><th>Dirección</th><th>Productos</th><th>Mensajería</th><th>Estado</th><th>Fecha</th><th></th></tr></thead>
          <tbody>
            <% if (!shipments || shipments.length === 0) { %>
            <tr><td colspan="7" class="text-center text-muted py-4">No hay envíos</td></tr>
            <% } else { shipments.forEach(s => { 
              const st = (s.status||'').toUpperCase();
              const sc = st === 'COMPLETED' || st === 'DELIVERED' ? 'success' : st === 'SENT' || st === 'IN_DELIVERY' ? 'info' : st === 'CREATED' ? 'warning' : st === 'ERRORED' ? 'danger' : st === 'CANCELED' ? 'secondary' : 'primary';
              const fv = [];
              if (st === 'COMPLETED' || st === 'DELIVERED') fv.push('completados');
              if (st === 'IN_DELIVERY' || st === 'SENT') fv.push('transito');
              if (st === 'CREATED' || st === 'PENDING') fv.push('pendientes');
              if (st === 'ERRORED') fv.push('error');
              if (st === 'CANCELED') fv.push('cancelados');
            %>
            <tr data-filter-values="<%= fv.join(' ') %>">
              <td><%= s.customer || s.customerName || s.name || '-' %></td>
              <td class="small"><%= s.address || s.direccion || '-' %></td>
              <td><%= s.products || s.productos || s.product || '-' %></td>
              <td><%= s.courier || s.mensajeria || '-' %></td>
              <td><span class="badge bg-<%= sc %>"><%= st %></span></td>
              <td class="small"><%= s.statusDate || s.fecha ? new Date(s.statusDate || s.fecha).toLocaleDateString('es-ES') : '-' %></td>
              <td><button class="btn btn-sm btn-outline-primary"><i class="ri-eye-line"></i></button></td>
            </tr>
            <% }); } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<script>
document.querySelectorAll('#statsRow .stat-card').forEach(function(c) {
  c.addEventListener('click', function() {
    var filter = this.getAttribute('data-filter');
    document.querySelectorAll('#statsRow .stat-card').forEach(function(x) { x.style.outline = ''; });
    if (filter !== 'all') this.style.outline = '2px solid #495057';
    document.querySelectorAll('table tbody tr').forEach(function(row) {
      if (filter === 'all') { row.style.display = ''; return; }
      if (!row.hasAttribute('data-filter-values')) { row.style.display = 'none'; return; }
      var vals = (row.getAttribute('data-filter-values') || '').split(' ');
      row.style.display = vals.indexOf(filter) !== -1 ? '' : 'none';
    });
  });
});
document.getElementById('toggleStats').addEventListener('click', function() {
  var r = document.getElementById('statsRow');
  r.style.display = r.style.display === 'none' ? '' : 'none';
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  new Chart(document.getElementById('shipmentsStatus'), {
    type: 'bar',
    data: {
      labels: ['Completados', 'En tránsito', 'Pendientes', 'Errores/Cancelados'],
      datasets: [{
        label: 'Envíos',
        data: [<%= completed %>, <%= inTransit %>, <%= pending %>, <%= errored + canceled %>],
        backgroundColor: ['#198754', '#0d6efd', '#ffc107', '#dc3545'],
        borderRadius: 6
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        y: { beginAtZero: true, grid: { color: '#eee' } },
        x: { grid: { display: false } }
      }
    }
  });
});
</script>
