<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="ri-router-line"></i> Penalizaciones Router</h2>
    <div>
      <button class="btn btn-sm btn-outline-secondary" id="toggleStats" title="Mostrar/ocultar estadísticas"><i class="ri-bar-chart-2-line"></i></button>
    </div>
  </div>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-warning"><%= error %></div><% } %>
  <% 
    const totalP = penalties.length;
    const pagadas = penalties.filter(p => (p.status||'').toUpperCase() === 'PAID' || (p.status||'').toUpperCase() === 'PAGADA').length;
    const pendientesP = penalties.filter(p => (p.status||'').toUpperCase() === 'PENDING' || (p.status||'').toUpperCase() === 'PENDIENTE').length;
    const canceladasP = penalties.filter(p => (p.status||'').toUpperCase() === 'CANCELED').length;
  %>
  <div class="row g-3 mb-3" id="statsRow">
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="all"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle primary"><span>📊</span></div><div><div class="stat-value"><%= totalP %></div><div class="stat-label">Total</div></div></div></div></div>
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="pagadas"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle success"><span>✅</span></div><div><div class="stat-value"><%= pagadas %></div><div class="stat-label">Pagadas</div></div></div></div></div>
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="pendientes"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle warning"><span>⏳</span></div><div><div class="stat-value"><%= pendientesP %></div><div class="stat-label">Pendientes</div></div></div></div></div>
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="canceladas"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle secondary"><span>🚫</span></div><div><div class="stat-value"><%= canceladasP %></div><div class="stat-label">Canceladas</div></div></div></div></div>
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="error"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle danger"><span>❌</span></div><div><div class="stat-value"><%= totalP - pagadas - pendientesP - canceladasP %></div><div class="stat-label">Error</div></div></div></div></div>
  </div>
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Penalizaciones por Estado</h6>
        <canvas id="chartPenEstado" style="height:221px;"></canvas>
      </div></div>
    </div>
    <div class="col-md-6">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Importe por Estado</h6>
        <canvas id="chartPenImporte" style="height:221px;"></canvas>
      </div></div>
    </div>
  </div>
  <div class="card hideable-section" data-card-id="penalizaciones-tabla">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover">
          <thead><tr><th>Cliente</th><th>Línea</th><th>Router</th><th>Penalización</th><th>Importe</th><th>Estado</th><th>Fecha</th></tr></thead>
          <tbody>
            <% if (!penalties || penalties.length === 0) { %>
            <tr><td colspan="7" class="text-center text-muted py-4">No hay penalizaciones</td></tr>
            <% } else { penalties.forEach(p => {
              const st = (p.status||'').toUpperCase();
              const sc = st === 'PAID' || st === 'PAGADA' ? 'success' : st === 'PENDING' || st === 'PENDIENTE' ? 'warning' : st === 'CANCELED' ? 'secondary' : 'danger';
              const fv = [];
              if (st === 'PAID' || st === 'PAGADA') fv.push('pagadas');
              if (st === 'PENDING' || st === 'PENDIENTE') fv.push('pendientes');
              if (st === 'CANCELED') fv.push('canceladas');
              if (!fv.length) fv.push('error');
            %>
            <tr data-filter-values="<%= fv.join(' ') %>">
              <td><%= p.customerName || p.name || '-' %></td>
              <td><%= p.lineNumber || p.linea || '-' %></td>
              <td><%= p.routerModel || p.router || '-' %></td>
              <td><%= p.description || p.descripcion || '-' %></td>
              <td><%= p.amount || p.importe ? (p.amount || p.importe) + '€' : '-' %></td>
              <td><span class="badge bg-<%= sc %>"><%= st %></span></td>
              <td class="small"><%= p.date || p.fecha ? new Date(p.date || p.fecha).toLocaleDateString('es-ES') : '-' %></td>
            </tr>
            <% }); } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<script>
document.querySelectorAll('#statsRow .stat-card').forEach(function(c) {
  c.addEventListener('click', function() {
    var filter = this.getAttribute('data-filter');
    document.querySelectorAll('#statsRow .stat-card').forEach(function(x) { x.style.outline = ''; });
    if (filter !== 'all') this.style.outline = '2px solid #495057';
    document.querySelectorAll('table tbody tr').forEach(function(row) {
      if (filter === 'all') { row.style.display = ''; return; }
      if (!row.hasAttribute('data-filter-values')) { row.style.display = 'none'; return; }
      var vals = (row.getAttribute('data-filter-values') || '').split(' ');
      row.style.display = vals.indexOf(filter) !== -1 ? '' : 'none';
    });
  });
});
document.getElementById('toggleStats').addEventListener('click', function() {
  var r = document.getElementById('statsRow');
  r.style.display = r.style.display === 'none' ? '' : 'none';
});

var pd = <%- JSON.stringify(penalties) %>;
var cpe = {}, cpi = {};
pd.forEach(function(x) {
  var k = (x.status || 'UNKNOWN').toUpperCase();
  cpe[k] = (cpe[k] || 0) + 1;
  cpi[k] = (cpi[k] || 0) + parseFloat(x.amount || x.importe || 0);
});
var lpe = Object.keys(cpe);
var cols = lpe.map(function(s) { return s === 'PAID' || s === 'PAGADA' ? '#198754' : s === 'PENDING' || s === 'PENDIENTE' ? '#ffc107' : s === 'CANCELED' ? '#dc3545' : '#6c757d'; });
new Chart(document.getElementById('chartPenEstado'), { type: 'bar', data: { labels: lpe, datasets: [{ label: 'Penalizaciones', data: Object.values(cpe), backgroundColor: cols, borderRadius: 6 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } } });
new Chart(document.getElementById('chartPenImporte'), { type: 'bar', data: { labels: lpe, datasets: [{ label: 'Importe (€)', data: Object.values(cpi), backgroundColor: cols, borderRadius: 6 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } } } });
</script>
