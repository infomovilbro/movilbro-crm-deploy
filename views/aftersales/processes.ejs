<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="ri-checkbox-multiple-blank-line"></i> Procesos Individuales</h2>
    <div>
      <button class="btn btn-sm btn-outline-secondary" id="toggleStats" title="Mostrar/ocultar estadísticas"><i class="ri-bar-chart-2-line"></i></button>
    </div>
  </div>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-warning"><%= error %></div><% } %>
  <% 
    const totalP = processes.length;
    const simChanges = processes.filter(p => (p.type||'').toUpperCase() === 'SIM_CHANGE').length;
    const prodChanges = processes.filter(p => (p.type||'').toUpperCase() === 'PRODUCT_CHANGE').length;
    const titularChanges = processes.filter(p => (p.type||'').toUpperCase() === 'TITULAR_CHANGE').length;
    const erroredP = processes.filter(p => (p.status||'').toUpperCase() === 'ERRORED').length;
  %>
  <div class="row g-3 mb-3" id="statsRow">
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="all"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle primary"><span>📊</span></div><div><div class="stat-value total-processes"><%= totalP %></div><div class="stat-label">Total</div></div></div></div></div>
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="sim"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle success"><span>📱</span></div><div><div class="stat-value"><%= simChanges %></div><div class="stat-label">Cambio SIM</div></div></div></div></div>
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="producto"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle warning"><span>🏷️</span></div><div><div class="stat-value"><%= prodChanges %></div><div class="stat-label">Cambio Producto</div></div></div></div></div>
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="titular"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle info"><span>👤</span></div><div><div class="stat-value"><%= titularChanges %></div><div class="stat-label">Cambio Titular</div></div></div></div></div>
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="error"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle danger"><span>❌</span></div><div><div class="stat-value"><%= erroredP %></div><div class="stat-label">Error</div></div></div></div></div>
    <div class="col-md-2 col-6"><div class="stat-card" data-filter="otros"><div class="d-flex align-items-center gap-3"><div class="stat-icon-circle secondary"><span>📌</span></div><div><div class="stat-value"><%= totalP - simChanges - prodChanges - titularChanges - erroredP %></div><div class="stat-label">Otros</div></div></div></div></div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Procesos por Tipo</h6>
        <div class="chart-wrap" style="height:150px;overflow:hidden;position:relative;"><canvas id="chartTipoProc"></canvas></div>
        <div class="chart-legend mt-2 d-flex flex-wrap gap-3 justify-content-center" id="legend-chartTipoProc"></div>
      </div></div>
    </div>
    <div class="col-md-6">
      <div class="card"><div class="card-body">
        <h6 class="card-title"><span style="font-size:1.2rem;">📊</span> Estado de Procesos</h6>
        <div class="chart-wrap" style="height:150px;overflow:hidden;position:relative;"><canvas id="chartEstadoProc"></canvas></div>
      </div></div>
    </div>
  </div>

  <div class="card hideable-section" data-card-id="procesos-tabla">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover">
          <thead><tr><th>Tipo</th><th>Cliente</th><th>Línea</th><th>Valor Anterior</th><th>Valor Nuevo</th><th>Estado</th><th>Fecha Cambio</th></tr></thead>
          <tbody>
            <% if (!processes || processes.length === 0) { %>
            <tr><td colspan="7" class="text-center text-muted py-4">No hay procesos</td></tr>
            <% } else { processes.forEach(p => { 
              const st = (p.status||'').toUpperCase();
              const sc = st === 'COMPLETED' ? 'success' : st === 'IN_PROGRESS' || st === 'PENDING' ? 'info' : st === 'ERRORED' ? 'danger' : st === 'CANCELED' ? 'secondary' : 'warning';
              const typeLabels = { SIM_CHANGE: 'Cambio SIM', PRODUCT_CHANGE: 'Cambio Producto', TITULAR_CHANGE: 'Cambio Titular', CREATE_SHARED_GROUP: 'Grupo Compartido', ADD_FIXED_IP: 'IP Fija', ADD_MULTISIM: 'MultiSIM', SMS_MASSIVE: 'SMS Masivo' };
              const pt = (p.type||'').toUpperCase();
              const fv = [];
              if (pt === 'SIM_CHANGE') fv.push('sim');
              if (pt === 'PRODUCT_CHANGE') fv.push('producto');
              if (pt === 'TITULAR_CHANGE') fv.push('titular');
              if (st === 'ERRORED') fv.push('error');
              if (!fv.length) fv.push('otros');
            %>
            <tr data-filter-values="<%= fv.join(' ') %>">
              <td><span class="badge bg-primary"><%= typeLabels[p.type] || p.type || '-' %></span></td>
              <td><%= p.customerName || p.name || '-' %></td>
              <td><%= p.lineNumber || p.linea || '-' %></td>
              <td class="small"><%= p.previousIcc || p.previous || p.anterior || '-' %></td>
              <td class="small"><%= p.actualProductName || p.newProduct || p.nuevo || '-' %></td>
              <td><span class="badge bg-<%= sc %>"><%= st %></span></td>
              <td class="small"><%= p.changeDate || p.fecha_cambio ? new Date(p.changeDate || p.fecha_cambio).toLocaleDateString('es-ES') : '-' %></td>
            </tr>
            <% }); } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<div class="modal fade" id="chartDetailModal" tabindex="-1">
  <div class="modal-dialog modal-lg"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title" id="chartDetailTitle"></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body p-0"><div class="table-responsive"><table class="table table-hover mb-0" id="chartDetailTable"><thead></thead><tbody></tbody></table></div></div>
    <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button></div>
  </div></div>
</div>

<script>
document.querySelectorAll('#statsRow .stat-card').forEach(function(c) {
  c.addEventListener('click', function() {
    var filter = this.getAttribute('data-filter');
    document.querySelectorAll('#statsRow .stat-card').forEach(function(x) { x.style.outline = ''; });
    if (filter !== 'all') this.style.outline = '2px solid #495057';
    document.querySelectorAll('table tbody tr').forEach(function(row) {
      if (filter === 'all') { row.style.display = ''; return; }
      if (!row.hasAttribute('data-filter-values')) { row.style.display = 'none'; return; }
      var vals = (row.getAttribute('data-filter-values') || '').split(' ');
      row.style.display = vals.indexOf(filter) !== -1 ? '' : 'none';
    });
  });
});
document.getElementById('toggleStats').addEventListener('click', function() {
  var r = document.getElementById('statsRow');
  r.style.display = r.style.display === 'none' ? '' : 'none';
});

document.addEventListener('DOMContentLoaded', function() {
  var typeLabelsMap = { SIM_CHANGE: 'Cambio SIM', PRODUCT_CHANGE: 'Cambio Producto', TITULAR_CHANGE: 'Cambio Titular', CREATE_SHARED_GROUP: 'Grupo Compartido', ADD_FIXED_IP: 'IP Fija', ADD_MULTISIM: 'MultiSIM', SMS_MASSIVE: 'SMS Masivo' };
  var processes = <%- JSON.stringify(processes) %>;
  if (!Array.isArray(processes)) processes = [];

  var tipoCount = {}; processes.forEach(function(p){ var t = (p.type||'OTRO').toUpperCase(); tipoCount[t] = (tipoCount[t]||0) + 1; });
  var tipoLabels = Object.keys(tipoCount).map(function(t){ return typeLabelsMap[t]||t; });
  var coloresTipo = ['#0d6efd','#198754','#ffc107','#dc3545','#6c757d','#17a2b8','#6610f2','#fd7e14'];
  var tipoData = Object.values(tipoCount);
  var tipoColors = coloresTipo.slice(0, tipoLabels.length);

  var chartTipo = new Chart(document.getElementById('chartTipoProc'), {
    type: 'doughnut',
    data: { labels: tipoLabels, datasets: [{ data: tipoData, backgroundColor: tipoColors, borderWidth: 0 }] },
    options: { responsive: true, maintainAspectRatio: false, animation: false, resizeDelay: 0, cutout: '60%', plugins: { legend: { display: false }, tooltip: { enabled: true } }, onClick: function(e, elements) { if (elements.length > 0) showChartDetail(this, elements[0].index); } }
  });
  makeLegend(chartTipo, 'legend-chartTipoProc');

  var statusCount = {}; processes.forEach(function(p){ var s = (p.status||'desconocido').toUpperCase(); statusCount[s] = (statusCount[s]||0) + 1; });
  var colorMap = { COMPLETED: '#198754', IN_PROGRESS: '#0d6efd', PENDING: '#ffc107', ERRORED: '#dc3545', CANCELED: '#6c757d' };
  var statusLabels = Object.keys(statusCount);
  new Chart(document.getElementById('chartEstadoProc'), {
    type: 'bar',
    data: { labels: statusLabels, datasets: [{ label: 'Procesos', data: Object.values(statusCount), backgroundColor: statusLabels.map(function(s){ return colorMap[s]||'#0d6efd'; }), borderRadius: 6 }] },
    options: { responsive: true, maintainAspectRatio: false, animation: false, resizeDelay: 0, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#eee' } }, x: { grid: { display: false } } }, onClick: function(e, elements) { if (elements.length > 0) showChartDetail(this, elements[0].index); } }
  });

  function makeLegend(chart, id) {
    var html = '', colors = chart.data.datasets[0].backgroundColor, data = chart.data.datasets[0].data;
    chart.data.labels.forEach(function(l, i) { var c = Array.isArray(colors) ? colors[i] : '#0d6efd'; html += '<span class="d-inline-flex align-items-center gap-1 small me-3"><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:'+c+';"></span> '+l+' ('+data[i]+')</span>'; });
    document.getElementById(id).innerHTML = html;
  }

  function showChartDetail(chart, idx) {
    var label = chart.data.labels[idx];
    var records;
    if (chart.canvas.id === 'chartTipoProc') {
      var typeKey = Object.keys(typeLabelsMap).find(function(k){ return typeLabelsMap[k] === label; }) || label;
      records = processes.filter(function(p){ return (p.type||'OTRO').toUpperCase() === typeKey; });
    } else {
      records = processes.filter(function(p){ return ((p.status||'desconocido').toUpperCase()) === label; });
    }
    var h = '<tr><th>Tipo</th><th>Cliente</th><th>Línea</th><th>Estado</th><th>Fecha</th></tr>';
    var b = '';
    records.forEach(function(p){ var tl = typeLabelsMap[p.type]||p.type||'-'; b += '<tr><td>'+tl+'</td><td>'+(p.customerName||p.name||'-')+'</td><td>'+(p.lineNumber||p.linea||'-')+'</td><td>'+(p.status||'-')+'</td><td>'+(p.changeDate||p.fecha_cambio?new Date(p.changeDate||p.fecha_cambio).toLocaleDateString('es-ES'):'-')+'</td></tr>'; });
    document.getElementById('chartDetailTitle').textContent = label + ' (' + records.length + ')';
    document.getElementById('chartDetailTable').querySelector('thead').innerHTML = h;
    document.getElementById('chartDetailTable').querySelector('tbody').innerHTML = b;
    new bootstrap.Modal(document.getElementById('chartDetailModal')).show();
  }
});
</script>
