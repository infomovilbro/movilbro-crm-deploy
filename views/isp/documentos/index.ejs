<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-files"></i> Documentos <span class="badge bg-secondary fs-6"><%= documentos.length %></span></h5>
  </div>
  <div class="card mb-3">
    <div class="card-header"><i class="bi bi-upload"></i> Subir Documento</div>
    <div class="card-body">
      <form method="POST" action="/isp/documentos/upload" enctype="multipart/form-data">
        <div class="row g-2 align-items-end">
          <div class="col-md-3">
            <label class="form-label">Archivo *</label>
            <input type="file" name="archivo" class="form-control form-control-sm" required>
          </div>
          <div class="col-md-2">
            <label class="form-label">Nombre</label>
            <input type="text" name="nombre" class="form-control form-control-sm" placeholder="Nombre del documento">
          </div>
          <div class="col-md-2">
            <label class="form-label">Tipo</label>
            <select name="tipo" class="form-select form-select-sm">
              <option value="pdf">PDF</option>
              <option value="imagen">Imagen</option>
              <option value="word">Word</option>
              <option value="excel">Excel</option>
              <option value="otro">Otro</option>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label">Categor&iacute;a</label>
            <select name="categoria" class="form-select form-select-sm">
              <option value="contrato">Contrato</option>
              <option value="factura">Factura</option>
              <option value="informe">Informe</option>
              <option value="tecnico">T&eacute;cnico</option>
              <option value="cliente">Cliente</option>
              <option value="otro">Otro</option>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label">Cliente</label>
            <select name="client_id" class="form-select form-select-sm">
              <option value="">Sin cliente</option>
              <% clientes.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.nombre %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-1">
            <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-cloud-upload"></i></button>
          </div>
        </div>
      </form>
    </div>
  </div>
  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle" id="documentosTable">
          <thead class="table-dark">
            <tr>
              <th>Nombre</th>
              <th>Tipo</th>
              <th>Categor&iacute;a</th>
              <th>Cliente</th>
              <th>Creaci&oacute;n</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (documentos.length === 0) { %>
            <tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-files"></i> No hay documentos subidos</td></tr>
            <% } else { %>
              <% documentos.forEach(d => { %>
              <tr>
                <td><%= d.nombre || d.archivo_original %></td>
                <td><span class="badge bg-secondary"><%= d.tipo %></span></td>
                <td><%= d.categoria || '-' %></td>
                <td><%= d.cliente_nombre || '-' %></td>
                <td class="small"><%= d.created_at ? new Date(d.created_at).toLocaleDateString('es-ES') : '-' %></td>
                <td class="text-end">
                  <a href="/isp/documentos/<%= d.id %>/download" class="btn btn-sm btn-outline-primary"><i class="bi bi-download"></i></a>
                  <button class="btn btn-sm btn-outline-danger" onclick="eliminarDocumento(<%= d.id %>)"><i class="bi bi-trash"></i></button>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
<script>
function eliminarDocumento(id) {
  if (!confirm('¿Eliminar este documento?')) return;
  fetch('/isp/documentos/' + id + '/delete', { method: 'POST' })
    .then(function(r) { return r.json(); })
    .then(function(d) { if (d.success) location.reload(); else alert('Error al eliminar'); })
    .catch(function() { alert('Error de conexi&oacute;n'); });
}
</script>
