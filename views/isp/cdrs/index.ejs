<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5><i class="bi bi-graph-up-arrow"></i> CDRs y Excedentes</h5>
    <div>
      <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalSubirCSV"><i class="bi bi-upload"></i> Importar CSV</button>
      <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modalNuevoCDR"><i class="bi bi-plus-lg"></i> Nuevo manual</button>
      <a href="/isp/cdrs/ejemplo" class="btn btn-outline-secondary btn-sm"><i class="bi bi-download"></i> CSV ejemplo</a>
    </div>
  </div>

  <div class="row g-2 mb-3">
    <div class="col-md-3"><div class="stat-card"><div class="stat-value"><%= total.c || 0 %></div><div class="stat-label">Excesos pendientes</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-value"><%= (total.t || 0).toFixed(2) %>€</div><div class="stat-label">Importe total pendiente</div></div></div>
  </div>

  <div class="card">
    <div class="card-body p-0">
      <div class="accordion" id="cdrAccordion">
        <% if (!groups || groups.length === 0) { %>
        <div class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><br>No hay CDRs registrados.<br>Sube un CSV con los consumos de los operadores o añádelos manualmente.</div>
        <% } else { groups.forEach(function(g, gi) { %>
        <div class="accordion-item">
          <h2 class="accordion-header">
            <button class="accordion-button collapsed py-2" type="button" data-bs-toggle="collapse" data-bs-target="#collapse<%= gi %>">
              <span class="fw-semibold"><%= g.cliente %></span>
              <span class="badge bg-secondary ms-2"><%= g.cdrs.length %></span>
              <span class="ms-2 small text-muted"><%= g.total.toFixed(2) %>€</span>
            </button>
          </h2>
          <div id="collapse<%= gi %>" class="accordion-collapse collapse" data-bs-parent="#cdrAccordion">
            <div class="accordion-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>#</th>
                      <th>Línea</th>
                      <th>Concepto</th>
                      <th>Tipo</th>
                      <th>Unidades</th>
                      <th>Importe</th>
                      <th>Periodo</th>
                      <th>Factura</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% g.cdrs.forEach(function(c) { %>
                    <tr style="cursor:pointer;" onclick="showCDRChart('<%= c.linea %>', '<%= c.concepto.replace(/'/g, "\\'") %>')">
                      <td><%= c.id %></td>
                      <td><code><%= c.linea || '-' %></code></td>
                      <td><%= c.concepto %></td>
                      <td><span class="badge bg-info"><%= c.tipo %></span></td>
                      <td><%= c.unidades ? c.unidades + ' ' + (c.tipo === 'exceso' ? 'GB' : c.tipo === 'sms' ? 'SMS' : 'min') : '-' %></td>
                      <td class="fw-bold"><%= parseFloat(c.importe).toFixed(2) %>€</td>
                      <td><%= c.periodo || '-' %></td>
                      <td><%= c.factura_id ? '#'+c.factura_id : '<span class="text-warning">Pendiente</span>' %></td>
                      <td class="text-end">
                        <button class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation();deleteCDR(<%= c.id %>)"><i class="bi bi-trash"></i></button>
                      </td>
                    </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
        <% }); } %>
      </div>
    </div>
  </div>
</section>

<!-- Chart Modal -->
<div class="modal fade" id="cdrChartModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-bar-chart-line"></i> Uso diario - <span id="cdrChartLinea" class="text-primary"></span></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <canvas id="cdrChartCanvas" height="220"></canvas>
        <div id="cdrChartEmpty" class="text-center text-muted py-4" style="display:none;">
          <i class="bi bi-inbox" style="font-size:2rem;"></i><br>No hay datos de uso diario para esta línea.
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal Subir CSV -->
<div class="modal" id="modalSubirCSV">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header"><h5>Importar CDRs desde CSV</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="POST" action="/isp/cdrs/import" enctype="multipart/form-data">
      <div class="modal-body">
        <p class="text-muted">Formato CSV: <code>fiscalId,linea,concepto,tipo,importe,unidades,periodo</code></p>
        <p class="small"><a href="/isp/cdrs/ejemplo">Descargar ejemplo CSV</a></p>
        <input type="file" name="csv" class="form-control" accept=".csv" required>
      </div>
      <div class="modal-footer"><button type="submit" class="btn btn-primary">Importar</button></div>
    </form>
  </div></div>
</div>

<!-- Modal Nuevo CDR Manual -->
<div class="modal" id="modalNuevoCDR">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header"><h5>Añadir excedente manual</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="POST" action="/isp/cdrs/create">
      <div class="modal-body">
        <div class="mb-2">
          <label class="form-label">Cliente (fiscalId)</label>
          <select name="fiscal_id" class="form-select">
            <option value="">Seleccionar cliente</option>
            <% clientes.forEach(function(c) { %>
            <option value="<%= c.likes_customer_id %>"><%= c.nombre %> (<%= c.likes_customer_id %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="mb-2">
          <label class="form-label">Línea</label>
          <input type="text" name="linea" class="form-control" placeholder="633879873">
        </div>
        <div class="mb-2">
          <label class="form-label">Concepto</label>
          <input type="text" name="concepto" class="form-control" placeholder="GB extra, llamadas internacionales..." required>
        </div>
        <div class="row g-2">
          <div class="col-4">
            <label class="form-label">Tipo</label>
            <select name="tipo" class="form-select">
              <option value="exceso">Exceso</option>
              <option value="llamadas">Llamadas</option>
              <option value="sms">SMS</option>
              <option value="otros">Otros</option>
            </select>
          </div>
          <div class="col-4">
            <label class="form-label">Unidades</label>
            <input type="number" step="0.01" name="unidades" class="form-control" placeholder="0">
          </div>
          <div class="col-4">
            <label class="form-label">Importe (€)</label>
            <input type="number" step="0.01" name="importe" class="form-control" required>
          </div>
        </div>
        <div class="mb-2 mt-2">
          <label class="form-label">Periodo</label>
          <input type="month" name="periodo" class="form-control" value="<%= new Date().toISOString().split('T')[0].substring(0,7) %>">
        </div>
      </div>
      <div class="modal-footer"><button type="submit" class="btn btn-primary">Guardar</button></div>
    </form>
  </div></div>
</div>

<div class="alert alert-info py-2 mb-3 small" id="cdrSyncStatus" style="display:none;">
  <i class="bi bi-arrow-repeat me-1"></i> <span id="cdrSyncText">Sincronizando...</span>
</div>

<script>
var cdrChartInstance = null;

function showCDRChart(linea, concepto) {
  document.getElementById('cdrChartLinea').textContent = linea + (concepto ? ' - ' + concepto : '');
  document.getElementById('cdrChartEmpty').style.display = 'none';
  document.getElementById('cdrChartCanvas').style.display = '';
  var modal = new bootstrap.Modal(document.getElementById('cdrChartModal'));
  modal.show();

  fetch('/isp/cdrs/daily/' + encodeURIComponent(linea))
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (!d.ok || !d.data || d.data.length === 0) {
        document.getElementById('cdrChartCanvas').style.display = 'none';
        document.getElementById('cdrChartEmpty').style.display = '';
        return;
      }
      var data = d.data;
      var labels, minutos, datos, sms;
      if (d.source === 'db') {
        labels = data.map(function(i) { return i.periodo; });
        var excesos = data.filter(function(i) { return i.tipo === 'exceso'; }).map(function(i) { return i.unidades || 0; });
        var llamadas = data.filter(function(i) { return i.tipo === 'llamadas'; }).map(function(i) { return i.unidades || 0; });
        var smsArr = data.filter(function(i) { return i.tipo === 'sms'; }).map(function(i) { return i.unidades || 0; });
        renderChart(labels, excesos, llamadas, smsArr);
      } else {
        labels = data.map(function(i) { return i.date || i.fecha || i.periodo || ''; });
        minutos = data.map(function(i) { return parseFloat(i.minutes || i.minutos || i.voiceDuration || 0); });
        datos = data.map(function(i) { return parseFloat(i.data || i.gb || i.dataUsage || 0); });
        sms = data.map(function(i) { return parseFloat(i.sms || i.smsCount || 0); });
        renderChart(labels, datos, minutos, sms);
      }
    })
    .catch(function() {
      document.getElementById('cdrChartCanvas').style.display = 'none';
      document.getElementById('cdrChartEmpty').style.display = '';
    });
}

function renderChart(labels, data1, data2, data3) {
  var ctx = document.getElementById('cdrChartCanvas').getContext('2d');
  if (cdrChartInstance) cdrChartInstance.destroy();
  cdrChartInstance = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [
        { label: 'Datos (GB)', data: data1, backgroundColor: 'rgba(13, 110, 253, 0.6)', borderRadius: 4 },
        { label: 'Minutos', data: data2, backgroundColor: 'rgba(40, 167, 69, 0.6)', borderRadius: 4 },
        { label: 'SMS', data: data3, backgroundColor: 'rgba(255, 193, 7, 0.6)', borderRadius: 4 }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { position: 'top', labels: { boxWidth: 12, padding: 8 } } },
      scales: { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } }, x: { grid: { display: false } } }
    }
  });
}

function deleteCDR(id) {
  if (!confirm('¿Eliminar este CDR?')) return;
  fetch('/isp/cdrs/delete', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({id:id}) })
  .then(function(r){return r.json();})
  .then(function(d){if(d.ok)location.reload();else alert('Error: '+d.error);})
  .catch(function(){alert('Error de conexión');});
}

var cdrSyncStatus = document.getElementById('cdrSyncStatus');
var cdrSyncText = document.getElementById('cdrSyncText');
if (cdrSyncStatus) {
  fetch('/sync-status')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.status === 'running') {
        cdrSyncStatus.style.display = '';
        cdrSyncText.textContent = data.step || 'Sincronizando...';
      } else {
        cdrSyncStatus.style.display = 'none';
      }
    })
    .catch(function() {});
}
</script>
