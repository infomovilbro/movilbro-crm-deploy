<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-file-earmark-bar-graph"></i> Listados y Reportes</h2>
  </div>
  <div class="row g-3">
    <% if (listados.length === 0) { %>
    <div class="col-12"><div class="alert alert-info text-center">No hay listados configurados</div></div>
    <% } else { %>
      <% listados.forEach(function(l) { %>
      <div class="col-md-4 col-6">
        <div class="card h-100 isp-menu-card">
          <a href="<%= l.ruta || '#' %>" class="text-decoration-none text-dark">
            <div class="card-body text-center py-4">
              <span style="font-size:2.5rem;">
                <%= l.tipo === 'contratos' ? '📄' : l.tipo === 'portabilidades' ? '🔄' : l.tipo === 'incidencias' ? '⚠️' : l.tipo === 'tareas' ? '📋' : l.tipo === 'facturacion' || l.tipo === 'facturación' ? '🧾' : l.tipo === 'clientes' ? '👤' : l.tipo === 'caja' ? '💰' : l.tipo === 'stock' || l.tipo === 'articulos' ? '📦' : l.tipo === 'tarifas' ? '🏷️' : l.tipo === 'vencimientos' ? '⏰' : l.tipo === 'ingresos' ? '📈' : l.tipo === 'gastos' ? '💸' : '📊' %>
              </span>
              <h6 class="mt-2 fw-semibold"><%= l.titulo %></h6>
              <span class="badge bg-secondary"><%= l.tipo %></span>
              <% if (l.categoria) { %>
              <span class="badge bg-info ms-1"><%= l.categoria %></span>
              <% } %>
            </div>
          </a>
        </div>
      </div>
      <% }) %>
    <% } %>
  </div>
</section>
