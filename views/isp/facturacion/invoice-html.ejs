<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Factura <%= (factura.serie || 'F') + '-' + String(factura.numero_factura || factura.id).padStart(5, '0') %> - <%= factura.cliente_nombre %></title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Lucida Sans Unicode', 'Lucida Grande', sans-serif; font-size: 12px; background: #fff; color: #000; }
.page { width: 210mm; margin: 0 auto; padding: 15mm 10mm; }
table { border-collapse: collapse; }
#tabla_resumen tr:nth-child(even) { background-color: #f2f2f2; }
@media print { .page { padding: 10mm 8mm; } }
</style>
</head>
<body>
<%
var ivaRate = 0.21;
var base = Number(factura.importe_base || 0);
var cdrs = Number(factura.importe_cdrs || 0);
var total = Number(factura.importe_total || 0);
var baseTotal = base + cdrs;
var iva = total - baseTotal;
var todasLineas = lineas; // Show ALL line items including CDRs
var months = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
var periodParts = (factura.periodo || '').split('-');
var monthName = periodParts[1] ? months[parseInt(periodParts[1]) - 1] : '';
var yearName = periodParts[0] || '';
var facturaNum = (factura.serie || 'F') + '-' + String(factura.numero_factura || factura.id).padStart(5, '0');
var fmt = function(n) { return Number(n || 0).toFixed(2).replace('.', ','); };
%>

<div class="page">
<div style="width:100%">
<span style="font-size:14px;">
<span style="font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;">
<img alt="" border="0" height="70" hspace="0" src="https://movilbro.ispgestion.com/documentos/open?doc=/PUBLICA/logo%20factura%20(3).png" style="float:left;margin-right:15px;">
</span>
</span>
<div style="float:right;width:40%">
<table style="width:100%;border-bottom:1px solid black">
<tbody>
<tr>
<td>
<p style="font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;font-size:14px;">Movilbro SL</p>
<p style="font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;font-size:14px;">C/ San Ricardo 17</p>
<p style="font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;font-size:14px;">29540, Antequera</p>
<p style="font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;font-size:14px;">Cif:B75559955</p>
<p style="font-size:10px;"><strong>N&uacute;m. de Factura: <%= facturaNum %></strong></p>
</td>
</tr>
<tr>
<td><span style="font-size:10px;"><strong>Fecha Factura: <%= factura.fecha_emision ? new Date(factura.fecha_emision).toLocaleDateString('es-ES') : '-' %></strong></span></td>
</tr>
</tbody>
</table>
</div>
<div style="clear:both;"></div>
</div>

<div style="width:100%;font-size:9px;color:#888;padding:3px 0;border-bottom:1px solid #ddd;">
<span style="color:#666;font-weight:600;">ATENCI&Oacute;N AL CLIENTE</span>
&nbsp;&nbsp;www.movilbro.es | facturacion@movilbro.com | 694297048 | @movilbro
</div>

<p style="text-align:center;font-size:9px;color:#999;margin:4px 0 8px;">P&aacute;gina 1 de<%= cdrsDetalle && cdrsDetalle.length > 0 ? ' 2' : ' 1' %></p>

<div style="width:100%"><span style="font-size:16px;"><strong><span style="color:#808080">TU FACTURA DE </span><span style="color:#3498db;"><%= monthName %> <%= yearName %></span></strong></span></div>
<div style="width:100%"><span style="font-size:14px;"><strong><span style="color:#808080">TOTAL A PAGAR</span> <span style="color:#3498db;"> <%= fmt(total) %> &euro; </span></strong></span></div>

<p>&nbsp;</p>

<div style="width:100%">
<div style="width:58%;float:left">
<table cellspacing="3" style="width:100%;">
<tbody>
<tr><td style="color:#808080"><span style="font-size:11px;">TITULAR</span></td><td><span style="font-size:11px;"><strong><%= factura.cliente_nombre || '-' %></strong></span></td></tr>
<tr><td style="color:#808080"><span style="font-size:11px;">NIF / NIE / CIF</span></td><td><span style="font-size:11px;"><strong><%= factura.fiscal_id || '-' %></strong></span></td></tr>
<tr><td style="color:#808080"><span style="font-size:11px;">N&ordm; FACTURA</span></td><td><span style="font-size:11px;"><strong><%= facturaNum %></strong></span></td></tr>
<tr><td style="color:#808080"><span style="font-size:11px;">FECHA FACTURA</span></td><td><span style="font-size:11px;"><strong><%= factura.fecha_emision ? new Date(factura.fecha_emision).toLocaleDateString('es-ES') : '-' %></strong></span></td></tr>
<tr><td style="color:#808080"><span style="font-size:11px;">FECHA VENCIMIENTO</span></td><td><span style="font-size:11px;"><strong><%= factura.fecha_vencimiento ? new Date(factura.fecha_vencimiento).toLocaleDateString('es-ES') : '-' %></strong></span></td></tr>
<tr><td style="color:#808080"><span style="font-size:11px;">ENTIDAD</span></td><td><span style="font-size:11px;"><strong><%= factura.metodo_pago === 'domiciliacion' ? 'BANCO BILBAO VIZCAYA ARGENTARIA, S.A.' : (factura.metodo_pago === 'stripe' ? 'STRIPE' : (factura.metodo_pago || '-')) %></strong></span></td></tr>
<tr><td style="color:#808080"><span style="font-size:11px;">CUENTA / IBAN</span></td><td><span style="font-size:11px;"><strong><%= factura.metodo_pago === 'stripe' ? 'Pago con tarjeta' : (factura.iban || '-') %></strong></span></td></tr>
<tr><td style="color:#808080"><span style="font-size:11px;">PERIODO</span></td><td><span style="font-size:11px;"><strong><%= factura.periodo || '-' %></strong></span></td></tr>
</tbody>
</table>
</div>
<div style="width:40%;float:right">
<table cellspacing="3" style="width:100%;">
<tbody>
<tr><td><span style="color:#3498db;font-size:14px;font-weight:bold;"><%= factura.cliente_nombre || '-' %></span></td></tr>
<tr><td>&nbsp;</td></tr>
<tr><td><span style="font-size:12px;"><%= factura.cliente_direccion || '' %></span></td></tr>
<tr><td><span style="font-size:12px;"><%= factura.cliente_poblacion || '' %> <%= factura.cliente_provincia || '' %></span></td></tr>
</tbody>
</table>
</div>
<div style="clear:both;"></div>
</div>

<p>&nbsp;</p>

<div style="width:100%;color:#808080"><strong><span style="font-size:16px;">RESUMEN DE TU FACTURA</span></strong></div>
<p>&nbsp;</p>

<div style="width:100%">
<table id="tabla_resumen" style="width:100%;border-collapse:collapse;border-bottom:1px solid black">
<tbody>
<tr>
<td style="width:80%;border-bottom:1px solid black;text-align:center;"><span style="font-size:12px;"><strong>CONCEPTO</strong></span></td>
<td style="width:20%;border-bottom:1px solid black;text-align:right;"><strong>IMPORTE</strong></td>
</tr>
<% todasLineas.forEach(function(l) { %>
<tr>
<td style="width:80%;"><span style="font-size:12px;"><%= l.concepto || '-' %><%= l.linea ? ' ' + l.linea : '' %></span></td>
<td style="width:20%;text-align:right;"><span style="font-size:12px;"><%= fmt(l.importe) %> &euro;</span></td>
</tr>
<% }) %>
</tbody>
</table>

<div style="width:100%;text-align:right"><span style="font-size:12px;"><strong>TOTAL CUOTAS TARIFAS Y CONSUMOS <%= fmt(baseTotal) %> &euro;</strong></span></div>
</div>

<p>&nbsp;</p>

<div style="width:100%">
<div style="width:40%;margin-left:5%;float:left;border:1px solid #ccc;padding:5px;text-align:center;font-size:9px;color:#888;">
<strong style="font-size:10px;color:#555;">Hist&oacute;rico de pagos</strong><br>
<% if (history && history.length > 0) { history.forEach(function(h, i) { %>
<%= h.periodo ? h.periodo.substring(5) + '/' + h.periodo.substring(0,4) : '' %> <%= fmt(h.total) %> &euro;<%= i < history.length - 1 ? ' | ' : '' %>
<% }); } else { %>
Sin historial
<% } %>
</div>
<div style="width:45%;float:right">
<table style="width:100%;border-top:1px solid black;border-collapse:collapse">
<tr><td><span style="font-size:12px;">Base Imponible</span></td><td style="text-align:right;"><span style="font-size:12px;"><%= fmt(baseTotal) %> &euro;</span></td></tr>
<tr><td><span style="font-size:12px;">Impuestos (IVA <%= (ivaRate * 100).toFixed(0) %>%)</span></td><td style="text-align:right;"><span style="font-size:12px;"><%= fmt(iva) %> &euro;</span></td></tr>
<tr><td style="border-bottom:1px solid black"><strong><span style="font-size:12px;">Total Factura</span></strong></td><td style="border-bottom:1px solid black;text-align:right;"><strong><span style="font-size:12px;"><%= fmt(total) %> &euro;</span></strong></td></tr>
<tr><td><span style="color:#3498db;font-size:14px;font-weight:bold;">TOTAL A PAGAR</span></td><td style="text-align:right;"><span style="color:#3498db;font-size:14px;font-weight:bold;"><%= fmt(total) %> &euro;</span></td></tr>
</table>
</div>
<div style="clear:both;"></div>
</div>

<p>&nbsp;</p>
<hr style="color:black" />

<div style="width:100%">
<div style="width:48%;float:left">
<table style="width:100%">
<tbody>
<tr><td><strong><span style="font-size:12px;">ATENCI&Oacute;N AL CLIENTE</span></strong></td></tr>
<tr><td>&nbsp;</td></tr>
<tr><td><span style="font-size:12px;">Entra en www.movilbro.es</span></td></tr>
<tr><td><span style="font-size:12px;">o escr&iacute;benos a facturacion@movilbro.com</span></td></tr>
<tr><td><span style="font-size:12px;">o ll&aacute;manos al 694297048, de lunes a viernes, de 9:00 a 19:00h</span></td></tr>
<tr><td><span style="font-size:12px;">o Facebook @movilbro</span></td></tr>
<tr><td><span style="font-size:12px;">o Instagram @movilbro</span></td></tr>
</tbody>
</table>
</div>
</div>

<div style="width:100%;text-align:right;"><span style="font-size:10px;">P&aacute;gina 1 de<%= cdrsDetalle && cdrsDetalle.length > 0 ? ' 2' : ' 1' %></span></div>
</div>

<% if (cdrsDetalle && cdrsDetalle.length > 0) { %>
<div class="page" style="page-break-before:always">

<div style="width:100%">
<div style="float:right;width:40%">
<table style="width:100%;border-bottom:1px solid black">
<tbody>
<tr><td><p style="font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;font-size:14px;">Movilbro SL</p><p style="font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;font-size:14px;">C/ San Ricardo 17</p><p style="font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;font-size:14px;">29540, Antequera</p><p style="font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;font-size:14px;">Cif:B75559955</p><p style="font-size:10px;"><strong><%= facturaNum %></strong></p></td></tr>
<tr><td><span style="font-size:10px;"><strong>Fecha Factura: <%= factura.fecha_emision ? new Date(factura.fecha_emision).toLocaleDateString('es-ES') : '-' %></strong></span></td></tr>
</tbody>
</table>
</div>
<div style="clear:both;"></div>
</div>

<p style="text-align:center;font-size:10px;color:#999;">P&aacute;gina 2 de 2</p>

<div style="border:thin solid #ccc;padding:10px 30px;box-shadow:4px 4px 8px 1px #ddd;">
<div style="background-color:#ccc;font-weight:bold;padding:0.5px 10px;"><span style="font-size:12px;"><strong>Datos del cliente</strong></span></div>
<p><strong>Nombre</strong> <%= factura.cliente_nombre || '-' %></p>
<p><strong>Direcci&oacute;n</strong> <%= factura.cliente_direccion || factura.cliente_nombre || '' %></p>
<p><strong>Contacto</strong> Tel&eacute;fono/s &nbsp;&nbsp; E-mail</p>
<p><%= (cdrsDetalle[0] && cdrsDetalle[0].linea) || '' %> &nbsp;&nbsp;&nbsp;&nbsp; <%= factura.cliente_email || '' %></p>
</div>

<p>&nbsp;</p>

<div style="border:thin solid #ccc;padding:10px 30px;box-shadow:4px 4px 8px 1px #ddd;">
<div style="background-color:#ccc;font-weight:bold;padding:0.5px 10px;"><span style="font-size:12px;"><strong>Resumen de consumo - L&iacute;nea <%= (cdrsDetalle[0] && cdrsDetalle[0].linea) || '' %></strong></span></div>
<p>&nbsp;</p>
<% var grupos = {}; %>
<% cdrsDetalle.forEach(function(c) { var g = c.tipo || 'Otros'; if (!grupos[g]) grupos[g] = { count: 0, importe: 0, duracion: '', unidades: 0 }; grupos[g].count++; grupos[g].importe += Number(c.importe || 0); if (c.unidades) { grupos[g].unidades += Number(c.unidades); grupos[g].duracion = c.tipo === 'exceso' ? Number(c.unidades).toFixed(0) + ' Mb' : c.unidades + ' min'; } }); %>
<table border="0" cellpadding="3" cellspacing="1" style="width:100%;font-size:11px;">
<tr>
<td style="width:30%;"><strong>Grupo</strong></td>
<td style="width:20%;text-align:right;"><strong>N&ordm; Llamadas</strong></td>
<td style="width:30%;text-align:right;"><strong>Duraci&oacute;n</strong></td>
<td style="width:20%;text-align:right;"><strong>Importe</strong></td>
</tr>
<% Object.keys(grupos).forEach(function(g) { %>
<tr>
<td><%= g === 'exceso' ? 'DATOS M\u00d3VILES' : g === 'llamadas' ? 'MOVILES NACIONALES' : g %></td>
<td style="text-align:right;"><%= grupos[g].count %></td>
<td style="text-align:right;"><%= grupos[g].duracion || '-' %></td>
<td style="text-align:right;"><%= fmt(grupos[g].importe) %>&euro;</td>
</tr>
<% }); %>
</table>
</div>

<p>&nbsp;</p>

<div style="border:thin solid #ccc;padding:10px 30px;box-shadow:4px 4px 8px 1px #ddd;">
<div style="background-color:#ccc;font-weight:bold;padding:0.5px 10px;"><span style="font-size:12px;"><strong>Detalle de llamadas de la l&iacute;nea <%= (cdrsDetalle[0] && cdrsDetalle[0].linea) || '' %> desde 01/<%= periodParts[1] || '' %>/<%= periodParts[0] || '' %> hasta 31/<%= periodParts[1] || '' %>/<%= periodParts[0] || '' %></strong></span></div>
<p>&nbsp;</p>
<table style="width:100%;border-collapse:collapse;font-size:8px;">
<thead>
<tr>
<td style="border:1px solid #ADAAA9;padding:2px;"><strong>Fecha</strong></td>
<td style="border:1px solid #ADAAA9;padding:2px;"><strong>Hora</strong></td>
<td style="border:1px solid #ADAAA9;padding:2px;"><strong>Destino</strong></td>
<td style="border:1px solid #ADAAA9;padding:2px;text-align:right;"><strong>Duraci&oacute;n</strong></td>
<td style="border:1px solid #ADAAA9;padding:2px;text-align:right;"><strong>Importe</strong></td>
</tr>
</thead>
<tbody>
<% var cdrTotal = 0; %>
<% cdrsDetalle.forEach(function(c) { cdrTotal += Number(c.importe || 0); %>
<tr>
<td style="border:1px solid #ADAAA9;padding:1px 2px;"><%= c.concepto ? c.concepto.substring(0,10) : '-' %></td>
<td style="border:1px solid #ADAAA9;padding:1px 2px;">-</td>
<td style="border:1px solid #ADAAA9;padding:1px 2px;"><%= c.linea || '-' %></td>
<td style="border:1px solid #ADAAA9;padding:1px 2px;text-align:right;"><%= c.unidades ? (c.tipo === 'exceso' ? Number(c.unidades).toFixed(0) + ' Mb' : c.unidades + ' min') : '-' %></td>
<td style="border:1px solid #ADAAA9;padding:1px 2px;text-align:right;"><%= fmt(c.importe) %> &euro;</td>
</tr>
<% }); %>
</tbody>
</table>
</div>

<div style="width:100%;text-align:right;margin-top:20px;"><span style="font-size:10px;">P&aacute;gina 2 de 2</span></div>
</div>
<% } %>
</body>
</html>