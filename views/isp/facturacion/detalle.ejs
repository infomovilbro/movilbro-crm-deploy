<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-receipt-cutoff"></i> Factura <%= (factura.serie || 'F') + '-' + String(factura.numero_factura || factura.id).padStart(5, '0') %></h2>
    <a href="/isp/facturacion/facturas" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Volver</a>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-8">
      <div class="card h-100">
        <div class="card-header"><i class="bi bi-info-circle"></i> Datos de la Factura</div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-4">
              <small class="text-muted d-block">Nº Factura</small>
              <span class="fw-bold"><%= (factura.serie || 'F') + '-' + String(factura.numero_factura || factura.id).padStart(5, '0') %></span>
            </div>
            <div class="col-md-4">
              <small class="text-muted d-block">Cliente</small>
              <span class="fw-bold"><%= factura.cliente_nombre || '-' %></span>
            </div>
            <div class="col-md-4">
              <small class="text-muted d-block">Email</small>
              <span><%= factura.cliente_email || '-' %></span>
            </div>
            <div class="col-md-4">
              <small class="text-muted d-block">Periodo</small>
              <span><%= factura.periodo || '-' %></span>
            </div>
            <div class="col-md-4">
              <small class="text-muted d-block">Fecha Emisión</small>
              <span><%= factura.fecha_emision ? new Date(factura.fecha_emision).toLocaleDateString('es-ES') : '-' %></span>
            </div>
            <div class="col-md-4">
              <small class="text-muted d-block">Fecha Vencimiento</small>
              <span><%= factura.fecha_vencimiento ? new Date(factura.fecha_vencimiento).toLocaleDateString('es-ES') : '-' %></span>
            </div>
            <div class="col-md-4">
              <small class="text-muted d-block">Método Pago</small>
              <span><%= factura.metodo_pago || '-' %></span>
            </div>
            <div class="col-md-4">
              <small class="text-muted d-block">Estado</small>
              <span class="badge fs-6 bg-<%= factura.estado === 'pendiente' ? 'warning' : factura.estado === 'pagada' ? 'success' : 'danger' %>">
                <%= factura.estado %>
              </span>
            </div>
            <div class="col-md-4">
              <small class="text-muted d-block">Email enviado</small>
              <span><%- factura.email_enviado ? '<span class="badge bg-success"><i class="bi bi-check"></i> Sí</span>' : '<span class="badge bg-secondary">No</span>' %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-header"><i class="bi bi-lightning"></i> Acciones</div>
        <div class="card-body d-flex flex-column gap-2">
          <a href="/isp/nube/pdf/<%= factura.id %>" class="btn btn-info" target="_blank">
            <i class="bi bi-file-pdf"></i> Descargar PDF
          </a>
          <button class="btn btn-primary btn-enviar-email" data-id="<%= factura.id %>">
            <i class="bi bi-envelope"></i> Enviar Email
          </button>
          <% if (factura.estado !== 'pagada') { %>
          <button class="btn btn-success btn-pagar" data-id="<%= factura.id %>">
            <i class="bi bi-check-lg"></i> Marcar Pagada
          </button>
          <% } %>
          <% if (factura.stripe_invoice_id) { %>
          <span class="text-success small text-center"><i class="bi bi-check-circle"></i> Stripe: <%= factura.stripe_invoice_id.substring(0,12) %>...</span>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header"><i class="bi bi-list-columns"></i> Líneas de Factura</div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-dark">
            <tr>
              <th>Concepto</th>
              <th>Línea</th>
              <th>Tipo</th>
              <th class="text-end">Importe</th>
            </tr>
          </thead>
          <tbody>
            <% if (lineas.length === 0) { %>
            <tr><td colspan="4" class="text-center text-muted py-4"><i class="bi bi-inbox"></i> Sin líneas en esta factura</td></tr>
            <% } else { lineas.forEach(function(l) { %>
            <tr>
              <td><%= l.concepto || '-' %></td>
              <td><%= l.linea || '-' %></td>
              <td><span class="badge bg-info"><%= l.tipo || '-' %></span></td>
              <td class="fw-bold text-end"><%= parseFloat(l.importe || 0).toFixed(2) %>€</td>
            </tr>
            <% }) } %>
          </tbody>
          <tfoot>
            <tr class="table-active">
              <td colspan="3" class="fw-bold text-end">Total</td>
              <td class="fw-bold text-end fs-5"><%= parseFloat(factura.importe_total || 0).toFixed(2) %>€</td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>

  <% if (cdrsDetalle && cdrsDetalle.length > 0) { %>
  <div class="card mt-3">
    <div class="card-header"><i class="bi bi-graph-up"></i> CDRs - Consumos del periodo</div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>Concepto</th>
              <th>Línea</th>
              <th>Tipo</th>
              <th class="text-end">Unidades</th>
              <th class="text-end">Importe</th>
            </tr>
          </thead>
          <tbody>
            <% cdrsDetalle.forEach(function(c) { %>
            <tr>
              <td><%= c.concepto || '-' %></td>
              <td><%= c.linea || '-' %></td>
              <td><span class="badge bg-warning"><%= c.tipo || '-' %></span></td>
              <td class="text-end"><%= c.unidades || '-' %></td>
              <td class="fw-bold text-end"><%= parseFloat(c.importe || 0).toFixed(2) %>€</td>
            </tr>
            <% }) %>
          </tbody>
          <tfoot>
            <tr class="table-active">
              <td colspan="4" class="fw-bold text-end">Total CDRs</td>
              <td class="fw-bold text-end"><%= cdrsDetalle.reduce(function(s,c){ return s + parseFloat(c.importe||0); }, 0).toFixed(2) %>€</td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>
  <% } %>

  <% if (llamadas && llamadas.length > 0) { %>
  <div class="card mt-3">
    <div class="card-header"><i class="bi bi-telephone"></i> Historial de llamadas (<%= llamadas.length %> registros)</div>
    <div class="card-body p-0">
      <div class="table-responsive" style="max-height:400px;">
        <table class="table table-sm table-hover mb-0 align-middle">
          <thead class="table-light" style="position:sticky;top:0;">
            <tr>
              <th>Fecha</th>
              <th>Hora</th>
              <th>Destino</th>
              <th>Grupo</th>
              <th>Duración</th>
              <th class="text-end">Importe</th>
            </tr>
          </thead>
          <tbody>
            <% llamadas.forEach(function(c) { %>
            <tr>
              <td><%= c.fecha || '-' %></td>
              <td><%= c.hora || '-' %></td>
              <td><%= c.destino || '-' %></td>
              <td><%= c.grupo || '-' %></td>
              <td><%= c.duracion || '-' %></td>
              <td class="fw-bold text-end"><%= parseFloat(c.importe || 0).toFixed(2) %>€</td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% } %>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelector('.btn-enviar-email')?.addEventListener('click', function() {
    const id = this.dataset.id;
    const btn = this;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Enviando...';
    fetch('/isp/facturacion/facturas/' + id + '/enviar', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
      .then(r => r.json())
      .then(d => {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-envelope"></i> Enviar Email';
        if (d.ok) {
          alert('✅ Email enviado correctamente');
          location.reload();
        } else {
          alert('❌ Error: ' + (d.error || 'desconocido'));
        }
      })
      .catch(function(err) {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-envelope"></i> Enviar Email';
        alert('❌ Error de conexión: ' + err.message);
      });
  });

  document.querySelector('.btn-pagar')?.addEventListener('click', function() {
    if (!confirm('¿Marcar esta factura como pagada?')) return;
    const id = this.dataset.id;
    fetch('/isp/facturacion/facturas/' + id + '/pagar', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
      .then(r => r.json())
      .then(d => {
        if (d.ok) { location.reload(); }
        else { alert('Error: ' + (d.error || 'desconocido')); }
      })
      .catch(() => { alert('Error de conexión'); });
  });
});
</script>