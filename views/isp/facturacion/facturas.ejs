<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-list-ul"></i> Facturas <span class="badge bg-secondary fs-6"><%= facturas.length %></span></h2>
    <a href="/isp/facturacion" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Volver</a>
  </div>

  <div class="card mb-3">
    <div class="card-body py-2">
      <div class="row g-2 align-items-center">
        <div class="col-md-4">
          <input type="text" class="form-control form-control-sm" id="searchFactura" placeholder="Buscar cliente o ID...">
        </div>
        <div class="col-md-2">
          <select class="form-select form-select-sm" id="filterEstado">
            <option value="">Todos los estados</option>
            <option value="pendiente">Pendiente</option>
            <option value="pagada">Pagada</option>
            <option value="vencida">Vencida</option>
          </select>
        </div>
        <div class="col-md-2">
          <button class="btn btn-outline-secondary btn-sm w-100" id="btnLimpiarFiltros"><i class="bi bi-x-circle"></i> Limpiar</button>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle" id="facturasTable">
          <thead class="table-dark">
            <tr>
              <th>#</th>
              <th>Cliente</th>
              <th>Periodo</th>
              <th>Importe</th>
              <th>Estado</th>
              <th>Emisión</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (facturas.length === 0) { %>
            <tr><td colspan="7" class="text-center text-muted py-4"><i class="bi bi-inbox"></i> No hay facturas registradas</td></tr>
            <% } else { facturas.forEach(function(f) { %>
            <tr class="factura-row">
              <td class="fw-bold">#<%= f.id %></td>
              <td><%= f.cliente_nombre || '-' %></td>
              <td><%= f.periodo || '-' %></td>
              <td class="fw-bold"><%= parseFloat(f.importe_total || 0).toFixed(2) %>€</td>
              <td>
                <span class="badge fs-6 bg-<%= f.estado === 'pendiente' ? 'warning' : f.estado === 'pagada' ? 'success' : 'danger' %>">
                  <%= f.estado %>
                </span>
              </td>
              <td class="small"><%= f.fecha_emision ? new Date(f.fecha_emision).toLocaleDateString('es-ES') : '-' %></td>
              <td class="text-end">
                <a href="/isp/facturacion/facturas/<%= f.id %>" class="btn btn-sm btn-outline-info" title="Ver"><i class="bi bi-eye"></i></a>
                <button class="btn btn-sm btn-outline-primary btn-enviar-email" data-id="<%= f.id %>" title="Enviar email"><i class="bi bi-envelope"></i></button>
                <% if (f.estado !== 'pagada') { %>
                <button class="btn btn-sm btn-outline-success btn-pagar" data-id="<%= f.id %>" title="Pagar"><i class="bi bi-check-lg"></i></button>
                <% } %>
              </td>
            </tr>
            <% }) } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('searchFactura');
  const filterEstado = document.getElementById('filterEstado');
  const btnLimpiar = document.getElementById('btnLimpiarFiltros');

  function filtrar() {
    const q = searchInput ? searchInput.value.toLowerCase().trim() : '';
    const est = filterEstado ? filterEstado.value : '';
    document.querySelectorAll('.factura-row').forEach(function(row) {
      const id = row.querySelector('td:nth-child(1)')?.textContent.toLowerCase() || '';
      const cliente = row.querySelector('td:nth-child(2)')?.textContent.toLowerCase() || '';
      const estado = row.querySelector('td:nth-child(5) .badge')?.textContent.trim().toLowerCase() || '';
      const matchTexto = !q || id.includes(q) || cliente.includes(q);
      const matchEstado = !est || estado === est;
      row.style.display = matchTexto && matchEstado ? '' : 'none';
    });
  }

  if (searchInput) searchInput.addEventListener('input', filtrar);
  if (filterEstado) filterEstado.addEventListener('change', filtrar);
  if (btnLimpiar) btnLimpiar.addEventListener('click', function() {
    if (searchInput) searchInput.value = '';
    if (filterEstado) filterEstado.value = '';
    filtrar();
  });

  document.querySelectorAll('.btn-enviar-email').forEach(function(b) {
    b.addEventListener('click', function() {
      const id = this.dataset.id;
      fetch('/isp/facturacion/facturas/' + id + '/enviar', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
        .then(r => r.json())
        .then(d => { alert(d.ok ? 'Email enviado correctamente' : 'Error: ' + (d.error || 'desconocido')); })
        .catch(() => { alert('Error de conexión'); });
    });
  });

  document.querySelectorAll('.btn-pagar').forEach(function(b) {
    b.addEventListener('click', function() {
      if (!confirm('¿Marcar esta factura como pagada?')) return;
      const id = this.dataset.id;
      fetch('/isp/facturacion/facturas/' + id + '/pagar', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
        .then(r => r.json())
        .then(d => {
          if (d.ok) { location.reload(); }
          else { alert('Error: ' + (d.error || 'desconocido')); }
        })
        .catch(() => { alert('Error de conexión'); });
    });
  });
});
</script>
