<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-journal-check"></i> Arqueos de Caja</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#arqueoModal" onclick="limpiarArqueo()"><i class="bi bi-plus-lg"></i> Nuevo Arqueo</button>
  </div>
  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle" id="arqueosTable">
          <thead class="table-dark">
            <tr>
              <th>Fecha</th>
              <th>Ing. Efectivo</th>
              <th>Ing. Tarjeta</th>
              <th>Ing. Transferencia</th>
              <th>Total Ingresos</th>
              <th>Gastos</th>
              <th>Saldo</th>
              <th>Usuario</th>
            </tr>
          </thead>
          <tbody>
            <% if (arqueos.length === 0) { %>
            <tr><td colspan="8" class="text-center text-muted py-4"><i class="bi bi-inbox"></i> No hay arqueos registrados</td></tr>
            <% } else { arqueos.forEach(a => { 
              var totalIng = parseFloat(a.ingresos_efectivo || 0) + parseFloat(a.ingresos_tarjeta || 0) + parseFloat(a.ingresos_transferencia || 0);
              var gastos = parseFloat(a.gastos || 0);
            %>
            <tr>
              <td class="fw-bold"><%= a.fecha %></td>
              <td><%= parseFloat(a.ingresos_efectivo || 0).toFixed(2) %>€</td>
              <td><%= parseFloat(a.ingresos_tarjeta || 0).toFixed(2) %>€</td>
              <td><%= parseFloat(a.ingresos_transferencia || 0).toFixed(2) %>€</td>
              <td class="text-success fw-bold"><%= totalIng.toFixed(2) %>€</td>
              <td class="text-danger fw-bold"><%= gastos.toFixed(2) %>€</td>
              <td class="fw-bold"><%= (totalIng - gastos).toFixed(2) %>€</td>
              <td><%= a.user_name || '-' %></td>
            </tr>
            <% }) } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<div class="modal fade" id="arqueoModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" action="/isp/caja/arqueos/crear">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-journal-check"></i> Nuevo Arqueo</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Fecha</label>
              <input type="date" name="fecha" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">Ing. Efectivo (€)</label>
              <input type="number" step="0.01" name="ingresos_efectivo" class="form-control" value="0">
            </div>
            <div class="col-md-4">
              <label class="form-label">Ing. Tarjeta (€)</label>
              <input type="number" step="0.01" name="ingresos_tarjeta" class="form-control" value="0">
            </div>
            <div class="col-md-4">
              <label class="form-label">Ing. Transferencia (€)</label>
              <input type="number" step="0.01" name="ingresos_transferencia" class="form-control" value="0">
            </div>
            <div class="col-md-6">
              <label class="form-label">Gastos (€)</label>
              <input type="number" step="0.01" name="gastos" class="form-control" value="0">
            </div>
            <div class="col-12">
              <label class="form-label">Observaciones</label>
              <textarea name="observaciones" class="form-control" rows="3"></textarea>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Guardar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  if (typeof $.fn.DataTable !== 'undefined' && document.querySelectorAll('#arqueosTable tbody tr').length > 1) {
    new DataTable('#arqueosTable', {
      language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es.json' },
      pageLength: 25,
      order: [[0, 'desc']]
    });
  }
});
function limpiarArqueo() {
  document.querySelector('#arqueoModal input[name="fecha"]').value = new Date().toISOString().split('T')[0];
  ['ingresos_efectivo','ingresos_tarjeta','ingresos_transferencia','gastos'].forEach(n => {
    document.querySelector('#arqueoModal input[name="' + n + '"]').value = '0';
  });
  document.querySelector('#arqueoModal textarea').value = '';
}
</script>
