<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-megaphone"></i> Campa&ntilde;as <span class="badge bg-secondary fs-6"><%= campanas.length %></span></h5>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createCampanaModal"><i class="bi bi-plus-lg"></i> Nueva Campa&ntilde;a</button>
  </div>
  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle" id="campanasTable">
          <thead class="table-dark">
            <tr>
              <th>Nombre</th>
              <th>Tipo</th>
              <th>Estado</th>
              <th>Inicio</th>
              <th>Fin</th>
              <th>Presupuesto</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (campanas.length === 0) { %>
            <tr><td colspan="7" class="text-center text-muted py-4"><i class="bi bi-megaphone"></i> No hay campa&ntilde;as registradas</td></tr>
            <% } else { %>
              <% campanas.forEach(c => { %>
              <tr>
                <td><a href="/isp/campanas/<%= c.id %>" class="fw-bold"><%= c.nombre %></a></td>
                <td><%= c.tipo || '-' %></td>
                <td>
                  <span class="badge bg-<%= c.estado === 'activa' ? 'success' : c.estado === 'pausada' ? 'warning' : 'secondary' %> fs-6"><%= c.estado %></span>
                </td>
                <td class="small"><%= c.fecha_inicio ? new Date(c.fecha_inicio).toLocaleDateString('es-ES') : '-' %></td>
                <td class="small"><%= c.fecha_fin ? new Date(c.fecha_fin).toLocaleDateString('es-ES') : '-' %></td>
                <td><%= c.presupuesto ? c.presupuesto + ' €' : '-' %></td>
                <td class="text-end">
                  <a href="/isp/campanas/<%= c.id %>" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
<div class="modal fade" id="createCampanaModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-plus-circle"></i> Nueva Campa&ntilde;a</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/isp/campanas/create">
        <div class="modal-body">
          <% if (typeof errors !== 'undefined' && errors.length > 0) { %><div class="alert alert-danger"><%= errors.join(', ') %></div><% } %>
          <div class="mb-3">
            <label class="form-label">Nombre *</label>
            <input type="text" name="nombre" class="form-control" required>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label class="form-label">Tipo</label>
              <select name="tipo" class="form-select">
                <option value="email">Email</option>
                <option value="sms">SMS</option>
                <option value="redes">Redes Sociales</option>
                <option value="telefono">Tel&eacute;fono</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Estado</label>
              <select name="estado" class="form-select">
                <option value="borrador">Borrador</option>
                <option value="activa">Activa</option>
                <option value="pausada">Pausada</option>
              </select>
            </div>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label class="form-label">Fecha de Inicio</label>
              <input type="date" name="fecha_inicio" class="form-control">
            </div>
            <div class="col-md-6">
              <label class="form-label">Fecha de Fin</label>
              <input type="date" name="fecha_fin" class="form-control">
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Presupuesto (€)</label>
            <input type="number" step="0.01" name="presupuesto" class="form-control">
          </div>
          <div class="mb-3">
            <label class="form-label">Descripci&oacute;n</label>
            <textarea name="descripcion" class="form-control" rows="3"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Crear Campa&ntilde;a</button>
        </div>
      </form>
    </div>
  </div>
</div>
