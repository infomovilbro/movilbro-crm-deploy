<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-people"></i> Clientes con Contrato <span class="badge bg-secondary fs-6"><%= clientes.length %></span></h5>
  </div>

  <div class="card mb-3">
    <div class="card-body py-2">
      <div class="row g-2 align-items-center">
        <div class="col-md-4">
          <input type="text" class="form-control form-control-sm" id="searchCliente" placeholder="Buscar nombre, NIF o teléfono...">
        </div>
        <div class="col-md-2">
          <button class="btn btn-outline-secondary btn-sm w-100" id="btnLimpiarCliente"><i class="bi bi-x-circle"></i> Limpiar</button>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-dark">
            <tr>
              <th>#</th>
              <th>Nombre</th>
              <th>DNI/NIF</th>
              <th>Teléfono</th>
              <th>Email</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (clientes.length === 0) { %>
            <tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-inbox"></i> No hay clientes con contrato</td></tr>
            <% } else { %>
              <% clientes.forEach(function(c) { %>
              <tr class="cliente-row">
                <td><%= c.id %></td>
                <td class="fw-semibold"><%= c.nombre %> <%= c.apellidos || '' %></td>
                <td><%= c.dni_nif || '-' %></td>
                <td><%= c.telefono || '-' %></td>
                <td><%= c.email || '-' %></td>
                <td class="text-end">
                  <a href="/isp/clientes/detalle/<%= c.id %>" class="btn btn-sm btn-outline-info" title="Detalle ISP"><i class="bi bi-eye"></i></a>
                  <a href="/isp/contratos?cliente=<%= c.id %>" class="btn btn-sm btn-outline-primary" title="Contratos"><i class="bi bi-file-text"></i></a>
                  <a href="/customers/<%= c.id %>" class="btn btn-sm btn-outline-secondary" title="Ficha principal"><i class="bi bi-box-arrow-up-right"></i></a>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('searchCliente');
  const btnLimpiar = document.getElementById('btnLimpiarCliente');

  function filtrar() {
    const q = searchInput ? searchInput.value.toLowerCase().trim() : '';
    document.querySelectorAll('.cliente-row').forEach(function(row) {
      const nombre = row.querySelector('td:nth-child(2)')?.textContent.toLowerCase() || '';
      const nif = row.querySelector('td:nth-child(3)')?.textContent.toLowerCase() || '';
      const telf = row.querySelector('td:nth-child(4)')?.textContent.toLowerCase() || '';
      row.style.display = !q || nombre.includes(q) || nif.includes(q) || telf.includes(q) ? '' : 'none';
    });
  }

  if (searchInput) searchInput.addEventListener('input', filtrar);
  if (btnLimpiar) btnLimpiar.addEventListener('click', function() {
    if (searchInput) searchInput.value = '';
    filtrar();
  });
});
</script>
