<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-router"></i> Equipos <span class="badge bg-secondary fs-6"><%= equipos.length %></span></h5>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createEquipoModal"><i class="bi bi-plus-lg"></i> Nuevo Equipo</button>
  </div>
  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle" id="equiposTable">
          <thead class="table-dark">
            <tr>
              <th>Nombre</th>
              <th>Nodo</th>
              <th>Tipo</th>
              <th>Fabricante</th>
              <th>Modelo</th>
              <th>MAC</th>
              <th>IP</th>
              <th>Cliente</th>
              <th>Estado</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (equipos.length === 0) { %>
            <tr><td colspan="10" class="text-center text-muted py-4"><i class="bi bi-router"></i> No hay equipos registrados</td></tr>
            <% } else { %>
              <% equipos.forEach(e => { %>
              <tr>
                <td><a href="/isp/equipos/<%= e.id %>" class="fw-bold"><%= e.nombre %></a></td>
                <td><%= e.nodo_nombre || '-' %></td>
                <td><%= e.tipo || '-' %></td>
                <td><%= e.fabricante || '-' %></td>
                <td><%= e.modelo || '-' %></td>
                <td><code><%= e.mac || '-' %></code></td>
                <td><code><%= e.ip || '-' %></code></td>
                <td><%= e.cliente_nombre || '-' %></td>
                <td>
                  <span class="badge bg-<%= e.estado === 'activo' ? 'success' : e.estado === 'averia' ? 'danger' : e.estado === 'mantenimiento' ? 'warning' : 'secondary' %> fs-6"><%= e.estado %></span>
                </td>
                <td class="text-end">
                  <button class="btn btn-sm btn-outline-danger" onclick="eliminarEquipo(<%= e.id %>)"><i class="bi bi-trash"></i></button>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
<div class="modal fade" id="createEquipoModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-plus-circle"></i> Nuevo Equipo</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/isp/equipos/create">
        <div class="modal-body">
          <% if (typeof errors !== 'undefined' && errors.length > 0) { %><div class="alert alert-danger"><%= errors.join(', ') %></div><% } %>
          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label class="form-label">Nombre *</label>
              <input type="text" name="nombre" class="form-control" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Nodo</label>
              <select name="nodo_id" class="form-select">
                <option value="">Sin nodo</option>
                <% if (typeof nodos !== 'undefined') { nodos.forEach(n => { %>
                <option value="<%= n.id %>"><%= n.nombre %></option>
                <% }) } %>
              </select>
            </div>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-md-4">
              <label class="form-label">Tipo</label>
              <select name="tipo" class="form-select">
                <option value="router">Router</option>
                <option value="switch">Switch</option>
                <option value="ont">ONT</option>
                <option value="ap">Access Point</option>
                <option value="cpe">CPE</option>
                <option value="servidor">Servidor</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Fabricante</label>
              <input type="text" name="fabricante" class="form-control">
            </div>
            <div class="col-md-4">
              <label class="form-label">Modelo</label>
              <input type="text" name="modelo" class="form-control">
            </div>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-md-4">
              <label class="form-label">MAC</label>
              <input type="text" name="mac" class="form-control" placeholder="00:00:00:00:00:00">
            </div>
            <div class="col-md-4">
              <label class="form-label">IP</label>
              <input type="text" name="ip" class="form-control" placeholder="192.168.1.1">
            </div>
            <div class="col-md-4">
              <label class="form-label">Cliente</label>
              <select name="client_id" class="form-select">
                <option value="">Sin cliente</option>
                <% clientes.forEach(c => { %>
                <option value="<%= c.id %>"><%= c.nombre %> <%= c.apellidos || '' %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Estado</label>
            <select name="estado" class="form-select">
              <option value="activo">Activo</option>
              <option value="averia">Aver&iacute;a</option>
              <option value="mantenimiento">Mantenimiento</option>
              <option value="inactivo">Inactivo</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Crear Equipo</button>
        </div>
      </form>
    </div>
  </div>
</div>
<script>
function eliminarEquipo(id) {
  if (!confirm('¿Eliminar este equipo?')) return;
  fetch('/isp/equipos/' + id + '/delete', { method: 'POST' })
    .then(function(r) { return r.json(); })
    .then(function(d) { if (d.success) location.reload(); else alert('Error al eliminar'); })
    .catch(function() { alert('Error de conexi&oacute;n'); });
}
</script>
