<section>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="ri-whatsapp-line text-success"></i> <%= ui.moduleName.whatsapp %></h2>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-5">
      <div class="card">
        <div class="card-header"><i class="ri-people-line"></i> Clientes con WhatsApp</div>
        <div class="card-body p-0">
          <div class="p-2">
            <input type="text" id="waSearch" class="form-control form-control-sm" placeholder="Buscar cliente..." onkeyup="filterWAClients()">
          </div>
          <div id="waClientList" style="max-height:500px;overflow-y:auto;">
            <% if (clientes.length === 0) { %>
            <div class="text-center text-muted py-4">No hay clientes con teléfono</div>
            <% } else { clientes.forEach(c => { 
              const phoneClean = c.telefono ? c.telefono.replace(/[^\d]/g, '') : '';
            %>
            <div class="wa-client d-flex align-items-center px-3 py-2 border-bottom" data-name="<%= (c.nombre + ' ' + (c.apellidos || '')).toLowerCase() %>">
              <div class="avatar bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-2 flex-shrink-0" style="width:42px;height:42px;font-weight:600;">
                <%= c.nombre.charAt(0).toUpperCase() %>
              </div>
              <div class="flex-grow-1 min-w-0">
                <div class="fw-bold small"><%= c.nombre %> <%= c.apellidos || '' %></div>
                <div class="text-muted small"><%= c.telefono %></div>
              </div>
              <% if (phoneClean) { %>
              <a href="/whatsapp?phone=<%= phoneClean %>" class="btn btn-sm btn-success" style="border-radius:20px;">
                <i class="ri-chat-1-line"></i> Chat
              </a>
              <% } %>
            </div>
            <% }); } %>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-7">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span><i class="ri-whatsapp-line text-success"></i> WhatsApp Web</span>
          <div class="d-flex gap-2">
            <input type="text" id="waPhoneInput" class="form-control form-control-sm" style="width:200px;" placeholder="Teléfono (ej. 34612345678)" value="<%= typeof phone !== 'undefined' ? phone : '' %>">
            <button class="btn btn-success btn-sm" onclick="openWAChat()"><i class="ri-send-plane-line"></i> Abrir chat</button>
          </div>
        </div>
        <div class="card-body p-0" style="height:600px;position:relative;">
          <% if (phone) { %>
          <iframe id="waIframe" src="/proxy/web.whatsapp.com/send?phone=<%= phone %>" style="width:100%;height:100%;border:none;" allow="camera;microphone"></iframe>
          <% } else { %>
          <iframe id="waIframe" src="/proxy/web.whatsapp.com" style="width:100%;height:100%;border:none;" allow="camera;microphone"></iframe>
          <% } %>
          <div id="waOverlay" style="position:absolute;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,0.9);display:flex;align-items:center;justify-content:center;flex-direction:column;z-index:10;cursor:pointer;" onclick="hideOverlay()">
            <i class="ri-whatsapp-line" style="font-size:4rem;color:#25D366;"></i>
            <h4 class="mt-3">WhatsApp Web</h4>
            <p class="text-muted">Haz clic para cargar WhatsApp Web</p>
            <button class="btn btn-success btn-lg" onclick="hideOverlay()"><i class="ri-play-circle-line"></i> Cargar</button>
          </div>
        </div>
      </div>
      <% if (phone) { %>
      <div class="alert alert-success mt-2 py-2">
        <i class="ri-checkbox-circle-line"></i> Chat pre-seleccionado: <strong>+<%= phone %></strong>
      </div>
      <% } %>
    </div>
  </div>
</section>

<script>
function filterWAClients() {
  const q = document.getElementById('waSearch').value.toLowerCase();
  document.querySelectorAll('.wa-client').forEach(el => {
    el.style.display = el.dataset.name.includes(q) ? '' : 'none';
  });
}

function hideOverlay() {
  document.getElementById('waOverlay').style.display = 'none';
}

function openWAChat() {
  const phone = document.getElementById('waPhoneInput').value.trim();
  if (!phone) { alert('Introduce un número de teléfono'); return; }
  const cleanPhone = phone.replace(/[^\d]/g, '');
  if (cleanPhone) {
    document.getElementById('waIframe').src = '/proxy/web.whatsapp.com/send?phone=' + cleanPhone;
    hideOverlay();
  }
}

// Auto-load if phone param present
document.addEventListener('DOMContentLoaded', function() {
  const phoneInput = document.getElementById('waPhoneInput');
  if (phoneInput && phoneInput.value) {
    setTimeout(() => hideOverlay(), 1000);
  }
});
</script>
